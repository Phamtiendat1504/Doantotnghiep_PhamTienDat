rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userExists(uid) {
      return exists(/databases/$(database)/documents/users/$(uid));
    }

    function isAdmin() {
      return isSignedIn()
        && userExists(request.auth.uid)
        && userDoc(request.auth.uid).data.role == "admin";
    }

    function canPostRoom() {
      return isSignedIn()
        && (
          isAdmin()
          || (
            userExists(request.auth.uid)
            && userDoc(request.auth.uid).data.isVerified == true
            && (
              !("postingUnlockAt" in userDoc(request.auth.uid).data)
              || userDoc(request.auth.uid).data.postingUnlockAt <= request.time.toMillis()
            )
          )
        );
    }

    function isAppointmentParticipant(apptId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/appointments/$(apptId))
        && (
          isAdmin()
          || request.auth.uid == get(/databases/$(database)/documents/appointments/$(apptId)).data.tenantId
          || request.auth.uid == get(/databases/$(database)/documents/appointments/$(apptId)).data.landlordId
        );
    }

    function isChatParticipant(chatId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
    }

    function isSupportTicketOwner(ticketId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/support_tickets/$(ticketId))
        && get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid;
    }

    function isSupportTicketOwnerAfter(ticketId) {
      return isSignedIn()
        && getAfter(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid;
    }

    // Dùng cho bookedSlots create trong Transaction (appointment chưa commit khi rules chạy)
    // existsAfter/getAfter đánh giá trạng thái SAU KHI tất cả writes trong transaction được áp dụng
    function isAppointmentParticipantAfter(apptId) {
      return isSignedIn()
        && existsAfter(/databases/$(database)/documents/appointments/$(apptId))
        && (
          isAdmin()
          || request.auth.uid == getAfter(/databases/$(database)/documents/appointments/$(apptId)).data.tenantId
          || request.auth.uid == getAfter(/databases/$(database)/documents/appointments/$(apptId)).data.landlordId
        );
    }

    // USERS
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      allow create: if isAdmin() || (
        isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role == "user"
        && request.resource.data.isVerified == false
        && request.resource.data.isLocked == false
        && request.resource.data.lockUntil == 0
      );

      allow update: if isAdmin() || (
        isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.role in ["user", "pending"]
        && (
          request.resource.data.diff(resource.data).changedKeys().hasOnly([
            "fullName",
            "email",
            "phone",
            "address",
            "birthday",
            "gender",
            "occupation",
            "avatarUrl",
            "fcmToken",
            "lastLoginAt",
            "isOnline",
            "lastSeen",
            "hasAcceptedRules",
            "role",
            "dailyPostCount",
            "dailyPostCountDate"
          ])
          || (
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              "purchasedSlots",
              "lastSlotConsumedAt"
            ])
            && resource.data.purchasedSlots is int
            && resource.data.purchasedSlots > 0
            && request.resource.data.purchasedSlots == resource.data.purchasedSlots - 1
            && request.resource.data.lastSlotConsumedAt is int
          )
        )
      );

      allow delete: if isAdmin();

      match /ai_conversations/{messageId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // ROOMS
    match /rooms/{roomId} {
      allow read: if resource.data.status in ["approved", "expired"]
                  || (isSignedIn() && resource.data.userId == request.auth.uid)
                  || isAdmin();

      allow create: if canPostRoom()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == "pending";

      allow update: if isAdmin()
                    || (
                      isSignedIn()
                      && resource.data.userId == request.auth.uid
                      && request.resource.data.userId == resource.data.userId
                      && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                        "featuredRequestStatus",
                        "featuredRequestId",
                        "featuredRequestUpdatedAt"
                      ])
                      && request.resource.data.featuredRequestStatus in [
                        "waiting_for_payment",
                        "paid_waiting_admin",
                        "cancelled"
                      ]
                    )
                    || (
                      isSignedIn()
                      && resource.data.userId == request.auth.uid
                      && request.resource.data.userId == resource.data.userId
                      && !request.resource.data.diff(resource.data).changedKeys().hasAny([
                        "isFeatured",
                        "featuredStartAt",
                        "featuredUntil",
                        "featuredPackageCode",
                        "featuredPaymentId",
                        "featuredRequestId"
                      ])
                    );

      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // VERIFICATIONS
    match /verifications/{userId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);

      allow create: if isSignedIn()
                    && request.auth.uid == userId
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == "pending";

      allow update: if isAdmin()
                    || (
                      isSignedIn()
                      && request.auth.uid == userId
                      && request.resource.data.userId == request.auth.uid
                      && request.resource.data.status == "pending"
                    );

      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // APPOINTMENTS
    match /appointments/{apptId} {
      allow read: if isAdmin()
                  || (
                    isSignedIn()
                    && (
                      request.auth.uid == resource.data.tenantId
                      || request.auth.uid == resource.data.landlordId
                    )
                  );

      allow create: if isSignedIn()
                    && request.resource.data.tenantId == request.auth.uid
                    && request.resource.data.status == "pending";

      allow update: if isAdmin()
                    || (
                      isSignedIn()
                      && (
                        request.auth.uid == resource.data.tenantId
                        || request.auth.uid == resource.data.landlordId
                      )
                      && request.resource.data.tenantId == resource.data.tenantId
                      && request.resource.data.landlordId == resource.data.landlordId
                      && request.resource.data.roomId == resource.data.roomId
                      && request.resource.data.createdAt == resource.data.createdAt
                    );

      allow delete: if isAdmin()
                    || (
                      isSignedIn()
                      && (
                        request.auth.uid == resource.data.tenantId
                        || request.auth.uid == resource.data.landlordId
                      )
                    );
    }

    // BOOKED SLOTS
    match /bookedSlots/{slotId} {
      allow read: if isSignedIn();
      // Dùng isAppointmentParticipantAfter vì appointment được tạo đồng thời trong cùng Transaction
      allow create: if isAdmin() || isAppointmentParticipantAfter(request.resource.data.appointmentId);
      // update/delete: appointment đã tồn tại sẵn → dùng exists() thông thường là đúng
      allow update, delete: if isAdmin() || isAppointmentParticipant(resource.data.appointmentId);
    }

    // SAVED POSTS
    match /savedPosts/{docId} {
      allow read: if isSignedIn()
                  && (
                    isAdmin()
                    || resource == null
                    || resource.data.userId == request.auth.uid
                  );

      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;

      allow update, delete: if isSignedIn()
                            && (
                              isAdmin()
                              || resource.data.userId == request.auth.uid
                            );
    }

    // SLOT UPGRADE PAYMENTS
    match /slot_upgrade_requests/{requestId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.uid == request.auth.uid);

      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.requestId == requestId
                    && request.resource.data.status == "waiting_for_payment"
                    && request.resource.data.amount is number
                    && request.resource.data.slots is number
                    && request.resource.data.createdAt is number
                    && request.resource.data.expiresAt is number;

      allow update: if isAdmin()
                    || (
                      isSignedIn()
                      && resource.data.uid == request.auth.uid
                      && resource.data.status == "waiting_for_payment"
                      && request.resource.data.uid == resource.data.uid
                      && request.resource.data.requestId == resource.data.requestId
                      && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                        "status",
                        "cancelledAt",
                        "updatedAt"
                      ])
                      && request.resource.data.status == "cancelled"
                    );

      allow delete: if isAdmin();
    }

    // FEATURED UPGRADE PAYMENTS
    match /featured_upgrade_requests/{requestId} {
      allow read: if isAdmin()
                  || (isSignedIn() && resource.data.uid == request.auth.uid);

      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.requestId == requestId
                    && request.resource.data.status == "waiting_for_payment"
                    && request.resource.data.approvalStatus == "pending_payment"
                    && request.resource.data.roomId is string
                    && request.resource.data.amount is number
                    && request.resource.data.days is number
                    && request.resource.data.createdAt is number
                    && request.resource.data.expiresAt is number;

      allow update: if isAdmin()
                    || (
                      isSignedIn()
                      && resource.data.uid == request.auth.uid
                      && resource.data.status == "waiting_for_payment"
                      && request.resource.data.uid == resource.data.uid
                      && request.resource.data.requestId == resource.data.requestId
                      && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                        "status",
                        "approvalStatus",
                        "cancelledAt",
                        "updatedAt"
                      ])
                      && request.resource.data.status == "cancelled"
                      && request.resource.data.approvalStatus == "cancelled"
                    );

      allow delete: if isAdmin();
    }

    // REVIEWS
    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.landlordId is string
                    && request.resource.data.landlordId != request.auth.uid
                    && request.resource.data.roomId is string
                    && request.resource.data.rating is number
                    && request.resource.data.rating >= 1
                    && request.resource.data.rating <= 5
                    && request.resource.data.comment is string
                    && request.resource.data.status in ["pending", "approved"];

      allow update: if isAdmin()
                    || (
                      isSignedIn()
                      && resource.data.userId == request.auth.uid
                      && request.resource.data.userId == resource.data.userId
                      && request.resource.data.landlordId == resource.data.landlordId
                      && request.resource.data.roomId == resource.data.roomId
                      && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                        "rating",
                        "comment",
                        "updatedAt"
                      ])
                    );

      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // NOTIFICATIONS
    match /notifications/{docId} {
      allow read: if isSignedIn()
                  && (
                    isAdmin()
                    || request.auth.uid == resource.data.userId
                  );

      allow create: if isSignedIn()
                    && request.resource.data.userId is string
                    && request.resource.data.title is string
                    && request.resource.data.message is string
                    && request.resource.data.createdAt is number
                    && request.resource.data.seen == false;

      allow update, delete: if isSignedIn()
                            && (
                              isAdmin()
                              || request.auth.uid == resource.data.userId
                            );
    }

    // CHATS
    match /chats/{chatId} {
      allow read: if isSignedIn()
                  && (resource == null || request.auth.uid in resource.data.participants);

      allow create: if isSignedIn()
                    && request.auth.uid in request.resource.data.participants;

      allow update, delete: if isSignedIn()
                            && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isChatParticipant(chatId);

        allow create: if isChatParticipant(chatId)
                      && request.auth.uid == request.resource.data.senderId
                      && request.resource.data.createdAt is number;

        allow update, delete: if isChatParticipant(chatId);
      }
    }

    // SUPPORT TICKETS
    match /support_tickets/{ticketId} {
      allow read: if isAdmin()
                  || (
                    isSignedIn()
                    && resource.data.userId == request.auth.uid
                  );

      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == "new"
                    && request.resource.data.priority in ["normal", "high"]
                    && request.resource.data.unreadForAdmin == true
                    && request.resource.data.unreadForUser == false;

      allow update: if isAdmin()
                    || (
                      isSignedIn()
                      && resource.data.userId == request.auth.uid
                      && request.resource.data.userId == resource.data.userId
                      && request.resource.data.createdAt == resource.data.createdAt
                      && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                        "updatedAt",
                        "lastMessage",
                        "lastSenderRole",
                        "status",
                        "unreadForAdmin",
                        "unreadForUser"
                      ])
                      && request.resource.data.status in ["new", "in_progress", "resolved", "closed"]
                    );

      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isAdmin() || isSupportTicketOwner(ticketId);

        allow create: if (
                        (isSupportTicketOwner(ticketId) || isSupportTicketOwnerAfter(ticketId))
                        && request.resource.data.senderId == request.auth.uid
                        && request.resource.data.senderRole == "user"
                      )
                      || (
                        isAdmin()
                        && request.resource.data.senderRole == "admin"
                      );

        allow update: if isAdmin()
                      || (
                        isSupportTicketOwner(ticketId)
                        && request.resource.data.diff(resource.data).changedKeys().hasOnly(["seenByUser"])
                      );

        allow delete: if isAdmin();
      }
    }

    // CCCD REGISTRY
    match /cccd_registry/{cccdNumber} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.cccdNumber == cccdNumber
                    && request.resource.data.createdAt is number
                    && request.resource.data.updatedAt is number;

      allow update: if isSignedIn()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.cccdNumber == resource.data.cccdNumber;

      allow delete: if isAdmin();
    }

    // Broadcast queue
    match /system_notifications/{docId} {
      allow read, write: if isAdmin();
    }

    // Internal checks
    match /checks/{docId} {
      allow read, write: if isAdmin();
    }

    // Server-side OCR counter — user can read/write own counter; admin has full access
    match /verification_counters/{uid} {
      allow read, write: if isAdmin() || request.auth.uid == uid;
    }

    // Phone registry — public read to check duplicate phone during registration
    match /phone_registry/{phone} {
      allow read: if true;

      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.phone == phone;

      allow delete: if isAdmin()
                    || (isSignedIn() && resource.data.uid == request.auth.uid);
    }
  }
}