<resources>

    <!-- ── Màu nền chính (xanh đậm navy) ── -->
    <color name="splash_bg">#0A1628</color>

    <!-- ── Primary brand (xanh nước biển sáng) ── -->
    <color name="splash_primary">#1E88E5</color>

    <!-- ── Accent (xanh sáng hơn cho highlight) ── -->
    <color name="splash_accent">#42A5F5</color>

    <!-- ── Typography ── -->
    <color name="splash_text_primary">#FFFFFF</color>
    <color name="splash_text_secondary">#90CAF9</color>   <!-- xanh nhạt -->
    <color name="splash_text_hint">#B0BEC5</color>         <!-- xám nhạt -->

    <!-- ── Helpers ── -->
    <color name="splash_accent_line">#1E88E5</color>
    <color name="splash_progress_bg">#1A2A4A</color>
    <color name="splash_circle_outline">#1E3A5F</color>
    <color name="splash_circle_fill">#0D1F3C</color>

</resources>


