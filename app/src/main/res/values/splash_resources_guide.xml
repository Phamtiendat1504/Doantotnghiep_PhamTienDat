    <!-- ═══════════════════════════════════════════════════════════════
         HƯỚNG DẪN CÀI ĐẶT FONT (res/font/)
         ═══════════════════════════════════════════════════════════════

         Tải các font Montserrat tại:
         https://fonts.google.com/specimen/Montserrat

         Các file cần:
           res/font/montserrat_bold.ttf
           res/font/montserrat_medium.ttf
           res/font/montserrat_light.ttf

         Hoặc dùng Google Fonts trong build.gradle:
         ─────────────────────────────────────────────
         dependencies {
             implementation "androidx.core:core-ktx:1.12.0"
         }

         Trong res/font/montserrat.xml (Downloadable Font):
         ─────────────────────────────────────────────
         <?xml version="1.0" encoding="utf-8"?>
         <font-family xmlns:app="http://schemas.android.com/apk/res-auto"
             app:fontProviderAuthority="com.google.android.gms.fonts"
             app:fontProviderPackage="com.google.android.gms"
             app:fontProviderQuery="Montserrat"
             app:fontProviderCerts="@array/com_google_android_gms_fonts_certs" />

         ═══════════════════════════════════════════════════════════════ -->