<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:paddingVertical="@dimen/padding_medium"
    android:paddingHorizontal="@dimen/padding_large">

    <!-- Clock Icon representing history -->
    <ImageView
        android:id="@+id/imgHistoryIcon"
        android:layout_width="@dimen/spacing_20"
        android:layout_height="@dimen/spacing_20"
        android:src="@drawable/ic_history"
        android:contentDescription="@null"
        app:tint="@color/text_secondary" />

    <!-- The search keyword text -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvSearchQuery"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/padding_medium"
        android:layout_marginEnd="@dimen/padding_medium"
        android:text="Ví dụ từ khóa"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_14"
        android:singleLine="true"
        android:ellipsize="end" />

    <!-- FrameLayout for larger tap target of delete button -->
    <FrameLayout
        android:id="@+id/btnDeleteQuery"
        android:layout_width="@dimen/image_size_32"
        android:layout_height="@dimen/image_size_32"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="@dimen/spacing_16"
            android:layout_height="@dimen/spacing_16"
            android:layout_gravity="center"
            android:src="@drawable/ic_close"
            android:contentDescription="@null"
            app:tint="@color/text_secondary" />
    </FrameLayout>
</LinearLayout>
