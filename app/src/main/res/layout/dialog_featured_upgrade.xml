<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_surface"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/padding_xlarge">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_ay_bai_noi_bat"
            android:textSize="@dimen/text_size_20"
            android:textStyle="bold"
            android:textColor="@android:color/white" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_thu_hut_nguoi_thue_voi_vi"
            android:textSize="@dimen/text_size_14"
            android:textColor="@color/color_E0F2FE"
            android:layout_marginTop="@dimen/elevation_4" />
    </LinearLayout>

    <!-- Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_xlarge"
        android:background="@android:color/white">

        <!-- Gói 3 ngày -->
        <LinearLayout
            android:id="@+id/layoutFeatured3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_slot_package_normal"
            android:padding="@dimen/padding_large"
            android:layout_marginBottom="@dimen/padding_medium">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_noi_bat_3_ngay"
                    android:textSize="@dimen/text_size_16"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />

            </LinearLayout>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_10_000"
                android:textSize="@dimen/text_size_16"
                android:textStyle="bold"
                android:textColor="@color/primary" />
        </LinearLayout>

        <!-- Gói 7 ngày (Phổ biến) -->
        <LinearLayout
            android:id="@+id/layoutFeatured7"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_slot_package_normal"
            android:backgroundTint="@color/color_F0F9FF"
            android:padding="@dimen/padding_large"
            android:layout_marginBottom="@dimen/padding_medium">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_noi_bat_7_ngay"
                        android:textSize="@dimen/text_size_16"
                        android:textStyle="bold"
                        android:textColor="@color/primary" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_pho_bien"
                        android:textSize="@dimen/text_size_10"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:background="@color/primary"
                        android:paddingStart="@dimen/elevation_6"
                        android:paddingEnd="@dimen/elevation_6"
                        android:paddingTop="@dimen/stroke_2"
                        android:paddingBottom="@dimen/stroke_2"
                        android:layout_marginStart="@dimen/padding_small" />
                </LinearLayout>

            </LinearLayout>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_20_000"
                android:textSize="@dimen/text_size_16"
                android:textStyle="bold"
                android:textColor="@color/primary" />
        </LinearLayout>

        <!-- Gói 15 ngày -->
        <LinearLayout
            android:id="@+id/layoutFeatured15"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_slot_package_normal"
            android:padding="@dimen/padding_large"
            android:layout_marginBottom="@dimen/padding_large">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_noi_bat_15_ngay"
                    android:textSize="@dimen/text_size_16"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />

            </LinearLayout>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_40_000"
                android:textSize="@dimen/text_size_16"
                android:textStyle="bold"
                android:textColor="@color/primary" />
        </LinearLayout>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/txt_hoac_tu_chon_so_ngay_1_ng"
            android:textSize="@dimen/text_size_14"
            android:textColor="@color/color_333333"
            android:textStyle="bold"
            android:layout_marginTop="@dimen/elevation_6"
            android:layout_marginBottom="@dimen/padding_small"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_slot_package_normal"
            android:padding="@dimen/padding_small"
            android:layout_marginBottom="@dimen/padding_xlarge">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtCustomDays"
                android:layout_width="0dp"
                android:layout_height="@dimen/dimen_50dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/txt_nhap_so_ngay"
                android:inputType="number"
                android:paddingStart="@dimen/padding_medium"
                android:paddingEnd="@dimen/padding_medium"
                android:textSize="@dimen/text_size_16"
                android:textColor="@color/primary"
                android:textColorHint="@color/text_hint" />

            <View
                android:layout_width="@dimen/stroke_1"
                android:layout_height="@dimen/dimen_30dp"
                android:background="@color/gray_200"
                android:layout_marginEnd="@dimen/padding_small"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="@dimen/padding_medium">
                
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvCustomPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_0"
                    android:textSize="@dimen/text_size_16"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuyCustom"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dimen_50dp"
                android:text="@string/txt_mua"
                android:textAllCaps="false"
                android:enabled="false"
                app:cornerRadius="@dimen/padding_small" />
        </LinearLayout>

        <!-- Nút Hủy -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelFeatured"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_50dp"
            android:text="@string/action_close"
            android:textAllCaps="false"
            android:textSize="@dimen/text_size_16"
            android:textColor="@color/text_secondary" />
    </LinearLayout>

</LinearLayout>
