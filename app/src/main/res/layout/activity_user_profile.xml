<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- AppBar: Giao diện trắng, sạch sẽ, chuẩn app hiện đại -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:elevation="@dimen/stroke_2">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarProfile"
            android:layout_width="match_parent"
            android:layout_height="?android:attr/actionBarSize"
            app:title="Hồ sơ người dùng"
            app:titleTextColor="@color/color_111827"
            app:navigationIcon="@drawable/ic_back"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/dimen_60dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- THẺ PROFILE CHÍNH (Đã code lại để chống vỡ layout chữ) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/padding_large"
                android:layout_marginTop="@dimen/padding_xlarge"
                app:cardCornerRadius="@dimen/padding_xlarge"
                app:cardElevation="@dimen/elevation_6"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingTop="@dimen/spacing_24"
                    android:paddingBottom="@dimen/spacing_24">

                    <!-- Avatar -->
                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/ivProfileAvatar"
                        android:layout_width="@dimen/dimen_96dp"
                        android:layout_height="@dimen/dimen_96dp"
                        android:src="@drawable/ic_person"
                        app:civ_border_color="@color/primary"
                        app:civ_border_width="@dimen/elevation_3"/>

                    <!-- Tên -->
                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_medium"
                        android:layout_marginHorizontal="@dimen/padding_large"
                        android:text="@string/loading_text"
                        android:textSize="@dimen/dimen_22sp"
                        android:textStyle="bold"
                        android:textColor="@color/color_111827"
                        android:textAlignment="center"/>

                    <!-- Huy hiệu uy tín -->
                    <LinearLayout
                        android:id="@+id/tvProfileVerified"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_small"
                        android:paddingHorizontal="@dimen/padding_medium"
                        android:paddingVertical="@dimen/elevation_6"
                        android:background="@drawable/bg_verified_pill"
                        android:gravity="center_vertical"
                        android:visibility="gone">
                        <ImageView
                            android:layout_width="@dimen/spacing_14"
                            android:layout_height="@dimen/spacing_14"
                            android:src="@drawable/ic_verified_check"
                            app:tint="@color/color_10B981"
                            android:layout_marginEnd="@dimen/elevation_6"/>
                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_tai_khoan_uy_tin"
                            android:textSize="@dimen/text_size_12"
                            android:textStyle="bold"
                            android:textColor="@color/color_10B981"/>
                    </LinearLayout>

                    <!-- Hàng Vai trò & Ngày tham gia (Xếp dọc gọn gàng, icon màu xanh) -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_large"
                        android:orientation="vertical">

                        <!-- Cột Vai trò -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <ImageView
                                android:layout_width="@dimen/padding_large"
                                android:layout_height="@dimen/padding_large"
                                android:src="@drawable/ic_person"
                                app:tint="@color/primary"/>
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvProfileRole"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/padding_small"
                                android:text="@string/txt_khach_thue"
                                android:textSize="@dimen/text_size_14"
                                android:textColor="@color/color_4B5563"/>
                        </LinearLayout>

                        <!-- Cột Ngày tham gia -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/padding_small"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">
                            <ImageView
                                android:layout_width="@dimen/padding_large"
                                android:layout_height="@dimen/padding_large"
                                android:src="@drawable/ic_calendar"
                                app:tint="@color/primary"/>
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvProfileJoinDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/padding_small"
                                android:text="@string/txt_tham_gia"
                                android:textSize="@dimen/text_size_14"
                                android:textColor="@color/color_4B5563"/>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Đường kẻ ngang -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/stroke_1"
                        android:layout_marginHorizontal="@dimen/image_size_32"
                        android:layout_marginTop="@dimen/padding_xlarge"
                        android:background="@color/color_F3F4F6"/>

                    <!-- Thống kê phòng -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="@dimen/image_size_32"
                        android:layout_marginTop="@dimen/padding_xlarge"
                        app:cardCornerRadius="@dimen/padding_large"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="@color/color_EBF5FF">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingVertical="@dimen/padding_large"
                            android:gravity="center">
                            
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvRoomCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_0_1"
                                android:textSize="@dimen/dimen_32sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary"/>
                                
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_phong_tro_a_ang"
                                android:textSize="@dimen/text_size_14"
                                android:textStyle="bold"
                                android:textColor="@color/primary"
                                android:alpha="0.8"
                                android:layout_marginTop="@dimen/stroke_2"/>
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- THẺ THÔNG TIN LIÊN HỆ (Giữ nguyên phần bạn đã ưng ý) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/padding_large"
                android:layout_marginTop="@dimen/padding_xlarge"
                app:cardCornerRadius="@dimen/padding_large"
                app:cardElevation="@dimen/stroke_2"
                app:cardBackgroundColor="@android:color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_xlarge">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_thong_tin_lien_he"
                        android:textSize="@dimen/text_size_18"
                        android:textStyle="bold"
                        android:textColor="@color/color_111827"
                        android:layout_marginBottom="@dimen/padding_large"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="@dimen/padding_small">
                        <FrameLayout
                            android:layout_width="@dimen/dimen_48dp"
                            android:layout_height="@dimen/dimen_48dp"
                            android:background="@drawable/bg_glass_card"
                            android:padding="@dimen/spacing_14">
                            <ImageView
                                android:layout_width="@dimen/padding_xlarge"
                                android:layout_height="@dimen/padding_xlarge"
                                android:src="@drawable/ic_phone"
                                app:tint="@color/primary"/>
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/padding_large">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_so_ien_thoai_1"
                                android:textSize="@dimen/text_size_12"
                                android:textColor="@color/color_9CA3AF"/>
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvProfilePhone"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_chua_cap_nhat"
                                android:textSize="@dimen/text_size_16"
                                android:textStyle="bold"
                                android:textColor="@color/color_1F2937"
                                android:layout_marginTop="@dimen/stroke_2"/>
                        </LinearLayout>
                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/btnCallProfile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_goi_ngay"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_13"
                            android:textStyle="bold"
                            android:paddingHorizontal="@dimen/padding_large"
                            android:paddingVertical="@dimen/padding_small"
                            android:background="@drawable/bg_btn_outline_primary"
                            android:visibility="gone"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingVertical="@dimen/padding_small"
                        android:layout_marginTop="@dimen/padding_small">
                        <FrameLayout
                            android:layout_width="@dimen/dimen_48dp"
                            android:layout_height="@dimen/dimen_48dp"
                            android:background="@drawable/bg_glass_card"
                            android:padding="@dimen/spacing_14">
                            <ImageView
                                android:layout_width="@dimen/padding_xlarge"
                                android:layout_height="@dimen/padding_xlarge"
                                android:src="@drawable/ic_email"
                                app:tint="@color/primary"/>
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/padding_large">
                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_email"
                                android:textSize="@dimen/text_size_12"
                                android:textColor="@color/color_9CA3AF"/>
                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvProfileEmail"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_chua_cap_nhat"
                                android:textSize="@dimen/text_size_16"
                                android:textStyle="bold"
                                android:textColor="@color/color_1F2937"
                                android:layout_marginTop="@dimen/stroke_2"/>
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnChatWithUser"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/bottom_nav_height"
                        android:layout_marginTop="@dimen/spacing_24"
                        android:text="@string/txt_nhan_tin_ngay"
                        android:textSize="@dimen/text_size_16"
                        android:textStyle="bold"
                        app:cornerRadius="@dimen/padding_medium"
                        app:backgroundTint="@color/primary"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- KHU VỰC DANH SÁCH PHÒNG TRỌ (Giữ nguyên) -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/padding_large"
                android:layout_marginTop="@dimen/dimen_36dp"
                android:layout_marginBottom="@dimen/padding_medium"
                android:text="@string/txt_danh_sach_phong_tro"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold"
                android:textColor="@color/color_111827"/>

            <LinearLayout
                android:id="@+id/layoutRoomControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/padding_large"
                android:layout_marginBottom="@dimen/padding_medium"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:background="@drawable/bg_glass_card"
                android:padding="@dimen/padding_small">
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/padding_small"
                    android:text="@string/txt_sap_xep"
                    android:textColor="@color/color_6B7280"
                    android:textSize="@dimen/text_size_13" />
                <Spinner
                    android:id="@+id/spinnerRoomSort"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/image_size_40"
                    android:layout_weight="1"
                    android:background="@drawable/bg_spinner_new"/>
                <View
                    android:layout_width="@dimen/stroke_1"
                    android:layout_height="@dimen/padding_xlarge"
                    android:layout_marginHorizontal="@dimen/padding_medium"
                    android:background="@color/color_E5E7EB"/>
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvPageSizeHint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_10_trang"
                    android:textColor="@color/color_6B7280"
                    android:textSize="@dimen/text_size_13" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progressRooms"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="@dimen/spacing_24"
                android:visibility="gone"/>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvNoRooms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="@dimen/image_size_40"
                android:text="@string/txt_nguoi_dung_chua_co_phong_"
                android:textSize="@dimen/text_size_14"
                android:textColor="@color/color_9CA3AF"
                android:visibility="gone"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvProfileRooms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:paddingHorizontal="@dimen/padding_large"
                android:nestedScrollingEnabled="false"/>

            <LinearLayout
                android:id="@+id/layoutRoomPagination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/padding_large"
                android:layout_marginTop="@dimen/padding_xlarge"
                android:gravity="center"
                android:orientation="horizontal">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPrevRoomPage"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_truoc"
                    app:cornerRadius="@dimen/padding_small"
                    app:strokeColor="@color/primary"
                    android:textColor="@color/primary"/>
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvRoomPageInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="@dimen/spacing_24"
                    android:text="@string/txt_trang_1_1"
                    android:textColor="@color/color_374151"
                    android:textStyle="bold"
                    android:textSize="@dimen/text_size_14" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNextRoomPage"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_sau"
                    app:cornerRadius="@dimen/padding_small"
                    app:strokeColor="@color/primary"
                    android:textColor="@color/primary"/>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>