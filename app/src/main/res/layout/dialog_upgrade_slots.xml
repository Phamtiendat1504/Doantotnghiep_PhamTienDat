<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_surface"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/padding_xlarge">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_mua_them_luot_ang_bai"
            android:textSize="@dimen/text_size_20"
            android:textStyle="bold"
            android:textColor="@android:color/white" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_chon_goi_hoac_nhap_so_luo"
            android:textSize="@dimen/text_size_14"
            android:textColor="@color/color_E0F2FE"
            android:layout_marginTop="@dimen/elevation_4" />

    </LinearLayout>

    <!-- Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_xlarge"
        android:background="@android:color/white">

        <!-- Gói 1 -->
        <LinearLayout
            android:id="@+id/layoutPkg1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_slot_package_normal"
            android:padding="@dimen/padding_large"
            android:layout_marginBottom="@dimen/padding_medium">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="3 lượt đăng bài"
                    android:textSize="@dimen/text_size_16"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />
            </LinearLayout>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10.000đ"
                android:textSize="@dimen/text_size_16"
                android:textStyle="bold"
                android:textColor="@color/primary" />
        </LinearLayout>

        <!-- Gói 2 -->
        <LinearLayout
            android:id="@+id/layoutPkg2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_slot_package_normal"
            android:padding="@dimen/padding_large"
            android:layout_marginBottom="@dimen/padding_medium">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 lượt đăng bài (Phổ biến)"
                    android:textSize="@dimen/text_size_16"
                    android:textStyle="bold"
                    android:textColor="#D32F2F" />
            </LinearLayout>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="20.000đ"
                android:textSize="@dimen/text_size_16"
                android:textStyle="bold"
                android:textColor="#D32F2F" />
        </LinearLayout>

        <!-- Gói 3 -->
        <LinearLayout
            android:id="@+id/layoutPkg3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_slot_package_normal"
            android:padding="@dimen/padding_large"
            android:layout_marginBottom="@dimen/padding_medium">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="10 lượt đăng bài"
                    android:textSize="@dimen/text_size_16"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />
            </LinearLayout>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="40.000đ"
                android:textSize="@dimen/text_size_16"
                android:textStyle="bold"
                android:textColor="@color/primary" />
        </LinearLayout>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/txt_hoac_nhap_so_luong_tuy_ch"
            android:textSize="@dimen/text_size_14"
            android:textColor="@color/color_333333"
            android:textStyle="bold"
            android:layout_marginTop="@dimen/corner_radius_10"
            android:layout_marginBottom="@dimen/padding_small"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_slot_package_normal"
            android:padding="@dimen/padding_small"
            android:layout_marginBottom="@dimen/padding_xlarge">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtCustomSlots"
                android:layout_width="0dp"
                android:layout_height="@dimen/dimen_50dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="@string/txt_nhap_so_luot"
                android:inputType="number"
                android:paddingStart="@dimen/padding_medium"
                android:paddingEnd="@dimen/padding_medium"
                android:textSize="@dimen/text_size_16"
                android:textColor="@color/primary"
                android:textColorHint="@color/text_hint" />

            <View
                android:layout_width="@dimen/stroke_1"
                android:layout_height="@dimen/dimen_30dp"
                android:background="@color/gray_200"
                android:layout_marginEnd="@dimen/padding_small"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:layout_marginEnd="@dimen/padding_medium">
                
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvCustomPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_0"
                    android:textSize="@dimen/text_size_16"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBuyCustom"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dimen_50dp"
                android:text="@string/txt_mua"
                android:textAllCaps="false"
                android:enabled="false"
                app:cornerRadius="@dimen/padding_small" />
        </LinearLayout>

        <!-- Nút đóng -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCloseUpgrade"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_50dp"
            android:text="@string/txt_e_sau"
            android:textAllCaps="false"
            android:textSize="@dimen/text_size_16"
            android:textColor="@color/text_secondary" />

    </LinearLayout>

</LinearLayout>
