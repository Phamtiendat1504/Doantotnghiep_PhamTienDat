<?xml version="1.0" encoding="utf-8"?>
<!-- Tin nhắn NHẬN - bên TRÁI màu xám -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="@dimen/stroke_2"
    android:paddingBottom="@dimen/stroke_2">

    <!-- Thời gian -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvTimeReceived"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:textSize="@dimen/text_size_11"
        android:textColor="@color/color_AAAAAA"
        android:paddingTop="@dimen/padding_small"
        android:paddingBottom="@dimen/elevation_4"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start">

        <!-- Vùng chứa Tin nhắn (Hình + Chữ) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/padding_small"
            android:layout_marginEnd="@dimen/bottom_nav_height"
            android:layout_marginBottom="@dimen/stroke_2"
            android:gravity="start">

            <!-- Hình ảnh -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardImageReceived"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/padding_large"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/bg_card"
                android:layout_marginBottom="@dimen/elevation_4"
                android:visibility="gone">
                
                <ImageView
                    android:id="@+id/ivImageReceived"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:maxWidth="@dimen/dimen_250dp"
                    android:maxHeight="@dimen/dimen_300dp"
                    android:scaleType="centerCrop" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Bubble tin nhắn -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvMessageReceived"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_tin_nhan_mau"
                android:textSize="@dimen/text_size_15"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_bubble_received"
                android:paddingStart="@dimen/spacing_14"
                android:paddingEnd="@dimen/spacing_14"
                android:paddingTop="@dimen/corner_radius_10"
                android:paddingBottom="@dimen/corner_radius_10"
                android:maxWidth="@dimen/dimen_280dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Emoji Reactions (hiện bên trái, sát bubble) -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvReactionsReceived"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginStart="@dimen/corner_radius_10"
        android:layout_marginTop="@dimen/dimen_minus_6dp"
        android:textSize="@dimen/text_size_14"
        android:background="@color/bg_white"
        android:elevation="@dimen/stroke_2"
        android:paddingStart="@dimen/elevation_4"
        android:paddingEnd="@dimen/elevation_4"
        android:paddingTop="@dimen/stroke_1"
        android:paddingBottom="@dimen/stroke_1"
        android:visibility="gone" />

</LinearLayout>
