<?xml version="1.0" encoding="utf-8"?>
<!-- Tin nhắn NHẬN - bên TRÁI màu xám -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <!-- Thời gian -->
    <TextView
        android:id="@+id/tvTimeReceived"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:textSize="11sp"
        android:textColor="#AAAAAA"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="start">

        <!-- Vùng chứa Tin nhắn (Hình + Chữ) -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="56dp"
            android:layout_marginBottom="2dp"
            android:gravity="start">

            <!-- Hình ảnh -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardImageReceived"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="#E0E0E0"
                android:layout_marginBottom="4dp"
                android:visibility="gone">
                
                <ImageView
                    android:id="@+id/ivImageReceived"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:adjustViewBounds="true"
                    android:maxWidth="250dp"
                    android:maxHeight="300dp"
                    android:scaleType="centerCrop" />
            </androidx.cardview.widget.CardView>

            <!-- Bubble tin nhắn -->
            <TextView
                android:id="@+id/tvMessageReceived"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tin nhắn mẫu"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:background="@drawable/bg_bubble_received"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:maxWidth="280dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Emoji Reactions (hiện bên trái, sát bubble) -->
    <TextView
        android:id="@+id/tvReactionsReceived"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginStart="10dp"
        android:layout_marginTop="-6dp"
        android:textSize="14sp"
        android:background="#FFFFFF"
        android:elevation="2dp"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:paddingTop="1dp"
        android:paddingBottom="1dp"
        android:visibility="gone" />

</LinearLayout>
