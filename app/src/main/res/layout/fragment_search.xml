<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/spacing_24">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_wave"
            android:orientation="vertical"
            android:paddingStart="@dimen/padding_xlarge"
            android:paddingTop="@dimen/dimen_44dp"
            android:paddingEnd="@dimen/padding_xlarge"
            android:paddingBottom="@dimen/dimen_22dp">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/search_screen_title"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_24"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/elevation_4"
                android:text="@string/search_screen_subtitle"
                android:textColor="@color/primary_light"
                android:textSize="@dimen/text_size_13" />
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_large"
            android:layout_marginTop="@dimen/dimen_minus_12dp"
            android:layout_marginEnd="@dimen/padding_large"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="@dimen/spacing_18"
            app:cardElevation="@dimen/elevation_3">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_large">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search_section_area_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_16"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/corner_radius_10"
                    android:text="@string/search_area_type_label"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_size_12" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupAreaType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/elevation_6"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPhuong"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="@string/search_area_type_ward"
                        app:chipBackgroundColor="@color/chip_bg_color" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipXa"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/search_area_type_xa"
                        app:chipBackgroundColor="@color/chip_bg_color" />
                </com.google.android.material.chip.ChipGroup>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/corner_radius_10"
                    android:text="@string/search_scope_label"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_size_12" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupSearchScope"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/elevation_6"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipScopeWard"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="@string/search_scope_ward"
                        app:chipBackgroundColor="@color/chip_bg_color" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipScopeDistrict"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/search_scope_district"
                        app:chipBackgroundColor="@color/chip_bg_color" />
                </com.google.android.material.chip.ChipGroup>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/corner_radius_10"
                    android:text="@string/search_area_picker_label"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_size_12" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/OutlinedBoxRounded"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/elevation_6"
                    app:endIconMode="dropdown_menu"
                    app:hintEnabled="false">

                    <AutoCompleteTextView
                        android:id="@+id/autoArea"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dimen_48dp"
                        android:completionThreshold="1"
                        android:dropDownHeight="@dimen/dimen_300dp"
                        android:hint="@string/search_area_picker_hint"
                        android:inputType="text"
                        android:paddingStart="@dimen/padding_medium"
                        android:paddingEnd="@dimen/padding_medium"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/corner_radius_10"
                    android:text="@string/search_address_optional"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_size_12" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtAddress"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_48dp"
                    android:layout_marginTop="@dimen/elevation_6"
                    android:background="@drawable/bg_spinner_new"
                    android:hint="@string/search_address_hint"
                    android:inputType="text"
                    android:paddingStart="@dimen/padding_medium"
                    android:paddingEnd="@dimen/padding_medium"
                    android:textSize="@dimen/text_size_14" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ────── Card: Tìm theo vị trí bản đồ ────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_large"
            android:layout_marginTop="@dimen/padding_medium"
            android:layout_marginEnd="@dimen/padding_large"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="@dimen/spacing_18"
            app:cardElevation="@dimen/elevation_3">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_large">

                <!-- Tiêu đề -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/txt_tim_theo_vi_tri_ban_o"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_16"
                        android:textStyle="bold" />

                </LinearLayout>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/elevation_4"
                    android:text="@string/txt_tim_phong_gan_vi_tri_ban_"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_size_12" />

                <!-- Nút chọn vị trí -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickMapLocation"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_48dp"
                    android:layout_marginTop="@dimen/padding_medium"
                    android:text="@string/txt_chon_vi_tri_tren_ban_o"
                    android:textAllCaps="false"
                    android:textColor="@color/primary"
                    app:cornerRadius="@dimen/padding_medium"
                    app:icon="@drawable/ic_location"
                    app:iconGravity="textStart"
                    app:iconPadding="@dimen/padding_small"
                    app:iconTint="@color/primary"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="@dimen/dimen_1_2dp" />

                <!-- Địa chỉ đã chọn + nút xóa (ẩn mặc định) -->
                <LinearLayout
                    android:id="@+id/layoutMapSelected"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/corner_radius_10"
                    android:background="@drawable/bg_input_disabled"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/corner_radius_10"
                    android:visibility="gone">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvMapSelectedAddress"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_13" />

                    <ImageView
                        android:id="@+id/btnClearMapLocation"
                        android:layout_width="@dimen/spacing_24"
                        android:layout_height="@dimen/spacing_24"
                        android:layout_marginStart="@dimen/padding_small"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="@dimen/stroke_2"
                        android:src="@drawable/ic_close"
                        app:tint="@color/text_secondary" />
                </LinearLayout>

                <!-- Bán kính tìm kiếm (ẩn khi chưa chọn vị trí) -->
                <LinearLayout
                    android:id="@+id/layoutRadiusPicker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/corner_radius_10"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/txt_ban_kinh_tim_kiem"
                            android:textColor="@color/text_hint"
                            android:textSize="@dimen/text_size_12" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvRadiusValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_2_km"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_13"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <SeekBar
                        android:id="@+id/seekBarRadius"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/elevation_4"
                        android:max="4"
                        android:progress="1"
                        android:progressTint="@color/primary"
                        android:thumbTint="@color/primary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/txt_1km"
                            android:textColor="@color/text_hint"
                            android:textSize="@dimen/text_size_11" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_5km"
                            android:textColor="@color/text_hint"
                            android:textSize="@dimen/text_size_11" />
                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ────── Card: Khoảng giá ────── -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_large"
            android:layout_marginTop="@dimen/padding_medium"
            android:layout_marginEnd="@dimen/padding_large"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="@dimen/spacing_18"
            app:cardElevation="@dimen/elevation_3">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_large">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search_section_price_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_16"
                    android:textStyle="bold" />



                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/corner_radius_10"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrice1"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/search_price_1"
                        app:chipBackgroundColor="@color/chip_bg_color" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrice2"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/search_price_2"
                        app:chipBackgroundColor="@color/chip_bg_color" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrice3"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/search_price_3"
                        app:chipBackgroundColor="@color/chip_bg_color" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrice4"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/search_price_4"
                        app:chipBackgroundColor="@color/chip_bg_color" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrice5"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/search_price_5"
                        app:chipBackgroundColor="@color/chip_bg_color" />
                </com.google.android.material.chip.ChipGroup>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPriceCustom"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/elevation_6"
                    android:text="@string/search_price_custom"
                    app:chipBackgroundColor="@color/chip_bg_color" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/OutlinedBoxRounded"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_small"
                    android:hint="@string/search_price_custom_hint"
                    app:errorEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtCustomPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:visibility="gone" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_large"
            android:layout_marginTop="@dimen/padding_medium"
            android:layout_marginEnd="@dimen/padding_large"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="@dimen/spacing_18"
            app:cardElevation="@dimen/elevation_3">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_large">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search_section_room_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_16"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/corner_radius_10"
                    android:text="@string/search_room_type"
                    android:textColor="@color/text_hint"
                    android:textSize="@dimen/text_size_12" />

                <RadioGroup
                    android:id="@+id/rgRoomStyle"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_48dp"
                    android:layout_marginTop="@dimen/elevation_6"
                    android:background="@drawable/bg_spinner_new"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_medium"
                    android:paddingEnd="@dimen/padding_medium">

                    <RadioButton
                        android:id="@+id/rbShared"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/primary"
                        android:text="@string/search_room_shared"
                        android:textSize="@dimen/text_size_14" />

                    <RadioButton
                        android:id="@+id/rbPrivate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/primary"
                        android:text="@string/search_room_private"
                        android:textSize="@dimen/text_size_14" />
                </RadioGroup>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/corner_radius_10"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="@dimen/padding_small"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/search_area_m2"
                            android:textColor="@color/text_hint"
                            android:textSize="@dimen/text_size_12" />

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtRoomArea"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dimen_48dp"
                            android:layout_marginTop="@dimen/elevation_6"
                            android:background="@drawable/bg_spinner_new"
                            android:hint="@string/search_area_hint"
                            android:inputType="number"
                            android:paddingStart="@dimen/padding_medium"
                            android:textSize="@dimen/text_size_14" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_small"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/search_people"
                            android:textColor="@color/text_hint"
                            android:textSize="@dimen/text_size_12" />

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtPeopleCount"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/dimen_48dp"
                            android:layout_marginTop="@dimen/elevation_6"
                            android:background="@drawable/bg_spinner_new"
                            android:hint="@string/search_people_hint"
                            android:inputType="number"
                            android:paddingStart="@dimen/padding_medium"
                            android:textSize="@dimen/text_size_14" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_large"
            android:layout_marginTop="@dimen/padding_medium"
            android:layout_marginEnd="@dimen/padding_large"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="@dimen/spacing_18"
            app:cardElevation="@dimen/elevation_3">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_large">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/search_section_amenities_title"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_16"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/corner_radius_10"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cbWifi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.35"
                        android:buttonTint="@color/primary"
                        android:text="@string/txt_wifi"
                        android:textSize="@dimen/text_size_14" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtWifiPrice"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/dimen_44dp"
                        android:layout_weight="0.65"
                        android:background="@drawable/bg_spinner_new"
                        android:enabled="false"
                        android:hint="@string/search_wifi_price_hint"
                        android:inputType="number"
                        android:paddingStart="@dimen/corner_radius_10"
                        android:textSize="@dimen/text_size_13" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_small"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cbElectric"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.35"
                        android:buttonTint="@color/primary"
                        android:text="@string/search_electric"
                        android:textSize="@dimen/text_size_14" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtElectricPrice"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/dimen_44dp"
                        android:layout_weight="0.65"
                        android:background="@drawable/bg_spinner_new"
                        android:enabled="false"
                        android:hint="@string/search_electric_price_hint"
                        android:inputType="number"
                        android:paddingStart="@dimen/corner_radius_10"
                        android:textSize="@dimen/text_size_13" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_small"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <CheckBox
                        android:id="@+id/cbWater"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.35"
                        android:buttonTint="@color/primary"
                        android:text="@string/search_water"
                        android:textSize="@dimen/text_size_14" />

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtWaterPrice"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/dimen_44dp"
                        android:layout_weight="0.65"
                        android:background="@drawable/bg_spinner_new"
                        android:enabled="false"
                        android:hint="@string/search_water_price_hint"
                        android:inputType="number"
                        android:paddingStart="@dimen/corner_radius_10"
                        android:textSize="@dimen/text_size_13" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <RadioGroup
                        android:id="@+id/rgCurfew"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/rbCurfewFree"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/search_curfew_free" />

                        <RadioButton
                            android:id="@+id/rbCurfewCustom"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/search_curfew_custom" />
                    </RadioGroup>

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtCurfewTime"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/search_curfew_hint" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResetFilter"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_48dp"
            android:layout_marginStart="@dimen/padding_large"
            android:layout_marginTop="@dimen/spacing_14"
            android:layout_marginEnd="@dimen/padding_large"
            android:text="@string/search_reset_filter"
            android:textAllCaps="false"
            android:textColor="@color/primary"
            app:cornerRadius="@dimen/spacing_14"
            app:strokeColor="@color/primary"
            app:strokeWidth="@dimen/dimen_1_2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSearch"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_52dp"
            android:layout_marginStart="@dimen/padding_large"
            android:layout_marginTop="@dimen/padding_medium"
            android:layout_marginEnd="@dimen/padding_large"
            android:text="@string/search_submit"
            android:textAllCaps="false"
            android:textSize="@dimen/text_size_15"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            app:cornerRadius="@dimen/spacing_14"
            app:icon="@drawable/ic_search"
            app:iconGravity="textStart"
            app:iconPadding="@dimen/padding_small"
            app:iconTint="@android:color/white" />

    </LinearLayout>

</ScrollView>
