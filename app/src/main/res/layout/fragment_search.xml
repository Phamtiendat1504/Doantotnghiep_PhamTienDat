<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="20dp">

        <!-- ===== HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#1976D2"
            android:paddingStart="20dp"
            android:paddingEnd="10dp"
            android:paddingTop="40dp"
            android:paddingBottom="20dp"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tìm phòng trọ"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_location"
                    app:tint="#B3DEFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thành phố: Hà Nội"
                    android:textSize="13sp"
                    android:textColor="#B3DEFF"
                    android:layout_marginStart="6dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- ═══════ 1. KHU VỰC ═══════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="-14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="#1976D2" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Khu vực"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupAreaType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPhuong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phường (nội thành)"
                        android:textSize="13sp"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_bg_color"
                        app:checkedIconVisible="true"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipXa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xã (ngoại thành)"
                        android:textSize="13sp"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_bg_color"
                        app:checkedIconVisible="true" />

                </com.google.android.material.chip.ChipGroup>

                <Spinner
                    android:id="@+id/spinnerArea"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_spinner_new"
                    android:paddingStart="12dp" />

                <EditText
                    android:id="@+id/edtAddress"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Số nhà, tên đường (tùy chọn)"
                    android:textSize="14sp"
                    android:paddingStart="12dp"
                    android:background="@drawable/bg_spinner_new"
                    android:inputType="text"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ═══════ 2. GIÁ THUÊ ═══════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="#E65100" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giá thuê / tháng"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- 3 mức giá trên 1 hàng -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:singleLine="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPrice1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1-3 tr"
                            android:textSize="12sp"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            app:chipBackgroundColor="@color/chip_bg_color" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPrice2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3-6 tr"
                            android:textSize="12sp"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            app:chipBackgroundColor="@color/chip_bg_color" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPrice3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="6-9 tr"
                            android:textSize="12sp"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            app:chipBackgroundColor="@color/chip_bg_color" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPrice4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="9-12 tr"
                            android:textSize="12sp"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            app:chipBackgroundColor="@color/chip_bg_color" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPrice5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=">12tr"
                            android:textSize="12sp"
                            style="@style/Widget.MaterialComponents.Chip.Choice"
                            app:chipBackgroundColor="@color/chip_bg_color" />

                    </com.google.android.material.chip.ChipGroup>

                </LinearLayout>

                <!-- Tùy chọn nhập giá -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPriceCustom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhập giá mong muốn tìm"
                    android:textSize="13sp"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/chip_bg_color"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/edtCustomPrice"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Nhập giá mong muốn (VD: 4.500.000)"
                    android:textSize="14sp"
                    android:inputType="number"
                    android:paddingStart="12dp"
                    android:background="@drawable/bg_spinner_new"
                    android:visibility="gone" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ═══════ 3. THÔNG TIN PHÒNG ═══════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="#5E35B1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin phòng"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- Dạng phòng thuê -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dạng phòng thuê"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#444444"
                    android:layout_marginBottom="4dp" />

                <RadioGroup
                    android:id="@+id/rgRoomStyle"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_spinner_new"
                    android:paddingStart="8dp"
                    android:layout_marginBottom="12dp">

                    <RadioButton
                        android:id="@+id/rbShared"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Chung chủ"
                        android:textSize="14sp"
                        android:buttonTint="#5E35B1" />

                    <RadioButton
                        android:id="@+id/rbPrivate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Riêng chủ"
                        android:textSize="14sp"
                        android:buttonTint="#5E35B1" />

                </RadioGroup>

                <!-- Diện tích + Số người trên 1 hàng -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Diện tích -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Diện tích (m²)"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#444444"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <EditText
                                android:id="@+id/edtRoomArea"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:hint="VD: 25"
                                android:textSize="14sp"
                                android:inputType="number"
                                android:paddingStart="12dp"
                                android:background="@drawable/bg_spinner_new" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#5E35B1" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Số người/phòng -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Số người/phòng"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#444444"
                            android:layout_marginBottom="4dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <EditText
                                android:id="@+id/edtPeopleCount"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:hint="VD: 2"
                                android:textSize="14sp"
                                android:inputType="number"
                                android:paddingStart="12dp"
                                android:background="@drawable/bg_spinner_new" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=""
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#5E35B1" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ═══════ 4. TIỆN ÍCH & GIỜ GIẤC ═══════ -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="10dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="#0097A7" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiện ích &amp; Giờ giấc"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A1A2E"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- Wifi -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <CheckBox
                        android:id="@+id/cbWifi"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="Wifi"
                        android:textSize="14sp"
                        android:buttonTint="#0097A7" />

                    <EditText
                        android:id="@+id/edtWifiPrice"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:hint="VD: 100.000 đ/tháng"
                        android:textSize="13sp"
                        android:inputType="number"
                        android:paddingStart="10dp"
                        android:background="@drawable/bg_spinner_new"
                        android:enabled="false" />

                </LinearLayout>

                <!-- Điện -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <CheckBox
                        android:id="@+id/cbElectric"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="Điện"
                        android:textSize="14sp"
                        android:buttonTint="#0097A7" />

                    <EditText
                        android:id="@+id/edtElectricPrice"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:hint="VD: 3.500 đ/kWh"
                        android:textSize="13sp"
                        android:inputType="number"
                        android:paddingStart="10dp"
                        android:background="@drawable/bg_spinner_new"
                        android:enabled="false" />

                </LinearLayout>

                <!-- Nước -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <CheckBox
                        android:id="@+id/cbWater"
                        android:layout_width="90dp"
                        android:layout_height="wrap_content"
                        android:text="Nước"
                        android:textSize="14sp"
                        android:buttonTint="#0097A7" />

                    <EditText
                        android:id="@+id/edtWaterPrice"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:hint="VD: 30.000 đ/m³"
                        android:textSize="13sp"
                        android:inputType="number"
                        android:paddingStart="10dp"
                        android:background="@drawable/bg_spinner_new"
                        android:enabled="false" />

                </LinearLayout>

                <!-- Đường kẻ -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F0F0F0"
                    android:layout_marginBottom="12dp" />

                <!-- Giờ giấc -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giờ ra vào"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#444444"
                    android:layout_marginBottom="6dp" />

                <RadioGroup
                    android:id="@+id/rgCurfew"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_spinner_new"
                    android:paddingStart="8dp">

                    <RadioButton
                        android:id="@+id/rbCurfewFree"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tự do"
                        android:textSize="14sp"
                        android:buttonTint="#0097A7" />

                    <RadioButton
                        android:id="@+id/rbCurfewCustom"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tùy chọn"
                        android:textSize="14sp"
                        android:buttonTint="#0097A7" />

                </RadioGroup>

                <EditText
                    android:id="@+id/edtCurfewTime"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:hint="Nhập giờ khóa cửa (VD: 22:00)"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:paddingStart="12dp"
                    android:background="@drawable/bg_spinner_new"
                    android:visibility="gone"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ═══════ NÚT TÌM KIẾM ═══════ -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSearch"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Tìm kiếm phòng trọ"
            android:textSize="17sp"
            android:textAllCaps="false"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="14dp"
            app:backgroundTint="#1976D2"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_search"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="#FFFFFF" />

    </LinearLayout>

</ScrollView>