<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:overScrollMode="never"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- ===== HEADER ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_header_wave"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="44dp"
            android:paddingBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tìm phòng trọ"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thiết lập bộ lọc để tìm phòng phù hợp"
                android:textSize="13sp"
                android:textColor="@color/primary_light"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- 📍📍📍🕐 1. KHU VỰC 📍📍📍🕐 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="-16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Section title -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="📍"
                        android:textSize="16sp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Khu vực"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

                <!-- Phường / Xã -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Loại khu vực"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupAreaType"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPhuong"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phường (nội thành)"
                        android:textSize="13sp"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_bg_color"
                        app:checkedIconVisible="true"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipXa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Xã (ngoại thành)"
                        android:textSize="13sp"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_bg_color"
                        app:checkedIconVisible="true" />

                </com.google.android.material.chip.ChipGroup>

                <!-- Phạm vi tìm kiếm -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phạm vi tìm kiếm"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupSearchScope"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    android:layout_marginBottom="12dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipScopeWard"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Theo phường / xã"
                        android:textSize="13sp"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_bg_color"
                        app:checkedIconVisible="true"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipScopeDistrict"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Toàn quận / huyện"
                        android:textSize="13sp"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_bg_color"
                        app:checkedIconVisible="true" />

                </com.google.android.material.chip.ChipGroup>

                <!-- Spinner chọn phường/xã -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chọn phường / xã"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/spinnerArea"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_spinner_new"
                    android:paddingStart="12dp"
                    android:layout_marginBottom="10dp" />

                <!-- Địa chỉ cụ thể -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số nhà, tên đường (tùy chọn)"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/edtAddress"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="VD: 12 Nguyễn Trãi"
                    android:textSize="14sp"
                    android:paddingStart="12dp"
                    android:background="@drawable/bg_spinner_new"
                    android:inputType="text" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 📍📍📍🕐 2. GIÁ THUÊ 📍📍📍🕐 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="\📍"
                        android:textSize="16sp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giá thuê / tháng"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

                <!-- Chip giá nhanh -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:singleSelection="true"
                    android:layout_marginBottom="10dp">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrice1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1–3 tr"
                        android:textSize="13sp"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_bg_color" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrice2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3–6 tr"
                        android:textSize="13sp"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_bg_color" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrice3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="6–9 tr"
                        android:textSize="13sp"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_bg_color" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrice4"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="9–12 tr"
                        android:textSize="13sp"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_bg_color" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipPrice5"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&gt;12 tr"
                        android:textSize="13sp"
                        style="@style/Widget.MaterialComponents.Chip.Choice"
                        app:chipBackgroundColor="@color/chip_bg_color" />

                </com.google.android.material.chip.ChipGroup>

                <!-- Nhập giá tùy chọn -->
                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPriceCustom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nhập giá mong muốn"
                    android:textSize="13sp"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    app:chipBackgroundColor="@color/chip_bg_color"
                    android:layout_marginBottom="8dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="VD: 4.500.000 đ"
                    style="@style/OutlinedBoxRounded"
                    app:errorEnabled="false">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtCustomPrice"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number"
                        android:visibility="gone" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 📍📍📍🕐 3. THÔNG TIN PHÒNG 📍📍📍🕐 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="\📍"
                        android:textSize="16sp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin phòng"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

                <!-- Dạng phòng -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Dạng phòng thuê"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="6dp" />

                <RadioGroup
                    android:id="@+id/rgRoomStyle"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_spinner_new"
                    android:paddingStart="12dp"
                    android:layout_marginBottom="14dp">

                    <RadioButton
                        android:id="@+id/rbShared"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Chung chủ"
                        android:textSize="14sp"
                        android:buttonTint="#1976D2" />

                    <RadioButton
                        android:id="@+id/rbPrivate"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Riêng chủ"
                        android:textSize="14sp"
                        android:buttonTint="#1976D2" />

                </RadioGroup>

                <!-- Diện tích + Số người: 2 cột -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Diện tích (m²)"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginBottom="6dp" />

                        <EditText
                            android:id="@+id/edtRoomArea"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="VD: 25"
                            android:textSize="14sp"
                            android:inputType="number"
                            android:paddingStart="12dp"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_spinner_new" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Số người / phòng"
                            android:textSize="12sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginBottom="6dp" />

                        <EditText
                            android:id="@+id/edtPeopleCount"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="VD: 2"
                            android:textSize="14sp"
                            android:inputType="number"
                            android:paddingStart="12dp"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_spinner_new" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 📍📍📍🕐 4. TIỆN ÍCH & GIỜ GIẤC 📍📍📍🕐 -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:text="\🕐"
                        android:textSize="16sp"
                        android:gravity="center" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiện ích &amp; Giờ giấc"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="4dp" />

                </LinearLayout>

                <!-- Wifi -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <CheckBox
                        android:id="@+id/cbWifi"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.35"
                        android:text="Wifi"
                        android:textSize="14sp"
                        android:buttonTint="#1976D2" />

                    <EditText
                        android:id="@+id/edtWifiPrice"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="0.65"
                        android:hint="Giá (đ/tháng)"
                        android:textSize="13sp"
                        android:inputType="number"
                        android:paddingStart="10dp"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_spinner_new"
                        android:enabled="false" />

                </LinearLayout>

                <!-- Điện -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <CheckBox
                        android:id="@+id/cbElectric"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.35"
                        android:text="Điện"
                        android:textSize="14sp"
                        android:buttonTint="#1976D2" />

                    <EditText
                        android:id="@+id/edtElectricPrice"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="0.65"
                        android:hint="Giá (đ/kWh)"
                        android:textSize="13sp"
                        android:inputType="number"
                        android:paddingStart="10dp"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_spinner_new"
                        android:enabled="false" />

                </LinearLayout>

                <!-- Nước -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <CheckBox
                        android:id="@+id/cbWater"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.35"
                        android:text="Nước"
                        android:textSize="14sp"
                        android:buttonTint="#1976D2" />

                    <EditText
                        android:id="@+id/edtWaterPrice"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="0.65"
                        android:hint="Giá (đ/m³)"
                        android:textSize="13sp"
                        android:inputType="number"
                        android:paddingStart="10dp"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_spinner_new"
                        android:enabled="false" />

                </LinearLayout>

                <!-- Đường kẻ -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/gray_200"
                    android:layout_marginBottom="14dp" />

                <!-- Giờ ra vào -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giờ ra vào"
                    android:textSize="12sp"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="6dp" />

                <RadioGroup
                    android:id="@+id/rgCurfew"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_spinner_new"
                    android:paddingStart="12dp">

                    <RadioButton
                        android:id="@+id/rbCurfewFree"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tự do"
                        android:textSize="14sp"
                        android:buttonTint="#1976D2" />

                    <RadioButton
                        android:id="@+id/rbCurfewCustom"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Tùy chọn"
                        android:textSize="14sp"
                        android:buttonTint="#1976D2" />

                </RadioGroup>

                <EditText
                    android:id="@+id/edtCurfewTime"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Giờ khóa cửa (VD: 22:00)"
                    android:textSize="14sp"
                    android:inputType="text"
                    android:paddingStart="12dp"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_spinner_new"
                    android:visibility="gone"
                    android:layout_marginTop="10dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- 📍📍📍🕐 NÚT XÓA BỘ LỌC 📍📍📍🕐 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResetFilter"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Xóa bộ lọc"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="12dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="#1976D2"
            app:strokeWidth="1.5dp"
            app:cornerRadius="16dp"
            android:textColor="@color/primary" />

        <!-- 📍📍📍🕐 NÚT TÌM KIẾM 📍📍📍🕐 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSearch"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Tìm kiếm phòng trọ"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            app:backgroundTint="#1976D2"
            app:cornerRadius="16dp"
            app:icon="@drawable/ic_search"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="#FFFFFF" />

    </LinearLayout>

</ScrollView>