<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_light"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/image_size_100">

            <!-- Premium Header -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_240dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/header_height"
                    android:background="@drawable/bg_header_wave" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/spacing_24"
                    android:paddingTop="@dimen/dimen_50dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvGreetingLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_chao_buoi_sang"
                                android:textSize="@dimen/text_size_12"
                                android:textStyle="bold"
                                android:textColor="@color/primary_light"
                                android:letterSpacing="0.15" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvUserName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_pham_tien_at"
                                android:textSize="@dimen/dimen_26sp"
                                android:textStyle="bold"
                                android:textColor="@color/white"
                                android:layout_marginTop="@dimen/stroke_2" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvCurrentDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_thu_hai_11_04_2026"
                                android:textSize="@dimen/text_size_12"
                                android:textColor="@color/primary_light"
                                android:layout_marginTop="@dimen/elevation_4"
                                android:alpha="0.9" />
                        </LinearLayout>

                        <!-- Only Notification Icon allowed -->
                        <FrameLayout
                            android:id="@+id/btnNotificationContainer"
                            android:layout_width="@dimen/dimen_45dp"
                            android:layout_height="@dimen/dimen_45dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_circle_white_alpha">

                            <ImageView
                                android:id="@+id/btnNotification"
                                android:layout_width="@dimen/dimen_22dp"
                                android:layout_height="@dimen/dimen_22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_notification"
                                app:tint="@color/white" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvNotificationBadge"
                                android:layout_width="@dimen/padding_large"
                                android:layout_height="@dimen/padding_large"
                                android:layout_gravity="top|end"
                                android:background="@drawable/bg_badge_red"
                                android:gravity="center"
                                android:text="@string/txt_0_1"
                                android:textColor="@color/white"
                                android:textSize="@dimen/dimen_9sp"
                                android:textStyle="bold"
                                android:visibility="gone" />
                        </FrameLayout>
                    </RelativeLayout>

                    <!-- Minimalist Search Box (No Icons) -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dimen_60dp"
                        android:layout_marginTop="@dimen/dimen_30dp"
                        app:cardCornerRadius="@dimen/spacing_14"
                        app:cardElevation="@dimen/padding_small">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="@dimen/padding_large">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/edtHomeSearch"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="@string/txt_tim_kiem_khu_vuc_hoac_ten"
                                android:textSize="@dimen/text_size_15"
                                android:textColor="@color/text_primary"
                                android:inputType="text"
                                android:imeOptions="actionSearch"/>

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/btnSearchLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_tim_kiem_1"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:textSize="@dimen/text_size_13"
                                android:paddingHorizontal="@dimen/padding_medium"
                                android:paddingVertical="@dimen/padding_small"
                                android:letterSpacing="0.05" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </FrameLayout>

            <!-- Tra cứu hồ sơ chủ trọ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_24"
                android:layout_marginTop="@dimen/padding_large"
                app:cardBackgroundColor="@color/color_0F172A"
                app:cardCornerRadius="@dimen/padding_large"
                app:cardElevation="@dimen/padding_small">

                <LinearLayout
                    android:id="@+id/btnSearchProfileView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="@dimen/padding_large"
                    android:paddingVertical="@dimen/spacing_18">

                    <FrameLayout
                        android:layout_width="@dimen/dimen_46dp"
                        android:layout_height="@dimen/dimen_46dp"
                        android:background="@drawable/bg_circle_white_alpha"
                        android:foreground="?attr/selectableItemBackgroundBorderless">

                        <ImageView
                            android:layout_width="@dimen/spacing_24"
                            android:layout_height="@dimen/spacing_24"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_shield_check"
                            app:tint="@color/color_38BDF8" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_14"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_tra_cuu_thong_tin_nguoi_d"
                            android:textColor="@color/color_F8FAFC"
                            android:textSize="@dimen/text_size_13"
                            android:textStyle="bold" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/elevation_4"
                            android:lineSpacingExtra="@dimen/stroke_2"
                            android:text="@string/txt_xem_anh_gia_amp_xac_thuc_"
                            android:textColor="@color/color_94A3B8"
                            android:textSize="@dimen/text_size_12" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnSearchProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_medium"
                        android:background="@drawable/bg_badge_blue"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/spacing_14"
                        android:paddingVertical="@dimen/padding_small">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_tra_cuu"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text_size_12"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="@dimen/spacing_14"
                            android:layout_height="@dimen/spacing_14"
                            android:layout_marginStart="@dimen/elevation_4"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="@color/bg_white" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sections with Typography Focus -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_24"
                android:layout_marginTop="@dimen/padding_xlarge">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_kham_pha_khu_vuc"
                    android:textSize="@dimen/text_size_11"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.2" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupPopularAreas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_medium"
                    app:chipSpacingHorizontal="@dimen/corner_radius_10" />
            </LinearLayout>



            <!-- Featured Rooms -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/image_size_28">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/spacing_24">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/home_featured_rooms"
                        android:textSize="@dimen/dimen_22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                </RelativeLayout>

                <View
                    android:id="@+id/skeletonFeatured"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/header_height"
                    android:layout_marginHorizontal="@dimen/spacing_24"
                    android:layout_marginTop="@dimen/padding_large"
                    android:background="@drawable/bg_skeleton"
                    android:visibility="gone" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvNoFeatured"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="@dimen/dimen_50dp"
                    android:text="@string/txt_hien_chua_co_du_lieu_noi_"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFeaturedRooms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_large"
                    android:clipToPadding="false"
                    android:paddingHorizontal="@dimen/spacing_18" />
            </LinearLayout>

            <!-- New Rooms -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/image_size_40"
                android:paddingHorizontal="@dimen/spacing_24">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_moi_ang_tai"
                    android:textSize="@dimen/dimen_22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <View
                    android:id="@+id/skeletonNewRooms"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_240dp"
                    android:layout_marginTop="@dimen/padding_large"
                    android:background="@drawable/bg_skeleton"
                    android:visibility="gone" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvNoNewRooms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="@dimen/dimen_50dp"
                    android:text="@string/txt_ang_cap_nhat_danh_sach_mo"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvNewRooms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_large"
                    android:nestedScrollingEnabled="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLoadMore"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/bottom_nav_height"
                    android:layout_marginTop="@dimen/padding_xlarge"
                    android:text="@string/txt_xem_them_bai_viet"
                    android:textColor="@color/primary"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Hidden compatibility IDs -->
    <com.google.android.material.textview.MaterialTextView android:id="@+id/tvGreeting" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <HorizontalScrollView android:id="@+id/scrollRecentSearch" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <LinearLayout android:id="@+id/layoutRecentSearch" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:orientation="horizontal" />
    <ImageView android:id="@+id/btnHomeSearch" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <View android:id="@+id/btnFilter" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
