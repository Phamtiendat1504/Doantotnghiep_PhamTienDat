<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefreshLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F7FA"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp">

            <!-- Premium Header -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="240dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:background="@drawable/bg_header_wave" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="50dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvGreetingLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CHÀO BUỔI SÁNG,"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary_light"
                                android:letterSpacing="0.15" />

                            <TextView
                                android:id="@+id/tvUserName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Phạm Tiến Đạt"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:textColor="@color/white"
                                android:layout_marginTop="2dp" />

                            <TextView
                                android:id="@+id/tvCurrentDate"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Thứ Hai, 11/04/2026"
                                android:textSize="12sp"
                                android:textColor="@color/primary_light"
                                android:layout_marginTop="4dp"
                                android:alpha="0.9" />
                        </LinearLayout>

                        <!-- Only Notification Icon allowed -->
                        <FrameLayout
                            android:id="@+id/btnNotificationContainer"
                            android:layout_width="45dp"
                            android:layout_height="45dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:background="@drawable/bg_circle_white_alpha">

                            <ImageView
                                android:id="@+id/btnNotification"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_notification"
                                app:tint="@color/white" />

                            <TextView
                                android:id="@+id/tvNotificationBadge"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_gravity="top|end"
                                android:background="@drawable/bg_badge_red"
                                android:gravity="center"
                                android:text="0"
                                android:textColor="@color/white"
                                android:textSize="9sp"
                                android:textStyle="bold"
                                android:visibility="gone" />
                        </FrameLayout>
                    </RelativeLayout>

                    <!-- Minimalist Search Box (No Icons) -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginTop="30dp"
                        app:cardCornerRadius="14dp"
                        app:cardElevation="8dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="16dp">

                            <EditText
                                android:id="@+id/edtHomeSearch"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="Tìm kiếm khu vực hoặc tên trọ..."
                                android:textSize="15sp"
                                android:textColor="@color/text_primary"
                                android:inputType="text"
                                android:imeOptions="actionSearch"/>

                            <TextView
                                android:id="@+id/btnSearchLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TÌM KIẾM"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:textSize="13sp"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="8dp"
                                android:letterSpacing="0.05" />
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </FrameLayout>

            <!-- Sections with Typography Focus -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:layout_marginTop="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KHÁM PHÁ KHU VỰC"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_secondary"
                    android:letterSpacing="0.2" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupPopularAreas"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    app:chipSpacingHorizontal="10dp" />
            </LinearLayout>

            <!-- Tra cứu hồ sơ chủ trọ -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="#EEF5FF"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:id="@+id/btnSearchProfileView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="12dp">

                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_circle_light_blue"
                        android:foreground="?attr/selectableItemBackgroundBorderless">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_shield_check"
                            app:tint="@color/primary" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tra cứu thông tin người dùng"
                            android:textColor="@color/text_primary"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:maxLines="2"
                            android:text="Kiểm tra độ uy tín trước khi đặt lịch xem phòng"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/btnSearchProfile"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_badge_blue"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="7dp"
                        android:text="Tra cứu"
                        android:textColor="@color/white"
                        android:textSize="11sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Featured Rooms -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="28dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phòng nổi bật"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                </RelativeLayout>

                <View
                    android:id="@+id/skeletonFeatured"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginHorizontal="24dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_skeleton"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvNoFeatured"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="50dp"
                    android:text="Hiện chưa có dữ liệu nổi bật"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFeaturedRooms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:clipToPadding="false"
                    android:paddingHorizontal="18dp" />
            </LinearLayout>

            <!-- New Rooms -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="40dp"
                android:paddingHorizontal="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mới đăng tải"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <View
                    android:id="@+id/skeletonNewRooms"
                    android:layout_width="match_parent"
                    android:layout_height="240dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_skeleton"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvNoNewRooms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:padding="50dp"
                    android:text="Đang cập nhật danh sách mới nhất..."
                    android:textColor="@color/text_secondary"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvNewRooms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:nestedScrollingEnabled="false" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLoadMore"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:text="Xem thêm bài viết"
                    android:textColor="@color/primary"
                    android:visibility="gone" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Hidden compatibility IDs -->
    <TextView android:id="@+id/tvGreeting" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <HorizontalScrollView android:id="@+id/scrollRecentSearch" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <LinearLayout android:id="@+id/layoutRecentSearch" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" android:orientation="horizontal" />
    <ImageView android:id="@+id/btnHomeSearch" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />
    <View android:id="@+id/btnFilter" android:layout_width="0dp" android:layout_height="0dp" android:visibility="gone" />

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
