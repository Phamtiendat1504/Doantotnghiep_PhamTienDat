<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/spacing_24">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bottom_nav_selected"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/padding_xlarge"
            android:paddingTop="@dimen/padding_large"
            android:paddingEnd="@dimen/padding_xlarge"
            android:paddingBottom="@dimen/padding_large">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/dimen_36dp"
                android:layout_height="@dimen/dimen_36dp"
                android:padding="@dimen/elevation_6"
                android:src="@drawable/ic_back"
                app:tint="@color/bg_white" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_medium"
                android:paddingStart="@dimen/dimen_50dp"
                android:text="@string/txt_at_lich_hen_xem_phong"
                android:textColor="@color/bg_white"
                android:textSize="@dimen/text_size_20"
                android:textStyle="bold" />

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_14"
            app:cardBackgroundColor="@color/bg_white"
            app:cardCornerRadius="@dimen/spacing_14"
            app:cardElevation="@dimen/elevation_3">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_large">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/corner_radius_10"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="@dimen/elevation_4"
                        android:layout_height="@dimen/padding_xlarge"
                        android:background="@color/bottom_nav_selected" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_small"
                        android:text="@string/txt_thong_tin_phong"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_15"
                        android:textStyle="bold" />

                </LinearLayout>

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvRoomTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_tieu_e_phong_tro"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_size_16"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvRoomAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/elevation_4"
                    android:text="@string/txt_ia_chi_phong"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_size_13" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvRoomPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/elevation_4"
                    android:text="@string/txt_0_thang"
                    android:textColor="@color/error"
                    android:textSize="@dimen/text_size_15"
                    android:textStyle="bold" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_14"
            android:layout_marginEnd="@dimen/spacing_14"
            android:layout_marginBottom="@dimen/spacing_14"
            app:cardBackgroundColor="@color/bg_white"
            app:cardCornerRadius="@dimen/spacing_14"
            app:cardElevation="@dimen/elevation_3">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_large">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/padding_medium"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="@dimen/elevation_4"
                        android:layout_height="@dimen/padding_xlarge"
                        android:background="@color/bottom_nav_selected" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_small"
                        android:text="@string/txt_thong_tin_nguoi_hen"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_15"
                        android:textStyle="bold" />

                </LinearLayout>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/elevation_4"
                    android:text="@string/txt_ho_va_ten"
                    android:textColor="@color/color_444444"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtFullName"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_46dp"
                    android:layout_marginBottom="@dimen/padding_medium"
                    android:background="@drawable/bg_spinner_new"
                    android:hint="@string/txt_nhap_ho_va_ten"
                    android:inputType="textPersonName"
                    android:paddingStart="@dimen/padding_medium"
                    android:textSize="@dimen/text_size_14" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/elevation_4"
                    android:text="@string/txt_gioi_tinh"
                    android:textColor="@color/color_444444"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold" />

                <RadioGroup
                    android:id="@+id/rgGender"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_46dp"
                    android:layout_marginBottom="@dimen/padding_medium"
                    android:background="@drawable/bg_spinner_new"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="@dimen/padding_small">

                    <RadioButton
                        android:id="@+id/rbMale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/bottom_nav_selected"
                        android:text="@string/txt_nam"
                        android:textSize="@dimen/text_size_14" />

                    <RadioButton
                        android:id="@+id/rbFemale"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:buttonTint="@color/bottom_nav_selected"
                        android:text="@string/txt_nu"
                        android:textSize="@dimen/text_size_14" />

                </RadioGroup>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/elevation_4"
                    android:text="@string/txt_so_ien_thoai"
                    android:textColor="@color/color_444444"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtPhone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_46dp"
                    android:layout_marginBottom="@dimen/padding_medium"
                    android:background="@drawable/bg_spinner_new"
                    android:hint="@string/hint_phone"
                    android:inputType="phone"
                    android:maxLength="10"
                    android:paddingStart="@dimen/padding_medium"
                    android:textSize="@dimen/text_size_14" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_14"
            android:layout_marginEnd="@dimen/spacing_14"
            android:layout_marginBottom="@dimen/spacing_14"
            app:cardBackgroundColor="@color/bg_white"
            app:cardCornerRadius="@dimen/spacing_14"
            app:cardElevation="@dimen/elevation_3">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_large">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/padding_medium"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="@dimen/elevation_4"
                        android:layout_height="@dimen/padding_xlarge"
                        android:background="@color/bottom_nav_selected" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/padding_small"
                        android:text="@string/txt_thoi_gian_hen"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_15"
                        android:textStyle="bold" />

                </LinearLayout>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/elevation_4"
                    android:text="@string/txt_chon_ngay"
                    android:textColor="@color/color_444444"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvSelectDate"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_46dp"
                    android:layout_marginBottom="@dimen/padding_medium"
                    android:background="@drawable/bg_spinner_new"
                    android:drawableEnd="@drawable/ic_arrow_right"
                    android:gravity="center_vertical"
                    android:hint="@string/txt_bam_e_chon_ngay"
                    android:paddingStart="@dimen/padding_medium"
                    android:textSize="@dimen/text_size_14" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/elevation_4"
                    android:text="@string/txt_chon_gio"
                    android:textColor="@color/color_444444"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvSelectTime"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_46dp"
                    android:layout_marginBottom="@dimen/padding_medium"
                    android:background="@drawable/bg_spinner_new"
                    android:drawableEnd="@drawable/ic_arrow_right"
                    android:gravity="center_vertical"
                    android:hint="@string/txt_bam_e_chon_gio"
                    android:paddingStart="@dimen/padding_medium"
                    android:textSize="@dimen/text_size_14" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/elevation_4"
                    android:text="@string/txt_ghi_chu_them"
                    android:textColor="@color/color_444444"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtNote"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_80dp"
                    android:background="@drawable/bg_spinner_new"
                    android:gravity="top"
                    android:hint="@string/txt_y_kien_them_khong_bat_buo"
                    android:inputType="textMultiLine"
                    android:paddingStart="@dimen/padding_medium"
                    android:paddingTop="@dimen/corner_radius_10"
                    android:textSize="@dimen/text_size_14" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmit"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_52dp"
            android:layout_marginStart="@dimen/spacing_14"
            android:layout_marginEnd="@dimen/spacing_14"
            android:text="@string/txt_gui_yeu_cau_at_lich"
            android:textAllCaps="false"
            android:textSize="@dimen/text_size_16"
            app:backgroundTint="@color/bottom_nav_selected"
            app:cornerRadius="@dimen/spacing_14" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/corner_radius_10"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>