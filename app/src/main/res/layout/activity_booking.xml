<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- AppBar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bottom_nav_selected"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="14dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_back"
            app:tint="@color/bg_white" />

        <TextView
            android:id="@+id/tvAppBarTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Đặt lịch xem phòng"
            android:textColor="@color/bg_white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:visibility="gone" />

    </LinearLayout>

    <!-- Step Indicator (4 bước) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp"
        android:background="@color/bg_white">

        <TextView
            android:id="@+id/tvStep1Indicator"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="1"
            android:textColor="@color/bg_white"
            android:textStyle="bold"
            android:background="@drawable/bg_step_active" />

        <View android:id="@+id/divider12" android:layout_width="0dp" android:layout_height="2dp"
            android:layout_weight="1" android:background="@color/gray_200"
            android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>

        <TextView
            android:id="@+id/tvStep2Indicator"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="2"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:background="@drawable/bg_step_inactive" />

        <View android:id="@+id/divider23" android:layout_width="0dp" android:layout_height="2dp"
            android:layout_weight="1" android:background="@color/gray_200"
            android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>

        <TextView
            android:id="@+id/tvStep3Indicator"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="3"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:background="@drawable/bg_step_inactive" />

        <View android:id="@+id/divider34" android:layout_width="0dp" android:layout_height="2dp"
            android:layout_weight="1" android:background="@color/gray_200"
            android:layout_marginStart="4dp" android:layout_marginEnd="4dp"/>

        <TextView
            android:id="@+id/tvStep4Indicator"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="4"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:background="@drawable/bg_step_inactive" />

    </LinearLayout>

    <!-- Room Info Card (luôn hiển thị) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/bg_white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvRoomTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="2"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tvRoomAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvPostExpiry"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="@color/primary"
                android:layout_marginTop="4dp" />

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Nội dung 5 màn hình (ViewFlipper) -->
    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- STEP 1: Chọn ngày -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="16dp">

                <!-- Cảnh báo no-show -->
                <TextView
                    android:id="@+id/tvNoShowWarning"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"
                    android:background="@drawable/bg_warning_surface"
                    android:padding="12dp"
                    android:text="⚠ Tài khoản của bạn có lịch sử không đến đúng hẹn. Vui lòng đảm bảo bạn sẽ có mặt đúng giờ."
                    android:textColor="@color/error"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvBookingQuota"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="4dp"
                    android:padding="12dp"
                    android:text="Bạn còn 5/5 lượt đặt lịch phòng này trong hôm nay"
                    android:textColor="#1976D2"
                    android:background="#E3F2FD"
                    android:textSize="12sp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chọn ngày xem phòng"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp" />

                <!-- Calendar Header: tháng nav -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@color/bg_white"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/btnPrevMonth"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_back"
                        android:padding="4dp" />

                    <TextView
                        android:id="@+id/tvMonthYear"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <ImageView
                        android:id="@+id/btnNextMonth"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_arrow_right"
                        android:padding="4dp" />

                </LinearLayout>

                <!-- Day-of-week headers -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="@color/bg_white"
                    android:paddingStart="4dp"
                    android:paddingEnd="4dp">

                    <TextView android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                        android:gravity="center" android:text="T2" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                        android:gravity="center" android:text="T3" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                        android:gravity="center" android:text="T4" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                        android:gravity="center" android:text="T5" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                        android:gravity="center" android:text="T6" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                        android:gravity="center" android:text="T7" android:textSize="12sp" android:textColor="@color/text_secondary"/>
                    <TextView android:layout_width="0dp" android:layout_height="32dp" android:layout_weight="1"
                        android:gravity="center" android:text="CN" android:textSize="12sp" android:textColor="@color/error"/>

                </LinearLayout>

                <!-- Calendar Grid -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvCalendar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/bg_white" />

                <!-- Chú thích 4 màu -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:layout_marginTop="8dp"
                    android:background="@color/bg_white">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chú thích:"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• Xanh = Có thể đặt  •  Xám = Không khả dụng"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="• Vàng = 1-5 lịch hẹn  •  Đỏ = Hơn 5 lịch hẹn (rất bận)"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/tvRangeInfo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp" />

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- STEP 2: Chọn giờ -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="16dp">

                <TextView
                    android:id="@+id/tvSelectedDateLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chọn giờ xem phòng (mỗi slot 30 phút):"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="8dp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvTimeSlots"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/bg_white"
                    android:padding="8dp" />

                <TextView
                    android:id="@+id/tvNoSlots"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Không có khung giờ nào khả dụng cho ngày này."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:padding="24dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tvAppointmentNotice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    android:background="@color/bg_white"
                    android:padding="12dp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone" />

            </LinearLayout>
        </ScrollView>

        <!-- STEP 3: Thông tin cá nhân -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="16dp">

                <!-- Thời gian hẹn đã chọn -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/bg_white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Thời gian hẹn" android:textSize="13sp" android:textColor="@color/text_secondary"/>
                        <TextView
                            android:id="@+id/tvConfirmDateTime"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/primary"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Form thông tin người thuê -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/bg_white">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Thông tin của bạn" android:textSize="14sp"
                            android:textStyle="bold" android:textColor="@color/text_primary"
                            android:layout_marginBottom="12dp"/>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Họ và tên *" android:textSize="12sp" android:textColor="@color/color_444444"
                            android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtFullName"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_spinner_new"
                            android:hint="Nhập họ và tên"
                            android:inputType="textPersonName"
                            android:paddingStart="12dp"
                            android:textSize="14sp" />

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Giới tính" android:textSize="12sp" android:textColor="@color/color_444444"
                            android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <RadioGroup
                            android:id="@+id/rgGender"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_spinner_new"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="12dp">
                            <RadioButton android:id="@+id/rbMale" android:layout_width="0dp"
                                android:layout_height="wrap_content" android:layout_weight="1"
                                android:buttonTint="@color/bottom_nav_selected" android:text="Nam" android:textSize="14sp"/>
                            <RadioButton android:id="@+id/rbFemale" android:layout_width="0dp"
                                android:layout_height="wrap_content" android:layout_weight="1"
                                android:buttonTint="@color/bottom_nav_selected" android:text="Nữ" android:textSize="14sp"/>
                            <RadioButton android:id="@+id/rbOther" android:layout_width="0dp"
                                android:layout_height="wrap_content" android:layout_weight="1"
                                android:buttonTint="@color/bottom_nav_selected" android:text="Khác" android:textSize="14sp"/>
                        </RadioGroup>

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Số điện thoại *" android:textSize="12sp" android:textColor="@color/color_444444"
                            android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtPhone"
                            android:layout_width="match_parent"
                            android:layout_height="46dp"
                            android:layout_marginBottom="4dp"
                            android:background="@drawable/bg_spinner_new"
                            android:hint="0xxxxxxxxx"
                            android:inputType="phone"
                            android:maxLength="10"
                            android:paddingStart="12dp"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvPhoneError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            android:textSize="11sp"
                            android:textColor="@color/error"
                            android:visibility="gone" />

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Ghi chú thêm" android:textSize="12sp" android:textColor="@color/color_444444"
                            android:textStyle="bold" android:layout_marginBottom="4dp"/>
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtNote"
                            android:layout_width="match_parent"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_spinner_new"
                            android:gravity="top"
                            android:hint="Ví dụ: Tôi đi cùng người thân (không bắt buộc)"
                            android:inputType="textMultiLine"
                            android:maxLength="500"
                            android:paddingStart="12dp"
                            android:paddingTop="10dp"
                            android:textSize="14sp" />

                        <TextView
                            android:id="@+id/tvNoteCounter"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="end"
                            android:text="0/500"
                            android:textSize="11sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp" />

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Lưu ý từ chủ trọ -->
                <TextView
                    android:id="@+id/tvNoticeStep3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    android:background="@color/bg_white"
                    android:padding="12dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sau khi gửi: Chủ trọ có 48h để xác nhận. Bạn sẽ nhận thông báo khi có cập nhật."
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginBottom="8dp" />

            </LinearLayout>
        </ScrollView>

        <!-- STEP 4: Xác nhận thông tin -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kiểm tra lại thông tin"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="12dp" />

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp"
                    app:cardBackgroundColor="@color/bg_white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Row: Phòng -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="10dp">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                                android:text="Phòng" android:textSize="13sp" android:textColor="@color/text_secondary"/>
                            <TextView android:id="@+id/tvSummaryRoomValue" android:layout_width="0dp"
                                android:layout_height="wrap_content" android:layout_weight="1"
                                android:textSize="13sp" android:textStyle="bold" android:textColor="@color/text_primary"/>
                        </LinearLayout>

                        <!-- Row: Địa chỉ -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="10dp">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                                android:text="Địa chỉ" android:textSize="13sp" android:textColor="@color/text_secondary"/>
                            <TextView android:id="@+id/tvSummaryAddressValue" android:layout_width="0dp"
                                android:layout_height="wrap_content" android:layout_weight="1"
                                android:textSize="13sp" android:textColor="@color/text_primary"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/gray_200" android:layout_marginBottom="10dp"/>

                        <!-- Row: Ngày hẹn -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="10dp">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                                android:text="Ngày hẹn" android:textSize="13sp" android:textColor="@color/text_secondary"/>
                            <TextView android:id="@+id/tvSummaryDateValue" android:layout_width="0dp"
                                android:layout_height="wrap_content" android:layout_weight="1"
                                android:textSize="13sp" android:textStyle="bold" android:textColor="@color/primary"/>
                        </LinearLayout>

                        <!-- Row: Giờ hẹn -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="10dp">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                                android:text="Giờ hẹn" android:textSize="13sp" android:textColor="@color/text_secondary"/>
                            <TextView android:id="@+id/tvSummaryTimeValue" android:layout_width="0dp"
                                android:layout_height="wrap_content" android:layout_weight="1"
                                android:textSize="13sp" android:textStyle="bold" android:textColor="@color/primary"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/gray_200" android:layout_marginBottom="10dp"/>

                        <!-- Row: Họ và tên -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="10dp">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                                android:text="Họ và tên" android:textSize="13sp" android:textColor="@color/text_secondary"/>
                            <TextView android:id="@+id/tvSummaryNameValue" android:layout_width="0dp"
                                android:layout_height="wrap_content" android:layout_weight="1"
                                android:textSize="13sp" android:textColor="@color/text_primary"/>
                        </LinearLayout>

                        <!-- Row: Giới tính -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="10dp">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                                android:text="Giới tính" android:textSize="13sp" android:textColor="@color/text_secondary"/>
                            <TextView android:id="@+id/tvSummaryGenderValue" android:layout_width="0dp"
                                android:layout_height="wrap_content" android:layout_weight="1"
                                android:textSize="13sp" android:textColor="@color/text_primary"/>
                        </LinearLayout>

                        <!-- Row: Điện thoại -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal" android:layout_marginBottom="10dp">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                                android:text="Điện thoại" android:textSize="13sp" android:textColor="@color/text_secondary"/>
                            <TextView android:id="@+id/tvSummaryPhoneValue" android:layout_width="0dp"
                                android:layout_height="wrap_content" android:layout_weight="1"
                                android:textSize="13sp" android:textColor="@color/text_primary"/>
                        </LinearLayout>

                        <!-- Row: Ghi chú -->
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView android:layout_width="100dp" android:layout_height="wrap_content"
                                android:text="Ghi chú" android:textSize="13sp" android:textColor="@color/text_secondary"/>
                            <TextView android:id="@+id/tvSummaryNoteValue" android:layout_width="0dp"
                                android:layout_height="wrap_content" android:layout_weight="1"
                                android:textSize="13sp" android:textColor="@color/text_secondary"
                                android:fontStyle="italic" />
                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Chủ trọ có 48h để xác nhận. Bạn sẽ nhận thông báo khi có cập nhật."
                    android:textSize="11sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginBottom="16dp" />

                <!-- Step 4 action buttons (nằm trong view, không dùng bottom bar) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEditInfo"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Sửa thông tin"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        app:strokeColor="@color/primary"
                        android:textColor="@color/primary" />

                    <View android:layout_width="8dp" android:layout_height="1dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConfirmBooking"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="Xác nhận đặt lịch"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/bottom_nav_selected"
                        app:cornerRadius="12dp" />

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- STEP 5: Thành công -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:src="@drawable/ic_check_circle"
                android:background="@drawable/bg_success_circle"
                android:padding="16dp"
                app:tint="@color/bg_white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đặt lịch thành công!"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Yêu cầu của bạn đã được gửi đến chủ trọ. Chủ trọ có 48 giờ để xác nhận. Bạn sẽ nhận thông báo khi có cập nhật."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="32dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewAppointments"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Xem lịch hẹn của tôi"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:backgroundTint="@color/bottom_nav_selected"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoHome"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:text="Về trang chủ"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:strokeColor="@color/primary"
                android:textColor="@color/primary" />

        </LinearLayout>

    </ViewFlipper>

    <!-- Bottom Navigation Buttons (ẩn ở step 4 và 5, vì step 4 có nút riêng) -->
    <LinearLayout
        android:id="@+id/bottomNavBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="@color/bg_white"
        android:elevation="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrevStep"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Quay lại"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:visibility="gone"
            app:strokeColor="@color/primary"
            android:textColor="@color/primary" />

        <View android:layout_width="8dp" android:layout_height="1dp"
            android:id="@+id/btnSpacer" android:visibility="gone"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNextStep"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Tiếp theo"
            android:textSize="14sp"
            android:textAllCaps="false"
            app:backgroundTint="@color/bottom_nav_selected"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>
