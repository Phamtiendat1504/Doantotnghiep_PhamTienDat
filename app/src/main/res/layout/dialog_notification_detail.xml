<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="8dp">

    <!-- Header: icon + title + time -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="14dp">

        <FrameLayout
            android:id="@+id/dialogIconWrap"
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_notif_icon"
            android:layout_marginEnd="12dp">

            <ImageView
                android:id="@+id/dialogIvIcon"
                android:layout_width="23dp"
                android:layout_height="23dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_notification"
                android:contentDescription="@null" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/dialogTvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="14.5sp"
                android:textStyle="bold"
                android:textColor="#0F172A"
                android:lineSpacingExtra="2dp" />

            <TextView
                android:id="@+id/dialogTvTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textSize="11sp"
                android:textColor="#94A3B8" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F1F5F9"
        android:layout_marginBottom="14dp" />

    <!-- Message (scrollable khi dài) -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none">

        <TextView
            android:id="@+id/dialogTvMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13.5sp"
            android:textColor="#334155"
            android:lineSpacingExtra="5dp"
            android:paddingBottom="8dp" />
    </ScrollView>

</LinearLayout>
