<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_header_wave"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.20">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="8dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back"
                android:tint="@color/on_primary"
                android:padding="4dp"
                android:contentDescription="Quay lại" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Thông Tin Cá Nhân"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/on_primary"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Xem và cập nhật thông tin của bạn"
            android:textSize="13sp"
            android:textColor="@color/primary_light"
            android:paddingStart="64dp"
            android:paddingBottom="12dp" />

    </LinearLayout>

    <!-- ScrollView -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="32dp">

            <!-- Card thông tin tài khoản -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/bg_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Section label -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tài khoản"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="12dp" />

                    <!-- Họ và tên -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilFullName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Họ và tên"
                        app:errorEnabled="true"
                        style="@style/OutlinedBoxRounded">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtFullName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:enabled="false"
                            android:drawableStart="@drawable/ic_person"
                            android:drawableTint="#888888"
                            android:drawablePadding="12dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Email"
                        android:layout_marginTop="10dp"
                        app:errorEnabled="true"
                        style="@style/OutlinedBoxRounded">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:enabled="false"
                            android:drawableStart="@drawable/ic_email"
                            android:drawableTint="#888888"
                            android:drawablePadding="12dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Số điện thoại -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Số điện thoại"
                        android:layout_marginTop="10dp"
                        app:errorEnabled="true"
                        style="@style/OutlinedBoxRounded">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtPhone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="phone"
                            android:enabled="false"
                            android:drawableStart="@drawable/ic_phone"
                            android:drawableTint="#888888"
                            android:drawablePadding="12dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card thông tin cá nhân -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/bg_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin cá nhân"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:textAllCaps="true"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="12dp" />

                    <!-- Ngày sinh -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngày sinh"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="6dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_spinner_new"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_calendar"
                            app:tint="#888888" />

                        <TextView
                            android:id="@+id/tvBirthday"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Chưa cập nhật"
                            android:textSize="14sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginStart="12dp" />

                        <ImageView
                            android:id="@+id/btnPickDate"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_arrow_right"
                            app:tint="#999999"
                            android:visibility="gone" />

                    </LinearLayout>

                    <!-- Giới tính -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giới tính"
                        android:textSize="12sp"
                        android:textColor="@color/text_hint"
                        android:layout_marginBottom="6dp" />

                    <RadioGroup
                        android:id="@+id/rgGender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="12dp">

                        <RadioButton
                            android:id="@+id/rbMale"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="Nam"
                            android:textSize="14sp"
                            android:buttonTint="#1976D2"
                            android:enabled="false" />

                        <RadioButton
                            android:id="@+id/rbFemale"
                            android:layout_width="0dp"
                            android:layout_height="44dp"
                            android:layout_weight="1"
                            android:text="Nữ"
                            android:textSize="14sp"
                            android:buttonTint="#1976D2"
                            android:enabled="false" />

                    </RadioGroup>

                    <!-- Nghề nghiệp -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilOccupation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nghề nghiệp"
                        app:errorEnabled="true"
                        style="@style/OutlinedBoxRounded">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtOccupation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:enabled="false"
                            android:drawableStart="@drawable/ic_post"
                            android:drawableTint="#888888"
                            android:drawablePadding="12dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Địa chỉ -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Địa chỉ"
                        android:layout_marginTop="10dp"
                        app:errorEnabled="true"
                        style="@style/OutlinedBoxRounded">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtAddress"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPostalAddress"
                            android:enabled="false"
                            android:drawableStart="@drawable/ic_home"
                            android:drawableTint="#888888"
                            android:drawablePadding="12dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Nút thao tác -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Thay đổi thông tin"
                android:textSize="15sp"
                android:textAllCaps="false"
                android:layout_marginTop="16dp"
                app:backgroundTint="@color/primary"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Lưu thông tin"
                android:textSize="15sp"
                android:textAllCaps="false"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                app:backgroundTint="#2E7D32"
                app:cornerRadius="14dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Hủy"
                android:textSize="15sp"
                android:textAllCaps="false"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:backgroundTint="@color/bg_white"
                app:strokeColor="#CCCCCC"
                app:strokeWidth="1dp"
                android:textColor="@color/text_secondary"
                app:cornerRadius="14dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_gravity="center"
                android:visibility="gone" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>