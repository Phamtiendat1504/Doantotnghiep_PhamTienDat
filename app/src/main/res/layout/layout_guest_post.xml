<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    android:weightSum="1">

    <!-- Vùng Typography: Căn trái, sử dụng khoảng trắng (white space) để tạo sự sang trọng -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center_vertical"
        android:orientation="vertical"
        android:paddingHorizontal="32dp"
        android:paddingBottom="40dp">

        <!-- Đường accent màu xanh làm điểm nhấn chuyên nghiệp -->
        <View
            android:layout_width="48dp"
            android:layout_height="5dp"
            android:layout_marginBottom="28dp"
            android:background="@color/primary" />

        <!-- Tiêu đề chính: To, rõ ràng, gãy gọn -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:letterSpacing="-0.03"
            android:lineSpacingExtra="8dp"
            android:text="Cho Thuê\nChuyên Nghiệp"
            android:textColor="#1A1A1A"
            android:textSize="38sp"
            android:textStyle="bold" />

        <!-- Đoạn mô tả phụ: Text size 16sp chuẩn đọc, khoảng cách dòng tốt -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:lineSpacingExtra="6dp"
            android:text="Nền tảng hỗ trợ chủ nhà đăng tin, quản lý tiện ích và tìm kiếm hàng ngàn người thuê tiềm năng một cách nhanh chóng, an toàn."
            android:textColor="#666666"
            android:textSize="16sp" />

    </LinearLayout>

    <!-- Khu vực nút bấm đáy -->
    <LinearLayout
        android:id="@+id/buttonContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="48dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuestLogin"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="Đăng nhập tài khoản"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            app:cornerRadius="12dp"
            app:elevation="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGuestRegister"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="12dp"
            android:text="Tạo tài khoản mới"
            android:textAllCaps="false"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:strokeColor="@color/primary"
            app:strokeWidth="1.5dp" />

    </LinearLayout>

</LinearLayout>