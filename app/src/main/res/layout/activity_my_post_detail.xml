<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/padding_large"
        android:paddingEnd="@dimen/padding_large"
        android:paddingTop="@dimen/spacing_14"
        android:paddingBottom="@dimen/spacing_14">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="@dimen/dimen_36dp"
            android:layout_height="@dimen/dimen_36dp"
            android:padding="@dimen/elevation_6"
            android:src="@drawable/ic_back"
            app:tint="@android:color/white" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/corner_radius_10"
            android:text="@string/txt_chi_tiet_bai_ang"
            android:textColor="@android:color/white"
            android:textSize="@dimen/text_size_20"
            android:textStyle="bold" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvStatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/corner_radius_10"
            android:paddingEnd="@dimen/corner_radius_10"
            android:paddingTop="@dimen/elevation_4"
            android:paddingBottom="@dimen/elevation_4"
            android:textSize="@dimen/text_size_12"
            android:textStyle="bold" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_24">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_230dp">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/viewPagerImages"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvImageCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="@dimen/corner_radius_10"
                    android:background="@color/color_66000000"
                    android:paddingStart="@dimen/corner_radius_10"
                    android:paddingEnd="@dimen/corner_radius_10"
                    android:paddingTop="@dimen/elevation_4"
                    android:paddingBottom="@dimen/elevation_4"
                    android:textColor="@android:color/white"
                    android:textSize="@dimen/text_size_12"
                    android:textStyle="bold" />

            </FrameLayout>

            <LinearLayout
                android:id="@+id/layoutRejectReason"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_large"
                android:layout_marginEnd="@dimen/padding_large"
                android:layout_marginTop="@dimen/padding_medium"
                android:background="@color/bg_error"
                android:gravity="center_vertical"
                android:orientation="vertical"
                android:padding="@dimen/padding_medium"
                android:visibility="gone">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/home_notification"
                    android:textColor="@color/secondary"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvRejectReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/elevation_4"
                    android:textColor="@color/secondary"
                    android:textSize="@dimen/text_size_13" />

            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_large"
                android:layout_marginEnd="@dimen/padding_large"
                android:layout_marginTop="@dimen/padding_medium"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="@dimen/spacing_14"
                app:cardElevation="@dimen/elevation_3">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/dimen_19sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_small"
                        android:textColor="@color/secondary"
                        android:textSize="@dimen/dimen_22sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_small"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_13" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvPostDate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/elevation_4"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_size_12" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_large"
                android:layout_marginEnd="@dimen/padding_large"
                android:layout_marginTop="@dimen/corner_radius_10"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="@dimen/spacing_14"
                app:cardElevation="@dimen/elevation_3">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_thong_tin_phong"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_15"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/layoutRoomInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/elevation_6"
                        android:orientation="vertical" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_large"
                android:layout_marginEnd="@dimen/padding_large"
                android:layout_marginTop="@dimen/corner_radius_10"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="@dimen/spacing_14"
                app:cardElevation="@dimen/elevation_3">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_tien_ich"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_15"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/layoutAmenities"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/elevation_6"
                        android:orientation="vertical" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_large"
                android:layout_marginEnd="@dimen/padding_large"
                android:layout_marginTop="@dimen/corner_radius_10"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="@dimen/spacing_14"
                app:cardElevation="@dimen/elevation_3">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_mo_ta"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_15"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/elevation_6"
                        android:lineSpacingExtra="@dimen/elevation_3"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_14" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMarkRented"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_52dp"
                android:layout_marginStart="@dimen/padding_large"
                android:layout_marginEnd="@dimen/padding_large"
                android:layout_marginTop="@dimen/spacing_14"
                android:text="@string/status_rented"
                android:textAllCaps="false"
                android:textSize="@dimen/text_size_16"
                android:visibility="gone"
                app:backgroundTint="@color/success"
                app:cornerRadius="@dimen/spacing_14" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEditPost"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_52dp"
                android:layout_marginStart="@dimen/padding_large"
                android:layout_marginEnd="@dimen/padding_large"
                android:layout_marginTop="@dimen/corner_radius_10"
                android:text="@string/txt_sua_va_ang_lai"
                android:textAllCaps="false"
                android:textSize="@dimen/text_size_16"
                android:visibility="gone"
                app:backgroundTint="@color/bottom_nav_selected"
                app:cornerRadius="@dimen/spacing_14" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
