<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <RelativeLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:background="@color/white"
        android:elevation="@dimen/elevation_4"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="@dimen/dimen_48dp"
            android:layout_height="@dimen/dimen_48dp"
            android:layout_centerVertical="true"
            android:layout_marginStart="@dimen/padding_small"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="@dimen/padding_medium"
            android:src="@drawable/ic_back"
            app:tint="@color/text_primary" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="@string/txt_thong_tin_phong_hen"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_18"
            android:textStyle="bold" />
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/padding_large">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_240dp"
                app:cardCornerRadius="@dimen/padding_large"
                app:cardElevation="@dimen/stroke_2">

                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/viewPagerImages"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@color/gray_200" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvImageCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="@dimen/padding_medium"
                    android:background="@drawable/bg_image_count"
                    android:paddingHorizontal="@dimen/padding_medium"
                    android:paddingVertical="@dimen/elevation_6"
                    android:text="@string/txt_0_0"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_12"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_xlarge"
                android:text="@string/txt_tieu_e_phong_tro"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/dimen_22sp"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/elevation_6"
                android:text="@string/txt_0_thang"
                android:textColor="@color/secondary"
                android:textSize="@dimen/text_size_20"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_medium"
                android:drawablePadding="@dimen/padding_small"
                android:gravity="center_vertical"
                android:text="@string/txt_ia_chi_phong"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_14"
                app:drawableStartCompat="@drawable/ic_location"
                app:drawableTint="@color/text_secondary" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/image_size_28"
                android:text="@string/txt_chi_tiet_phong"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_medium"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/padding_large"
                app:cardElevation="@dimen/stroke_2">

                <LinearLayout
                    android:id="@+id/layoutRoomInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/image_size_28"
                android:text="@string/txt_tien_nghi_amp_dich_vu"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_medium"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/padding_large"
                app:cardElevation="@dimen/stroke_2">

                <LinearLayout
                    android:id="@+id/layoutAmenities"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/image_size_28"
                android:text="@string/txt_thong_tin_chu_tro"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_medium"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/padding_large"
                app:cardElevation="@dimen/stroke_2">

                <LinearLayout
                    android:id="@+id/layoutOwnerInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large" />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/image_size_28"
                android:text="@string/txt_mo_ta_them"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_medium"
                android:lineSpacingExtra="@dimen/elevation_6"
                android:text="@string/txt_noi_dung_mo_ta_bai_viet"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_15" />

            <!-- Thông tin lịch hẹn -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAppointmentInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/corner_radius_10"
                android:visibility="gone"
                app:cardCornerRadius="@dimen/padding_large"
                app:cardElevation="@dimen/elevation_3"
                app:cardBackgroundColor="@color/bg_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin lịch hẹn"
                        android:textSize="@dimen/text_size_15"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="@dimen/padding_medium" />

                    <LinearLayout
                        android:id="@+id/layoutExpiryRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="@dimen/padding_small"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/elevation_4">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Ngày đăng bài:"
                                android:textSize="@dimen/text_size_13"
                                android:textColor="@color/text_secondary" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvPostCreatedAtDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/text_size_13"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Hết hạn hiển thị:"
                                android:textSize="@dimen/text_size_13"
                                android:textColor="@color/text_secondary" />

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvPostExpiryDisplay"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textSize="@dimen/text_size_13"
                                android:textStyle="bold"
                                android:textColor="@color/color_C2410C" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutTimeSlotsRow"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Khung giờ nhận lịch hẹn:"
                            android:textSize="@dimen/text_size_13"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="@dimen/elevation_6" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvAvailableTimeSlotsDisplay"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textSize="@dimen/text_size_13"
                            android:textColor="@color/text_primary"
                            android:lineSpacingExtra="@dimen/stroke_2" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_60dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>