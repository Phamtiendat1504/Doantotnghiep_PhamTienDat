<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="0dp">

    <!-- Header gradient -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_dialog_header"
        android:padding="@dimen/padding_xlarge"
        android:gravity="center">

        <ImageView
            android:layout_width="@dimen/dimen_48dp"
            android:layout_height="@dimen/dimen_48dp"
            android:src="@drawable/ic_search_location"
            app:tint="@android:color/white"
            android:layout_marginBottom="@dimen/padding_small" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_tim_ia_chi"
            android:textSize="@dimen/text_size_18"
            android:textStyle="bold"
            android:textColor="@android:color/white" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_nhap_ia_chi_hoac_ten_khu_"
            android:textSize="@dimen/text_size_12"
            android:textColor="@color/color_CCFFFFFF"
            android:layout_marginTop="@dimen/stroke_2" />

    </LinearLayout>

    <!-- Input area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/padding_xlarge"
        android:background="@android:color/white">

        <!-- Search input box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_input"
            android:paddingStart="@dimen/spacing_14"
            android:paddingEnd="@dimen/spacing_14">

            <ImageView
                android:layout_width="@dimen/padding_xlarge"
                android:layout_height="@dimen/padding_xlarge"
                android:src="@android:drawable/ic_menu_search"
                android:layout_marginEnd="@dimen/corner_radius_10" />

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtSearchQuery"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="@string/txt_vd_15_nguyen_van_linh_ha_"
                android:textSize="@dimen/text_size_14"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:background="@null"
                android:imeOptions="actionSearch"
                android:inputType="textPostalAddress"
                android:maxLines="1"
                android:singleLine="true" />

        </LinearLayout>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_meo_nhap_so_nha_ten_uong_"
            android:textSize="@dimen/text_size_11"
            android:textColor="@color/color_888888"
            android:layout_marginTop="@dimen/padding_small"
            android:layout_marginStart="@dimen/elevation_4" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/padding_xlarge"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDialogCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dimen_44dp"
                android:text="@string/action_cancel"
                android:textSize="@dimen/text_size_14"
                android:layout_marginEnd="@dimen/padding_small"
                app:strokeColor="@color/primary"
                android:textColor="@color/primary"
                app:cornerRadius="@dimen/corner_radius_10" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDialogSearch"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/dimen_44dp"
                android:text="@string/txt_tim_kiem"
                android:textSize="@dimen/text_size_14"
                android:textAllCaps="false"
                app:backgroundTint="@color/primary"
                app:cornerRadius="@dimen/corner_radius_10" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
