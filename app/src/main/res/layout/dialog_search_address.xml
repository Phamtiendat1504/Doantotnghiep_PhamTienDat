<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="0dp">

    <!-- Header gradient -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_dialog_header"
        android:padding="20dp"
        android:gravity="center">

        <ImageView
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_search_location"
            android:tint="@android:color/white"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tìm địa chỉ"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@android:color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nhập địa chỉ hoặc tên khu vực"
            android:textSize="12sp"
            android:textColor="#CCffffff"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Input area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@android:color/white">

        <!-- Search input box -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_input"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_search"
                android:layout_marginEnd="10dp" />

            <EditText
                android:id="@+id/edtSearchQuery"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="VD: 15 Nguyễn Văn Linh, Hà Đông..."
                android:textSize="14sp"
                android:textColor="#1A1A2E"
                android:textColorHint="#999999"
                android:background="@null"
                android:imeOptions="actionSearch"
                android:inputType="textPostalAddress"
                android:maxLines="1"
                android:singleLine="true" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💡 Mẹo: Nhập số nhà, tên đường hoặc tên khu vực"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginTop="8dp"
            android:layout_marginStart="4dp" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDialogCancel"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Hủy"
                android:textSize="14sp"
                android:layout_marginEnd="8dp"
                app:strokeColor="@color/primary"
                android:textColor="@color/primary"
                app:cornerRadius="10dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDialogSearch"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="🔍  Tìm kiếm"
                android:textSize="14sp"
                android:textAllCaps="false"
                app:backgroundTint="@color/primary"
                app:cornerRadius="10dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
