<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- ── HEADER ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen_64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/padding_small"
        android:paddingEnd="@dimen/padding_large"
        android:background="@color/bg_white"
        android:elevation="@dimen/elevation_4">

        <ImageView
            android:id="@+id/btnConvBack"
            android:layout_width="@dimen/dimen_44dp"
            android:layout_height="@dimen/dimen_44dp"
            android:padding="@dimen/corner_radius_10"
            android:src="@drawable/ic_back"
            app:tint="@color/text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/txt_tin_nhan"
            android:textSize="@dimen/text_size_18"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginStart="@dimen/padding_small" />

    </LinearLayout>

    <!-- ── EMPTY STATE ─────────────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/layoutConvEmpty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <ImageView
            android:layout_width="@dimen/dimen_80dp"
            android:layout_height="@dimen/dimen_80dp"
            android:src="@drawable/ic_ai"
            app:tint="@color/text_disabled"
            android:alpha="0.6" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_chua_co_cuoc_tro_chuyen_n"
            android:textSize="@dimen/text_size_16"
            android:textColor="@color/color_AAAAAA"
            android:layout_marginTop="@dimen/padding_large" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_hay_tim_phong_va_nhan_tin"
            android:textSize="@dimen/text_size_13"
            android:textColor="@color/text_disabled"
            android:layout_marginTop="@dimen/elevation_6" />

    </LinearLayout>

    <!-- ── CONVERSATIONS LIST ──────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvConversations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingTop="@dimen/padding_small"
        android:paddingBottom="@dimen/dimen_80dp" />

</LinearLayout>
