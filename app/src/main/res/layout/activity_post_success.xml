<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Nền xanh phía trên -->
    <LinearLayout
        android:id="@+id/layoutTop"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_header_wave"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.36">

        <!-- Vòng tròn xanh lá + icon check -->
        <FrameLayout
            android:layout_width="110dp"
            android:layout_height="110dp">

            <!-- Vòng ngoài mờ -->
            <View
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:background="@drawable/bg_success_circle"
                android:alpha="0.3" />

            <!-- Vòng trong đậm -->
            <View
                android:layout_width="84dp"
                android:layout_height="84dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_success_circle" />

            <!-- Icon check -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✓"
                android:textSize="38sp"
                android:textStyle="bold"
                android:textColor="@color/success" />

        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đăng bài thành công!"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/on_primary"
            android:layout_marginTop="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bài đăng đã được gửi đến hệ thống"
            android:textSize="13sp"
            android:textColor="@color/primary_light"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <!-- Card thông tin bên dưới -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/layoutTop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="32dp">

            <!-- Card 3 bước quy trình -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/bg_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quy trình xét duyệt"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="20dp" />

                    <!-- Bước 1  – ĐÃ XONG -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">

                        <!-- Cột trái: số + đường dọc -->
                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_step_done"
                                android:text="1"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_primary"
                                android:gravity="center" />

                            <View
                                android:layout_width="2dp"
                                android:layout_height="40dp"
                                android:background="@color/success"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp"
                            android:layout_marginBottom="28dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Nhập thông tin"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/success" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bài đăng đã được gửi thành công"
                                android:textSize="12sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Bước 2  – ĐANG XỬ LÝ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">

                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_step_active"
                                android:text="2"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_primary"
                                android:gravity="center" />

                            <View
                                android:layout_width="2dp"
                                android:layout_height="40dp"
                                android:background="@color/gray_300"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp"
                            android:layout_marginBottom="28dp">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Chờ admin duyệt"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/primary" />

                                <!-- Badge "Đang xử lý" -->
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_badge_pending"
                                    android:paddingStart="8dp"
                                    android:paddingEnd="8dp"
                                    android:paddingTop="2dp"
                                    android:paddingBottom="2dp"
                                    android:text="Đang xử lý"
                                    android:textSize="10sp"
                                    android:textColor="@color/warning"
                                    android:textStyle="bold"
                                    android:layout_marginStart="8dp" />

                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Admin sẽ kiểm duyệt trong 1–2 giờ"
                                android:textSize="12sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Bước 3  – CHƯA -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">

                        <LinearLayout
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <TextView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_step_pending"
                                android:text="3"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_primary"
                                android:gravity="center" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bài đăng hoạt động"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_hint" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Hiển thị cho người thuê tìm kiếm"
                                android:textSize="12sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="2dp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card thông tin bài vừa đăng -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/bg_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <View
                            android:layout_width="4dp"
                            android:layout_height="18dp"
                            android:background="@color/primary"
                            android:layout_marginEnd="8dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thông tin bài đăng"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="90dp"
                            android:layout_height="wrap_content"
                            android:text="Tiêu đề"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint" />

                        <TextView
                            android:id="@+id/tvPostTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="–"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:maxLines="2"
                            android:ellipsize="end" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="90dp"
                            android:layout_height="wrap_content"
                            android:text="Giá thuê"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint" />

                        <TextView
                            android:id="@+id/tvPostPrice"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="–"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/secondary" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="90dp"
                            android:layout_height="wrap_content"
                            android:text="Khu vực"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint" />

                        <TextView
                            android:id="@+id/tvPostLocation"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="–"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Card cảnh báo thời hạn bài đăng -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="#FFF8E1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Tiêu đề cảnh báo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⚠️"
                            android:textSize="16sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lưu ý về thời hạn bài đăng"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="@color/warning"
                            android:layout_marginStart="6dp" />

                    </LinearLayout>

                    <!-- Dòng 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="•"
                            android:textSize="13sp"
                            android:textColor="@color/gray_700"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Bài đăng sẽ hiển thị trong vòng 2 tháng kể từ ngày đăng."
                            android:textSize="12sp"
                            android:textColor="@color/gray_700"
                            android:lineSpacingExtra="2dp" />

                    </LinearLayout>

                    <!-- Dòng 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="•"
                            android:textSize="13sp"
                            android:textColor="@color/gray_700"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Hết 2 tháng, bài sẽ tự động bị ẩn và bạn sẽ nhận thông báo."
                            android:textSize="12sp"
                            android:textColor="@color/gray_700"
                            android:lineSpacingExtra="2dp" />

                    </LinearLayout>

                    <!-- Dòng 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="•"
                            android:textSize="13sp"
                            android:textColor="@color/gray_700"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Bạn có thể gia hạn thêm 2 tháng hoặc đánh dấu để cho thuê trong mục &quot;Bài đăng của tôi&quot;."
                            android:textSize="12sp"
                            android:textColor="@color/gray_700"
                            android:lineSpacingExtra="2dp" />

                    </LinearLayout>

                    <!-- Dòng 4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="•"
                            android:textSize="13sp"
                            android:textColor="@color/gray_700"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Nếu không thao tác, bài sẽ bị xóa vĩnh viễn sau 1 tháng tiếp theo."
                            android:textSize="12sp"
                            android:textColor="@color/gray_700"
                            android:lineSpacingExtra="2dp" />

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Nút Xem bài đăng của tôi -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewMyPosts"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Xem bài đăng của tôi"
                android:textSize="15sp"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:layout_marginBottom="10dp"
                app:backgroundTint="@color/primary"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_post"
                app:iconTint="@color/on_primary"
                app:iconPadding="8dp" />

            <!-- Nút Đăng bài khác -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPostAnother"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Đăng bài khác"
                android:textSize="15sp"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                app:backgroundTint="@color/primary_surface"
                app:cornerRadius="14dp"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>