<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- Nền xanh phía trên -->
    <LinearLayout
        android:id="@+id/layoutTop"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_header_wave"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.36">

        <!-- Vòng tròn xanh lá + icon check -->
        <FrameLayout
            android:layout_width="@dimen/dimen_110dp"
            android:layout_height="@dimen/dimen_110dp">

            <!-- Vòng ngoài mờ -->
            <View
                android:layout_width="@dimen/dimen_110dp"
                android:layout_height="@dimen/dimen_110dp"
                android:background="@drawable/bg_success_circle"
                android:alpha="0.3" />

            <!-- Vòng trong đậm -->
            <View
                android:layout_width="@dimen/dimen_84dp"
                android:layout_height="@dimen/dimen_84dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_success_circle" />

            <!-- Icon check -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/string_xsculb"
                android:textSize="@dimen/dimen_38sp"
                android:textStyle="bold"
                android:textColor="@color/success" />

        </FrameLayout>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/post_success_title"
            android:textSize="@dimen/dimen_22sp"
            android:textStyle="bold"
            android:textColor="@color/on_primary"
            android:layout_marginTop="@dimen/padding_large" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/post_success_subtitle"
            android:textSize="@dimen/text_size_13"
            android:textColor="@color/primary_light"
            android:layout_marginTop="@dimen/elevation_6" />

    </LinearLayout>

    <!-- Card thông tin bên dưới -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/layoutTop"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/padding_large"
            android:paddingEnd="@dimen/padding_large"
            android:paddingTop="@dimen/padding_xlarge"
            android:paddingBottom="@dimen/image_size_32">

            <!-- Card 3 bước quy trình -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/padding_large"
                app:cardCornerRadius="@dimen/padding_large"
                app:cardElevation="@dimen/elevation_4"
                app:cardBackgroundColor="@color/bg_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_xlarge">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/post_process_title"
                        android:textSize="@dimen/text_size_15"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="@dimen/padding_xlarge" />

                    <!-- Bước 1  – ĐÃ XONG -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">

                        <!-- Cột trái: số + đường dọc -->
                        <LinearLayout
                            android:layout_width="@dimen/dimen_36dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="@dimen/image_size_32"
                                android:layout_height="@dimen/image_size_32"
                                android:background="@drawable/bg_step_done"
                                android:text="@string/txt_1"
                                android:textSize="@dimen/text_size_14"
                                android:textStyle="bold"
                                android:textColor="@color/on_primary"
                                android:gravity="center" />

                            <View
                                android:layout_width="@dimen/stroke_2"
                                android:layout_height="@dimen/image_size_40"
                                android:background="@color/success"
                                android:layout_marginTop="@dimen/stroke_2" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/spacing_14"
                            android:layout_marginBottom="@dimen/image_size_28">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/post_step_1_title"
                                android:textSize="@dimen/text_size_14"
                                android:textStyle="bold"
                                android:textColor="@color/success" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/post_step_1_desc"
                                android:textSize="@dimen/text_size_12"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="@dimen/stroke_2" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Bước 2  – ĐANG XỬ LÝ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">

                        <LinearLayout
                            android:layout_width="@dimen/dimen_36dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="@dimen/image_size_32"
                                android:layout_height="@dimen/image_size_32"
                                android:background="@drawable/bg_step_active"
                                android:text="@string/txt_2"
                                android:textSize="@dimen/text_size_14"
                                android:textStyle="bold"
                                android:textColor="@color/on_primary"
                                android:gravity="center" />

                            <View
                                android:layout_width="@dimen/stroke_2"
                                android:layout_height="@dimen/image_size_40"
                                android:background="@color/gray_300"
                                android:layout_marginTop="@dimen/stroke_2" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/spacing_14"
                            android:layout_marginBottom="@dimen/image_size_28">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/post_step_2_title"
                                    android:textSize="@dimen/text_size_14"
                                    android:textStyle="bold"
                                    android:textColor="@color/primary" />

                                <!-- Badge "Đang xử lý" -->
                                <com.google.android.material.textview.MaterialTextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:background="@drawable/bg_badge_pending"
                                    android:paddingStart="@dimen/padding_small"
                                    android:paddingEnd="@dimen/padding_small"
                                    android:paddingTop="@dimen/stroke_2"
                                    android:paddingBottom="@dimen/stroke_2"
                                    android:text="@string/post_step_2_badge"
                                    android:textSize="@dimen/text_size_10"
                                    android:textColor="@color/warning"
                                    android:textStyle="bold"
                                    android:layout_marginStart="@dimen/padding_small" />

                            </LinearLayout>

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/post_step_2_desc"
                                android:textSize="@dimen/text_size_12"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="@dimen/stroke_2" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Bước 3  – CHƯA -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">

                        <LinearLayout
                            android:layout_width="@dimen/dimen_36dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="@dimen/image_size_32"
                                android:layout_height="@dimen/image_size_32"
                                android:background="@drawable/bg_step_pending"
                                android:text="@string/txt_3"
                                android:textSize="@dimen/text_size_14"
                                android:textStyle="bold"
                                android:textColor="@color/on_primary"
                                android:gravity="center" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/spacing_14">

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/post_step_3_title"
                                android:textSize="@dimen/text_size_14"
                                android:textStyle="bold"
                                android:textColor="@color/text_hint" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/post_step_3_desc"
                                android:textSize="@dimen/text_size_12"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="@dimen/stroke_2" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card thông tin bài vừa đăng -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/padding_xlarge"
                app:cardCornerRadius="@dimen/padding_large"
                app:cardElevation="@dimen/elevation_3"
                app:cardBackgroundColor="@color/bg_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_18">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/padding_medium">

                        <View
                            android:layout_width="@dimen/elevation_4"
                            android:layout_height="@dimen/spacing_18"
                            android:background="@color/primary"
                            android:layout_marginEnd="@dimen/padding_small" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/post_info_title"
                            android:textSize="@dimen/text_size_14"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/elevation_6">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="@dimen/image_size_90"
                            android:layout_height="wrap_content"
                            android:text="@string/post_info_label_id"
                            android:textSize="@dimen/text_size_13"
                            android:textColor="@color/text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvPostId"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/string_tbw298"
                            android:textSize="@dimen/text_size_13"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/elevation_6">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="@dimen/image_size_90"
                            android:layout_height="wrap_content"
                            android:text="@string/post_info_label_title"
                            android:textSize="@dimen/text_size_13"
                            android:textColor="@color/text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvPostTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/string_tbw298"
                            android:textSize="@dimen/text_size_13"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:maxLines="2"
                            android:ellipsize="end" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/elevation_6">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="@dimen/image_size_90"
                            android:layout_height="wrap_content"
                            android:text="@string/post_info_label_price"
                            android:textSize="@dimen/text_size_13"
                            android:textColor="@color/text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvPostPrice"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/string_tbw298"
                            android:textSize="@dimen/text_size_13"
                            android:textStyle="bold"
                            android:textColor="@color/secondary" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="@dimen/image_size_90"
                            android:layout_height="wrap_content"
                            android:text="@string/post_info_label_location"
                            android:textSize="@dimen/text_size_13"
                            android:textColor="@color/text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvPostLocation"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/string_tbw298"
                            android:textSize="@dimen/text_size_13"
                            android:textColor="@color/text_primary" />

                    </LinearLayout>


                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Card cảnh báo thời hạn bài đăng -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/padding_xlarge"
                app:cardCornerRadius="@dimen/spacing_14"
                app:cardElevation="@dimen/stroke_2"
                app:cardBackgroundColor="@color/color_FFF8E1">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large">

                    <!-- Tiêu đề cảnh báo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/corner_radius_10">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/string_ptbhqa"
                            android:textSize="@dimen/text_size_16" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/post_note_title"
                            android:textSize="@dimen/text_size_13"
                            android:textStyle="bold"
                            android:textColor="@color/warning"
                            android:layout_marginStart="@dimen/elevation_6" />

                    </LinearLayout>

                    <!-- Dòng 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top"
                        android:layout_marginBottom="@dimen/elevation_6">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/string_2a5te2"
                            android:textSize="@dimen/text_size_13"
                            android:textColor="@color/gray_700"
                            android:layout_marginEnd="@dimen/elevation_6" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/post_note_line_1"
                            android:textSize="@dimen/text_size_12"
                            android:textColor="@color/gray_700"
                            android:lineSpacingExtra="@dimen/stroke_2" />

                    </LinearLayout>

                    <!-- Dòng 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top"
                        android:layout_marginBottom="@dimen/elevation_6">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/string_2a5te2"
                            android:textSize="@dimen/text_size_13"
                            android:textColor="@color/gray_700"
                            android:layout_marginEnd="@dimen/elevation_6" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/post_note_line_2"
                            android:textSize="@dimen/text_size_12"
                            android:textColor="@color/gray_700"
                            android:lineSpacingExtra="@dimen/stroke_2" />

                    </LinearLayout>

                    <!-- Dòng 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top"
                        android:layout_marginBottom="@dimen/elevation_6">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/string_2a5te2"
                            android:textSize="@dimen/text_size_13"
                            android:textColor="@color/gray_700"
                            android:layout_marginEnd="@dimen/elevation_6" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/post_note_line_3"
                            android:textSize="@dimen/text_size_12"
                            android:textColor="@color/gray_700"
                            android:lineSpacingExtra="@dimen/stroke_2" />

                    </LinearLayout>

                    <!-- Dòng 4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="top">

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/string_2a5te2"
                            android:textSize="@dimen/text_size_13"
                            android:textColor="@color/gray_700"
                            android:layout_marginEnd="@dimen/elevation_6" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/post_note_line_4"
                            android:textSize="@dimen/text_size_12"
                            android:textColor="@color/gray_700"
                            android:lineSpacingExtra="@dimen/stroke_2" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Nút Xem bài đăng của tôi -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewMyPosts"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_52dp"
                android:text="@string/post_btn_my_posts"
                android:textSize="@dimen/text_size_15"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/corner_radius_10"
                app:backgroundTint="@color/primary"
                app:cornerRadius="@dimen/spacing_14"
                app:icon="@drawable/ic_post"
                app:iconTint="@color/on_primary"
                app:iconPadding="@dimen/padding_small" />

            <!-- Nút Đăng bài khác -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPostAnother"
                android:layout_width="match_parent"
                android:layout_height="@dimen/dimen_52dp"
                android:text="@string/post_btn_another"
                android:textSize="@dimen/text_size_15"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                app:backgroundTint="@color/primary_surface"
                app:cornerRadius="@dimen/spacing_14"
                app:strokeColor="@color/primary"
                app:strokeWidth="@dimen/stroke_1" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>