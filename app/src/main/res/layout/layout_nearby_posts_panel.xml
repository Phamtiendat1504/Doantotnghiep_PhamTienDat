<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/panelNearbyPosts"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="bottom"
    android:visibility="gone"
    app:cardBackgroundColor="@android:color/white"
    app:cardCornerRadius="@dimen/spacing_18"
    app:cardElevation="@dimen/elevation_3">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/padding_medium"
        android:paddingEnd="@dimen/padding_medium"
        android:paddingTop="@dimen/corner_radius_10"
        android:paddingBottom="@dimen/corner_radius_10">

        <!-- Drag handle -->
        <View
            android:layout_width="32dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="@dimen/elevation_6"
            android:background="#CCCCCC"
            android:backgroundTint="@color/text_hint" />

        <!-- Header: tiêu đề + làm mới + chọn tất cả + ẩn panel -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvPanelTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Phòng trọ gần đây"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_15"
                android:textStyle="bold" />

            <!-- Nút làm mới dữ liệu -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRefreshPanel"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/elevation_4"
                android:minWidth="0dp"
                android:paddingStart="@dimen/elevation_6"
                android:paddingEnd="@dimen/elevation_6"
                android:text="↻"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_size_18"
                app:rippleColor="@color/primary" />

            <CheckBox
                android:id="@+id/cbPanelSelectAll"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="@color/primary"
                android:text="Chọn tất cả"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_13" />

            <!-- Nút ẩn panel -->
            <ImageView
                android:id="@+id/btnTogglePanel"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginStart="@dimen/elevation_4"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="@dimen/elevation_4"
                android:src="@drawable/ic_chevron_down"
                android:contentDescription="Ẩn danh sách"
                app:tint="@color/text_secondary" />

        </LinearLayout>

        <!-- Bán kính tìm kiếm -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/elevation_6"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bán kính:"
                android:textColor="@color/text_hint"
                android:textSize="@dimen/text_size_12" />

            <SeekBar
                android:id="@+id/seekBarPanelRadius"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_small"
                android:layout_marginEnd="@dimen/padding_small"
                android:layout_weight="1"
                android:max="9"
                android:progress="5"
                android:progressTint="@color/primary"
                android:thumbTint="@color/primary" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvPanelRadiusValue"
                android:layout_width="44dp"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:text="3.0 km"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_size_12"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/elevation_6"
            android:background="#E8E8E8" />

        <!-- Danh sách phòng (cuộn được khi nhiều) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvNearbyPosts"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/elevation_4"
            android:nestedScrollingEnabled="true"
            android:overScrollMode="never" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/elevation_4"
            android:background="#E8E8E8" />

        <!-- Nút xác nhận -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmLocations"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_48dp"
            android:layout_marginTop="@dimen/padding_small"
            android:enabled="false"
            android:text="Xác nhận vị trí"
            android:textAllCaps="false"
            android:textSize="@dimen/text_size_14"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            app:cornerRadius="@dimen/spacing_14" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
