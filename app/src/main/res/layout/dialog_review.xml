<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/padding_xlarge"
    android:background="@drawable/bg_dialog">

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/txt_anh_gia_chu_tro"
        android:textSize="@dimen/text_size_20"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:layout_marginBottom="@dimen/padding_large" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/txt_vui_long_chon_so_sao"
        android:textSize="@dimen/text_size_14"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:layout_marginBottom="@dimen/padding_small" />

    <RatingBar
        android:id="@+id/ratingBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:numStars="5"
        android:stepSize="1.0"
        android:rating="5"
        android:layout_gravity="center"
        android:progressTint="@color/color_FFC107"
        android:progressBackgroundTint="@color/gray_300"
        android:secondaryProgressTint="@color/color_FFC107"
        android:layout_marginBottom="@dimen/padding_large" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_24"
        app:boxStrokeColor="@color/primary"
        app:boxCornerRadiusTopStart="@dimen/padding_small"
        app:boxCornerRadiusTopEnd="@dimen/padding_small"
        app:boxCornerRadiusBottomStart="@dimen/padding_small"
        app:boxCornerRadiusBottomEnd="@dimen/padding_small"
        app:hintEnabled="false">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/edtComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/txt_nhap_nhan_xet_ve_chu_tro_"
            android:minLines="3"
            android:maxLines="5"
            android:gravity="top|start"
            android:inputType="textMultiLine"
            android:padding="@dimen/padding_medium"
            android:background="@null"
            android:textSize="@dimen/text_size_14" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancel"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_cancel"
            android:textColor="@color/text_secondary"
            android:layout_marginEnd="@dimen/padding_small" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_gui_anh_gia"
            app:cornerRadius="@dimen/padding_small" />
    </LinearLayout>

</LinearLayout>
