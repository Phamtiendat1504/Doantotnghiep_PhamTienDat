<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_header_wave"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.22">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="@dimen/padding_large"
            android:paddingEnd="@dimen/padding_large"
            android:paddingTop="@dimen/padding_medium">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/image_size_40"
                android:layout_height="@dimen/image_size_40"
                android:src="@drawable/ic_back"
                app:tint="@color/on_primary"
                android:padding="@dimen/padding_small"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="Quay lại" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/profile_change_password"
                android:textSize="@dimen/dimen_22sp"
                android:textStyle="bold"
                android:textColor="@color/on_primary"
                android:layout_marginStart="@dimen/padding_large" />

        </LinearLayout>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/txt_nhap_mat_khau_cu_va_mat_k"
            android:textSize="@dimen/text_size_12"
            android:textColor="@color/primary_light"
            android:layout_marginStart="@dimen/dimen_72dp"
            android:paddingEnd="@dimen/padding_large"
            android:paddingBottom="@dimen/spacing_24" />

    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/padding_xlarge"
            android:paddingEnd="@dimen/padding_xlarge"
            android:paddingTop="@dimen/spacing_24"
            android:paddingBottom="@dimen/image_size_40">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/padding_large"
                app:cardElevation="@dimen/stroke_2"
                app:cardBackgroundColor="@color/bg_white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_xlarge">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilOldPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/txt_mat_khau_hien_tai"
                        app:endIconMode="password_toggle"
                        app:errorEnabled="true"
                        app:helperTextEnabled="true"
                        app:helperText="Nhập mật khẩu cũ của bạn"
                        style="@style/OutlinedBoxRounded">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtOldPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:drawableStart="@drawable/ic_lock"
                            android:drawableTint="@color/color_888888"
                            android:drawablePadding="@dimen/padding_medium" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/stroke_1"
                        android:background="@color/bg_card"
                        android:layout_marginTop="@dimen/padding_small"
                        android:layout_marginBottom="@dimen/spacing_24" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilNewPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/label_new_password"
                        app:endIconMode="password_toggle"
                        app:errorEnabled="true"
                        app:helperTextEnabled="true"
                        app:helperText="Tối thiểu 12 ký tự, gồm chữ hoa, số và ký tự đặc biệt"
                        app:helperTextTextColor="@color/color_888888"
                        style="@style/OutlinedBoxRounded">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtNewPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:drawableStart="@drawable/ic_lock"
                            android:drawableTint="@color/color_888888"
                            android:drawablePadding="@dimen/padding_medium" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/tilConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/label_reset_confirm_password"
                        android:layout_marginTop="@dimen/padding_large"
                        app:endIconMode="password_toggle"
                        app:errorEnabled="true"
                        app:helperTextEnabled="true"
                        app:helperText="Nhập lại mật khẩu mới"
                        style="@style/OutlinedBoxRounded">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edtConfirmPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:drawableStart="@drawable/ic_lock"
                            android:drawableTint="@color/color_888888"
                            android:drawablePadding="@dimen/padding_medium" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnChangePassword"
                android:layout_width="match_parent"
                android:layout_height="@dimen/bottom_nav_height"
                android:text="@string/txt_xac_nhan_oi_mat_khau"
                android:textSize="@dimen/text_size_16"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:layout_marginTop="@dimen/image_size_28"
                app:backgroundTint="@color/primary"
                app:cornerRadius="@dimen/padding_medium"
                app:iconGravity="textStart"
                app:iconPadding="@dimen/padding_small"
                app:iconTint="@color/bg_white" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_large"
                android:layout_gravity="center"
                android:visibility="gone" />

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>