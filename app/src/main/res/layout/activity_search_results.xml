<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:paddingStart="@dimen/padding_xlarge"
        android:paddingEnd="@dimen/padding_xlarge"
        android:paddingTop="@dimen/dimen_25dp"
        android:paddingBottom="@dimen/padding_large"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="@dimen/dimen_36dp"
            android:layout_height="@dimen/dimen_36dp"
            android:src="@drawable/ic_back"
            app:tint="@color/bg_white"
            android:padding="@dimen/elevation_6" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/txt_ket_qua_tim_kiem"
            android:textSize="@dimen/text_size_20"
            android:paddingTop="@dimen/dimen_25dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginStart="@dimen/dimen_50dp" />

    </LinearLayout>

    <!-- Thanh khu vực + kết quả -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_white"
        android:paddingStart="@dimen/spacing_14"
        android:paddingEnd="@dimen/spacing_14"
        android:paddingTop="@dimen/corner_radius_10"
        android:paddingBottom="@dimen/corner_radius_10"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/search_section_area"
                android:textSize="@dimen/text_size_13"
                android:textColor="@color/text_hint" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvSearchArea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Khu vực"
                android:textSize="@dimen/text_size_13"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:background="@drawable/bg_badge_tenant"
                android:paddingStart="@dimen/padding_medium"
                android:paddingEnd="@dimen/padding_medium"
                android:paddingTop="@dimen/elevation_4"
                android:paddingBottom="@dimen/elevation_4"
                android:layout_marginStart="@dimen/padding_small" />

        </LinearLayout>

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvResultCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_ket_qua_tim_kiem_0_phong"
            android:textSize="@dimen/text_size_13"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="@dimen/elevation_6" />

    </LinearLayout>

    <!-- Thanh sắp xếp -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_white"
        android:paddingStart="@dimen/spacing_14"
        android:paddingEnd="@dimen/spacing_14"
        android:paddingTop="@dimen/stroke_2"
        android:paddingBottom="@dimen/padding_medium"
        android:orientation="vertical">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_sap_xep_ket_qua"
            android:textSize="@dimen/text_size_12"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:letterSpacing="0.04" />

        <FrameLayout
            android:id="@+id/btnSortDropdown"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_44dp"
            android:layout_marginTop="@dimen/padding_small"
            android:background="@drawable/bg_sort_selector"
            android:paddingStart="@dimen/spacing_14"
            android:paddingEnd="@dimen/spacing_14"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvCurrentSort"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/txt_moi_nhat"
                    android:textSize="@dimen/text_size_14"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivSortArrow"
                    android:layout_width="@dimen/spacing_18"
                    android:layout_height="@dimen/spacing_18"
                    android:src="@drawable/ic_chevron_right"
                    android:rotation="90"
                    app:tint="@color/primary" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

    <!-- Hidden Chips for Logic (Optional, or remove from code) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone">
        <com.google.android.material.textview.MaterialTextView android:id="@+id/chipSortPriceAsc" android:layout_width="0dp" android:layout_height="0dp" />
        <com.google.android.material.textview.MaterialTextView android:id="@+id/chipSortPriceDesc" android:layout_width="0dp" android:layout_height="0dp" />
        <com.google.android.material.textview.MaterialTextView android:id="@+id/chipSortNewest" android:layout_width="0dp" android:layout_height="0dp" />
        <com.google.android.material.textview.MaterialTextView android:id="@+id/chipSortOldest" android:layout_width="0dp" android:layout_height="0dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/stroke_1"
        android:background="@color/gray_300" />

    <!-- Nội dung -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/corner_radius_10">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/image_size_40" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/txt_khong_tim_thay_phong_tro_"
                android:textSize="@dimen/text_size_14"
                android:textColor="@color/text_hint"
                android:gravity="center"
                android:padding="@dimen/image_size_40"
                android:visibility="gone" />

            <!-- Danh sách kết quả dạng lưới -->
            <LinearLayout
                android:id="@+id/layoutResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Phân trang -->
            <LinearLayout
                android:id="@+id/layoutPagination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="@dimen/spacing_14"
                android:paddingBottom="@dimen/padding_xlarge" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
