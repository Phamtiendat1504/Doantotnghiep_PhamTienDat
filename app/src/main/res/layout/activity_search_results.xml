<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="25dp"
        android:paddingBottom="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF"
            android:padding="6dp" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Kết quả tìm kiếm"
            android:textSize="20sp"
            android:paddingTop="25dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginStart="50dp" />

    </LinearLayout>

    <!-- Thanh khu vực + kết quả -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_white"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Khu vực"
                android:textSize="13sp"
                android:textColor="@color/text_hint" />

            <TextView
                android:id="@+id/tvSearchArea"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:background="@drawable/bg_badge_tenant"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvResultCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kết quả tìm kiếm: 0 phòng"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginTop="6dp" />

    </LinearLayout>

    <!-- Thanh sắp xếp -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_white"
        android:paddingStart="14dp"
        android:paddingEnd="14dp"
        android:paddingTop="2dp"
        android:paddingBottom="12dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sắp xếp kết quả"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:letterSpacing="0.04" />

        <FrameLayout
            android:id="@+id/btnSortDropdown"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_sort_selector"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCurrentSort"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mới nhất"
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/ivSortArrow"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_chevron_right"
                    android:rotation="90"
                    app:tint="@color/primary" />

            </LinearLayout>

        </FrameLayout>

    </LinearLayout>

    <!-- Hidden Chips for Logic (Optional, or remove from code) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone">
        <TextView android:id="@+id/chipSortPriceAsc" android:layout_width="0dp" android:layout_height="0dp" />
        <TextView android:id="@+id/chipSortPriceDesc" android:layout_width="0dp" android:layout_height="0dp" />
        <TextView android:id="@+id/chipSortNewest" android:layout_width="0dp" android:layout_height="0dp" />
        <TextView android:id="@+id/chipSortOldest" android:layout_width="0dp" android:layout_height="0dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/gray_300" />

    <!-- Nội dung -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="40dp" />

            <TextView
                android:id="@+id/tvEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Không tìm thấy phòng trọ phù hợp"
                android:textSize="14sp"
                android:textColor="@color/text_hint"
                android:gravity="center"
                android:padding="40dp"
                android:visibility="gone" />

            <!-- Danh sách kết quả dạng lưới -->
            <LinearLayout
                android:id="@+id/layoutResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

            <!-- Phân trang -->
            <LinearLayout
                android:id="@+id/layoutPagination"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingTop="14dp"
                android:paddingBottom="20dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
