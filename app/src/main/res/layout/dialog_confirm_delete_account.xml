<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/spacing_24"
    android:paddingTop="@dimen/padding_large"
    android:paddingEnd="@dimen/spacing_24"
    android:paddingBottom="@dimen/padding_small"
    android:background="@drawable/bg_dialog">

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Xác minh mật khẩu"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_16"
        android:textStyle="bold" />

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_small"
        android:text="Để đảm bảo an toàn bảo mật, vui lòng nhập mật khẩu hiện tại để xác nhận yêu cầu hủy tài khoản."
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_size_13" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilConfirmPassword"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_large"
        app:boxStrokeColor="@color/primary"
        app:hintTextColor="@color/primary"
        app:passwordToggleEnabled="true"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etConfirmPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nhập mật khẩu của bạn"
            android:inputType="textPassword"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_15" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_large"
        android:orientation="horizontal">
        
        <ImageView
            android:layout_width="@dimen/padding_large"
            android:layout_height="@dimen/padding_large"
            android:src="@drawable/ic_info"
            app:tint="@color/text_hint"
            android:layout_gravity="top"
            android:layout_marginTop="@dimen/stroke_2" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_small"
            android:text="Thao tác hủy tài khoản không thể khôi phục. Mọi dữ liệu liên quan sẽ bị xóa vĩnh viễn khỏi backend."
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_12"
            android:lineSpacingExtra="@dimen/stroke_2" />
    </LinearLayout>

</LinearLayout>
