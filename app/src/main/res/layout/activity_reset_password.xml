<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:background="@color/primary_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_24"
        android:gravity="center_horizontal">

        <!-- Tiêu đề -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/title_reset_password"
            android:textSize="@dimen/text_size_28"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginTop="@dimen/image_size_100" />

        <!-- Mô tả -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/desc_reset_password"
            android:textSize="@dimen/text_size_14"
            android:textColor="@color/primary"
            android:textAlignment="center"
            android:layout_marginTop="@dimen/padding_small" />

        <!-- Card chứa form -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/image_size_28"
            app:cardCornerRadius="@dimen/padding_xlarge"
            app:cardElevation="@dimen/elevation_6"
            app:cardBackgroundColor="@color/bg_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_xlarge">

                <!-- Label Mật khẩu mới -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_new_password"
                    android:textSize="@dimen/text_size_14"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="@dimen/elevation_6" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilNewPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:endIconMode="password_toggle"
                    app:errorEnabled="true"
                    style="@style/OutlinedBoxRounded">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtNewPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:hint="@string/hint_new_password"
                        android:drawableStart="@drawable/ic_lock"
                        android:drawableTint="@color/color_888888"
                        android:drawablePadding="@dimen/padding_medium" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Label Xác nhận mật khẩu -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_reset_confirm_password"
                    android:textSize="@dimen/text_size_14"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="@dimen/elevation_4"
                    android:layout_marginBottom="@dimen/elevation_6" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilConfirmPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:endIconMode="password_toggle"
                    app:errorEnabled="true"
                    style="@style/OutlinedBoxRounded">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtConfirmPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:hint="@string/hint_reset_confirm_password"
                        android:drawableStart="@drawable/ic_lock"
                        android:drawableTint="@color/color_888888"
                        android:drawablePadding="@dimen/padding_medium" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Nút Đổi mật khẩu -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnResetPassword"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_52dp"
                    android:text="@string/btn_change_password"
                    android:textSize="@dimen/text_size_18"
                    android:textAllCaps="false"
                    android:layout_marginTop="@dimen/padding_large"
                    app:backgroundTint="@color/bottom_nav_selected"
                    app:cornerRadius="@dimen/padding_medium" />

                <!-- Thanh loading -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_large"
                    android:layout_gravity="center"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
