<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="@dimen/spacing_24"
    android:paddingTop="@dimen/padding_large"
    android:paddingEnd="@dimen/spacing_24"
    android:paddingBottom="@dimen/padding_small"
    android:background="@drawable/bg_dialog">

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/txt_loai_van_e_can_ho_tro"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_14"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/dimen_52dp"
        android:layout_marginTop="@dimen/padding_small"
        android:background="@drawable/bg_spinner_outline"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/elevation_4"
        android:paddingEnd="@dimen/elevation_4">

        <Spinner
            android:id="@+id/spSupportCategory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:entries="@array/support_categories" />
    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_large"
        app:boxStrokeColor="@color/primary"
        app:hintTextColor="@color/primary"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSupportTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/txt_tieu_e_yeu_cau"
            android:inputType="textCapSentences"
            android:maxLines="2"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_15" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_large"
        app:boxStrokeColor="@color/primary"
        app:hintTextColor="@color/primary"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSupportContent"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_140dp"
            android:gravity="top"
            android:hint="@string/txt_mo_ta_chi_tiet_van_e_ban_"
            android:inputType="textMultiLine|textCapSentences"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_15" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/padding_large"
        android:orientation="horizontal">
        
        <ImageView
            android:layout_width="@dimen/padding_large"
            android:layout_height="@dimen/padding_large"
            android:src="@drawable/ic_info"
            app:tint="@color/text_hint"
            android:layout_gravity="top"
            android:layout_marginTop="@dimen/stroke_2" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_small"
            android:text="@string/txt_sau_khi_tao_yeu_cau_ban_c"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_12"
            android:lineSpacingExtra="@dimen/stroke_2" />
    </LinearLayout>

</LinearLayout>
