<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_white"
        app:elevation="4dp">

        <!-- Hero header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_support_hero"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/padding_small"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <ImageView
                android:id="@+id/btnSupportBack"
                android:layout_width="@dimen/dimen_44dp"
                android:layout_height="@dimen/dimen_44dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true"
                android:padding="@dimen/corner_radius_10"
                android:src="@drawable/ic_back"
                app:tint="@color/white" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/padding_small"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_trung_tam_ho_tro"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_size_20"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Luôn sẵn sàng hỗ trợ bạn 24/7"
                    android:textColor="#B3FFFFFF"
                    android:textSize="@dimen/text_size_13" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_hero_icon_circle">

                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_shield_check"
                    app:tint="@color/white" />
            </FrameLayout>
        </LinearLayout>

        <!-- Filter strip -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/bg_white"
            android:clipToPadding="false"
            android:paddingStart="@dimen/padding_medium"
            android:paddingTop="@dimen/padding_medium"
            android:paddingEnd="@dimen/padding_medium"
            android:paddingBottom="@dimen/padding_medium"
            android:scrollbars="none">

            <RadioGroup
                android:id="@+id/rgTicketFilters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/rbAllTickets"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dimen_36dp"
                    android:layout_marginEnd="@dimen/padding_small"
                    android:background="@drawable/selector_ticket_filter_bg"
                    android:button="@null"
                    android:checked="true"
                    android:elevation="@dimen/stroke_1"
                    android:gravity="center"
                    android:paddingStart="@dimen/padding_large"
                    android:paddingEnd="@dimen/padding_large"
                    android:text="@string/txt_tat_ca"
                    android:textColor="@color/selector_ticket_filter_text"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbNewTickets"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dimen_36dp"
                    android:layout_marginEnd="@dimen/padding_small"
                    android:background="@drawable/selector_ticket_filter_bg"
                    android:button="@null"
                    android:elevation="@dimen/stroke_1"
                    android:gravity="center"
                    android:paddingStart="@dimen/padding_large"
                    android:paddingEnd="@dimen/padding_large"
                    android:text="@string/txt_moi"
                    android:textColor="@color/selector_ticket_filter_text"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbProgressTickets"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dimen_36dp"
                    android:layout_marginEnd="@dimen/padding_small"
                    android:background="@drawable/selector_ticket_filter_bg"
                    android:button="@null"
                    android:elevation="@dimen/stroke_1"
                    android:gravity="center"
                    android:paddingStart="@dimen/padding_large"
                    android:paddingEnd="@dimen/padding_large"
                    android:text="@string/post_step_2_badge"
                    android:textColor="@color/selector_ticket_filter_text"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbResolvedTickets"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dimen_36dp"
                    android:layout_marginEnd="@dimen/padding_small"
                    android:background="@drawable/selector_ticket_filter_bg"
                    android:button="@null"
                    android:elevation="@dimen/stroke_1"
                    android:gravity="center"
                    android:paddingStart="@dimen/padding_large"
                    android:paddingEnd="@dimen/padding_large"
                    android:text="@string/txt_a_xu_ly"
                    android:textColor="@color/selector_ticket_filter_text"
                    android:textStyle="bold" />

                <RadioButton
                    android:id="@+id/rbClosedTickets"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/dimen_36dp"
                    android:background="@drawable/selector_ticket_filter_bg"
                    android:button="@null"
                    android:elevation="@dimen/stroke_1"
                    android:gravity="center"
                    android:paddingStart="@dimen/padding_large"
                    android:paddingEnd="@dimen/padding_large"
                    android:text="@string/txt_a_ong"
                    android:textColor="@color/selector_ticket_filter_text"
                    android:textStyle="bold" />
            </RadioGroup>
        </HorizontalScrollView>
    </com.google.android.material.appbar.AppBarLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvSupportTickets"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="@dimen/padding_small"
            android:paddingBottom="@dimen/dimen_96dp" />

        <LinearLayout
            android:id="@+id/layoutTicketEmpty"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/image_size_32"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:background="@drawable/bg_icon_circle_light_blue">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_info"
                    app:tint="@color/primary" />
            </FrameLayout>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_large"
                android:gravity="center"
                android:text="@string/txt_ban_chua_co_yeu_cau_ho_tr"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_small"
                android:gravity="center"
                android:text="@string/txt_bam_nut_dau_cong_ben_duoi"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_size_14" />
        </LinearLayout>
    </FrameLayout>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btnNewTicket"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_24"
        android:backgroundTint="@color/primary"
        android:text="Tạo yêu cầu"
        android:textColor="@color/white"
        app:elevation="@dimen/elevation_6"
        app:icon="@drawable/ic_add"
        app:iconTint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
