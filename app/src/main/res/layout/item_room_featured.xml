<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/dimen_240dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="@dimen/padding_large"
    android:layout_marginBottom="@dimen/padding_small"
    android:layout_marginTop="@dimen/elevation_4"
    android:layout_marginStart="@dimen/elevation_4"
    app:cardCornerRadius="@dimen/padding_xlarge"
    app:cardElevation="@dimen/elevation_6"
    app:cardBackgroundColor="@color/bg_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Ảnh + Overlay gradient -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_160dp">

            <ImageView
                android:id="@+id/imgRoom"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/gray_200" />

            <!-- Gradient phủ bên dưới ảnh - Tinh tế hơn -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/image_size_90"
                android:layout_gravity="bottom"
                android:background="@drawable/bg_gradient_bottom" />

            <!-- Badge "Nổi bật" góc trên trái - Gold Gradient -->
            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|start"
                android:layout_margin="@dimen/padding_medium"
                android:background="@drawable/bg_featured_badge"
                android:paddingStart="@dimen/corner_radius_10"
                android:paddingEnd="@dimen/corner_radius_10"
                android:paddingTop="@dimen/elevation_4"
                android:paddingBottom="@dimen/elevation_4"
                android:text="@string/txt_noi_bat"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_10"
                android:letterSpacing="0.05"
                android:fontFamily="sans-serif-black" />

            <!-- Giá hiển thị trên gradient - Typography mạnh mẽ -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|start"
                android:layout_marginStart="@dimen/spacing_14"
                android:layout_marginBottom="@dimen/padding_medium"
                android:text="@string/txt_0_th"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_18"
                android:fontFamily="sans-serif-black"
                android:shadowColor="@color/color_80000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2" />

        </FrameLayout>

        <!-- Thông tin bên dưới ảnh -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/padding_large"
            android:paddingEnd="@dimen/padding_large"
            android:paddingTop="@dimen/spacing_14"
            android:paddingBottom="@dimen/padding_large">

            <!-- Tiêu đề - Editorial Style -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/txt_tieu_e_phong"
                android:textSize="@dimen/text_size_14"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingExtra="@dimen/elevation_3" />

            <!-- Địa chỉ - Minimalist -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/corner_radius_10">

                <ImageView
                    android:layout_width="@dimen/spacing_14"
                    android:layout_height="@dimen/spacing_14"
                    android:src="@drawable/ic_location"
                    app:tint="@color/primary"
                    android:layout_marginEnd="@dimen/elevation_6" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_quan_thanh_pho"
                    android:textSize="@dimen/text_size_12"
                    android:textColor="@color/text_secondary"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>