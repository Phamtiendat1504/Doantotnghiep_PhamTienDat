<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:background="@color/primary_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_24"
        android:gravity="center_horizontal">

        <!-- Mũi tên quay lại -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="@dimen/image_size_40"
            android:layout_height="@dimen/image_size_40"
            android:layout_gravity="start"
            android:layout_marginTop="@dimen/padding_small"
            android:src="@drawable/ic_back"
            android:contentDescription="Quay lại"
            android:padding="@dimen/elevation_4"
            android:background="?attr/selectableItemBackgroundBorderless" />

        <!-- Tiêu đề -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_quen_mat_khau"
            android:textSize="@dimen/dimen_26sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginTop="@dimen/padding_large" />

        <!-- Mô tả -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/txt_nhap_email_va_so_ien_thoa"
            android:textSize="@dimen/text_size_14"
            android:textColor="@color/text_secondary"
            android:textAlignment="center"
            android:lineSpacingExtra="@dimen/elevation_3"
            android:layout_marginTop="@dimen/corner_radius_10"
            android:layout_marginStart="@dimen/padding_small"
            android:layout_marginEnd="@dimen/padding_small" />

        <!-- Card chứa form -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/image_size_28"
            app:cardCornerRadius="@dimen/padding_xlarge"
            app:cardElevation="@dimen/padding_small"
            app:cardBackgroundColor="@color/bg_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_24">

                <!-- Label Email -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_ia_chi_email"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="@dimen/elevation_6" />

                <!-- Ô nhập Email -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:errorEnabled="true"
                    style="@style/OutlinedBoxRounded">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtEmail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textEmailAddress"
                        android:hint="@string/txt_example_gmail_com"
                        android:drawableStart="@drawable/ic_email"
                        android:drawableTint="@color/color_888888"
                        android:drawablePadding="@dimen/padding_medium" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Label Số điện thoại -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_so_ien_thoai_1"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginTop="@dimen/padding_large"
                    android:layout_marginBottom="@dimen/elevation_6" />

                <!-- Ô nhập Số điện thoại -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:errorEnabled="true"
                    style="@style/OutlinedBoxRounded">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edtPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="phone"
                        android:hint="@string/txt_0xxxxxxxxx"
                        android:drawableStart="@drawable/ic_phone"
                        android:drawableTint="@color/color_888888"
                        android:drawablePadding="@dimen/padding_medium" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- Nút Gửi yêu cầu -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSendEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/dimen_52dp"
                    android:text="@string/txt_gui_lien_ket_email"
                    android:textSize="@dimen/dimen_15dp"
                    android:textAllCaps="false"
                    android:layout_marginTop="@dimen/padding_xlarge"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="@dimen/padding_medium" />

                <!-- Thanh loading -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/padding_large"
                    android:layout_gravity="center"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Thông báo khi gửi thành công (mặc định ẩn) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSuccess"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_xlarge"
            android:visibility="gone"
            app:cardCornerRadius="@dimen/padding_large"
            app:cardElevation="@dimen/elevation_4"
            app:cardBackgroundColor="@color/success_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/padding_large"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="@dimen/image_size_28"
                    android:layout_height="@dimen/image_size_28"
                    android:src="@drawable/ic_check_circle"
                    app:tint="@color/color_388E3C"
                    android:contentDescription="Thành công" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvSuccessMessage"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/txt_email_at_lai_mat_khau_a_u"
                    android:textSize="@dimen/text_size_13"
                    android:textColor="@color/color_1B5E20"
                    android:lineSpacingExtra="@dimen/elevation_3"
                    android:layout_marginStart="@dimen/padding_medium" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Dòng quay lại đăng nhập -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/image_size_28"
            android:layout_marginBottom="@dimen/spacing_24">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_a_nho_mat_khau"
                android:textSize="@dimen/text_size_14"
                android:textColor="@color/text_secondary" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvGoToLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/txt_ang_nhap_ngay"
                android:textSize="@dimen/text_size_14"
                android:textColor="@color/primary"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>