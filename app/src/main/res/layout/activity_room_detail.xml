<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_F4F6F8">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <FrameLayout
            android:id="@+id/btnBackContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingStart="@dimen/padding_medium"
            android:paddingTop="@dimen/padding_small"
            android:paddingEnd="@dimen/padding_medium"
            android:paddingBottom="@dimen/padding_small">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/image_size_40"
                android:layout_height="@dimen/image_size_40"
                app:cardCornerRadius="@dimen/padding_xlarge"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/color_F8FAFC">

                <ImageView
                    android:id="@+id/btnBack"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:clickable="true"
                    android:focusable="true"
                    android:padding="@dimen/corner_radius_10"
                    android:src="@drawable/ic_back"
                    app:tint="@color/color_1F2937" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_300dp"
            app:layout_scrollFlags="scroll|exitUntilCollapsed">

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPagerImages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_collapseMode="parallax" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvImageCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="@dimen/padding_large"
                android:background="@drawable/bg_badge_tenant"
                android:paddingStart="@dimen/corner_radius_10"
                android:paddingTop="@dimen/elevation_4"
                android:paddingEnd="@dimen/corner_radius_10"
                android:paddingBottom="@dimen/elevation_4"
                android:text="@string/txt_1_1"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_11" />
        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/dimen_104dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dimen_minus_20dp"
            android:orientation="vertical"
            android:paddingStart="@dimen/padding_large"
            android:paddingEnd="@dimen/padding_large"
            android:paddingBottom="@dimen/padding_large">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/padding_medium"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/spacing_18"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_18">

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvRoomNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_tenant"
                        android:paddingStart="@dimen/corner_radius_10"
                        android:paddingTop="@dimen/elevation_4"
                        android:paddingEnd="@dimen/corner_radius_10"
                        android:paddingBottom="@dimen/elevation_4"
                        android:text="@string/txt_phong_01"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_size_11"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/corner_radius_10"
                        android:lineSpacingExtra="@dimen/stroke_2"
                        android:textColor="@color/color_111827"
                        android:textSize="@dimen/dimen_22sp"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/elevation_6"
                        android:textColor="@color/color_6B7280"
                        android:textSize="@dimen/text_size_14" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/stroke_1"
                        android:layout_marginTop="@dimen/spacing_14"
                        android:layout_marginBottom="@dimen/spacing_14"
                        android:background="@color/color_E5E7EB" />

                    <androidx.gridlayout.widget.GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:columnCount="3">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_spec_item"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/corner_radius_10"
                            app:layout_columnWeight="1">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvSpecArea"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_m"
                                android:textColor="@color/color_111827"
                                android:textSize="@dimen/text_size_14"
                                android:textStyle="bold" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/stroke_2"
                                android:text="@string/room_area"
                                android:textColor="@color/color_6B7280"
                                android:textSize="@dimen/text_size_11" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/padding_small"
                            android:background="@drawable/bg_spec_item"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/corner_radius_10"
                            app:layout_columnWeight="1">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvSpecPeople"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/txt_nguoi"
                                android:textColor="@color/color_111827"
                                android:textSize="@dimen/text_size_14"
                                android:textStyle="bold" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/stroke_2"
                                android:text="@string/txt_suc_chua"
                                android:textColor="@color/color_6B7280"
                                android:textSize="@dimen/text_size_11" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/padding_small"
                            android:background="@drawable/bg_spec_item"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/corner_radius_10"
                            app:layout_columnWeight="1">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvSpecType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/string_t5vcph"
                                android:textColor="@color/color_111827"
                                android:textSize="@dimen/text_size_14"
                                android:textStyle="bold" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/stroke_2"
                                android:text="@string/txt_loai_phong"
                                android:textColor="@color/color_6B7280"
                                android:textSize="@dimen/text_size_11" />
                        </LinearLayout>
                    </androidx.gridlayout.widget.GridLayout>

                    <LinearLayout
                        android:id="@+id/layoutRoomInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_14"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardReviews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/padding_medium"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/spacing_18"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_18">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvReviewsTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/txt_anh_gia_chu_tro"
                            android:textColor="@color/color_111827"
                            android:textSize="@dimen/text_size_18"
                            android:textStyle="bold" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddReview"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/image_size_40"
                            android:minHeight="0dp"
                            android:text="@string/txt_anh_gia"
                            android:textAllCaps="false"
                            android:textSize="@dimen/text_size_13"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="@dimen/padding_medium" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutReviews"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_medium"
                        android:orientation="vertical" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/padding_medium"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/spacing_18"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_18">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_tien_ich_va_dich_vu"
                        android:textColor="@color/color_111827"
                        android:textSize="@dimen/text_size_18"
                        android:textStyle="bold" />

                    <androidx.gridlayout.widget.GridLayout
                        android:id="@+id/gridAmenities"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_14"
                        app:columnCount="2" />

                    <LinearLayout
                        android:id="@+id/layoutAmenities"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/corner_radius_10"
                        android:orientation="vertical" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/padding_medium"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/spacing_18"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_18">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_mo_ta_chi_tiet"
                        android:textColor="@color/color_111827"
                        android:textSize="@dimen/text_size_18"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_medium"
                        android:ellipsize="end"
                        android:lineSpacingExtra="@dimen/dimen_5dp"
                        android:maxLines="4"
                        android:textColor="@color/color_374151"
                        android:textSize="@dimen/text_size_15" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/btnReadMore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_small"
                        android:text="@string/txt_xem_them"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_size_14"
                        android:textStyle="bold"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBookedSlots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/padding_medium"
                app:cardBackgroundColor="@color/color_FFF8EE"
                app:cardCornerRadius="@dimen/spacing_18"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/padding_large">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvBookedCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_lich_ban_0"
                            android:textColor="@color/color_C2410C"
                            android:textSize="@dimen/text_size_15"
                            android:textStyle="bold" />

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/btnViewAllSlots"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="@string/txt_xem_chi_tiet"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_size_13"
                            android:textStyle="bold" />
                    </RelativeLayout>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_medium"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/layoutBookedSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/padding_medium"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/spacing_18"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_18">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_nguoi_ang_tin"
                        android:textColor="@color/color_111827"
                        android:textSize="@dimen/text_size_18"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/layoutOwnerInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_medium"
                        android:background="@drawable/bg_spec_item"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_medium" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="@dimen/spacing_18"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_18">

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_vi_tri_phong"
                        android:textColor="@color/color_111827"
                        android:textSize="@dimen/text_size_18"
                        android:textStyle="bold" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvMapAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/corner_radius_10"
                        android:textColor="@color/color_6B7280"
                        android:textSize="@dimen/text_size_14" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dimen_220dp"
                        android:layout_marginTop="@dimen/padding_medium"
                        app:cardCornerRadius="@dimen/spacing_14"
                        app:cardElevation="0dp">

                        <androidx.fragment.app.FragmentContainerView
                            android:id="@+id/mapContainer"
                            android:name="com.google.android.gms.maps.SupportMapFragment"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnOpenMaps"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/dimen_52dp"
                        android:layout_marginTop="@dimen/padding_medium"
                        android:text="@string/txt_mo_trong_google_maps"
                        android:textAllCaps="false"
                        app:cornerRadius="@dimen/padding_medium"
                        app:strokeColor="@color/color_D1D5DB" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardBackgroundColor="@color/white"
        app:cardElevation="@dimen/spacing_18">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="@dimen/padding_large"
            android:paddingTop="@dimen/corner_radius_10"
            android:paddingEnd="@dimen/padding_large"
            android:paddingBottom="@dimen/corner_radius_10">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvPrice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_0"
                    android:textColor="@color/color_DC2626"
                    android:textSize="@dimen/text_size_18"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_gia_moi_thang"
                    android:textColor="@color/color_9CA3AF"
                    android:textSize="@dimen/text_size_11" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSavePost"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="@dimen/dimen_46dp"
                android:layout_height="@dimen/dimen_46dp"
                android:layout_marginEnd="@dimen/corner_radius_10"
                android:padding="0dp"
                app:icon="@drawable/ic_bookmark"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="@dimen/spacing_24"
                app:iconTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBooking"
                android:layout_width="@dimen/dimen_162dp"
                android:layout_height="@dimen/dimen_50dp"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                android:text="@string/txt_at_lich_ngay"
                android:textAllCaps="false"
                android:textSize="@dimen/text_size_15"
                android:textStyle="bold"
                app:backgroundTint="@color/primary"
                app:cornerRadius="@dimen/padding_medium" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
