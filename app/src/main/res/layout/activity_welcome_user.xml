<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash_gradient">

    <View
        android:id="@+id/decorTopRight"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginTop="-96dp"
        android:layout_marginEnd="-72dp"
        android:background="@drawable/bg_circle_white_alpha"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/decorBottomLeft"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:layout_marginStart="-64dp"
        android:layout_marginBottom="-58dp"
        android:background="@drawable/bg_circle_white_alpha"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <View
        android:id="@+id/pulseDot1"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:background="@drawable/bg_dot_white"
        app:layout_constraintBottom_toTopOf="@id/welcomeCard"
        app:layout_constraintEnd_toEndOf="@id/welcomeCard"
        app:layout_constraintHorizontal_bias="0.92"
        app:layout_constraintTop_toTopOf="@id/welcomeCard"
        app:layout_constraintVertical_bias="-0.14" />

    <View
        android:id="@+id/pulseDot2"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:background="@drawable/bg_dot_white"
        app:layout_constraintBottom_toBottomOf="@id/welcomeCard"
        app:layout_constraintEnd_toStartOf="@id/welcomeCard"
        app:layout_constraintHorizontal_bias="-0.06"
        app:layout_constraintStart_toStartOf="@id/welcomeCard"
        app:layout_constraintTop_toTopOf="@id/welcomeCard"
        app:layout_constraintVertical_bias="0.8" />

    <LinearLayout
        android:id="@+id/welcomeCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/bg_welcome_card"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.55">

        <FrameLayout
            android:id="@+id/logoPlate"
            android:layout_width="108dp"
            android:layout_height="108dp"
            android:background="@drawable/bg_splash_logo_plate"
            android:padding="20dp">

            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="Logo"
                android:src="@drawable/ic_logo" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvWelcomeLine"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Chào mừng đến với Tìm Trọ 24/7"
            android:textColor="#EAF3FF"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvWelcomeUserName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="Bạn"
            android:textColor="@color/white"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWelcomeSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Đặt hẹn lịch phòng và quản lý bài đăng trên chính điện thoại của bạn"
            android:textColor="#DAE9FF"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartApp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:text="Bắt đầu khám phá"
            android:textAllCaps="false"
            android:textColor="@color/on_primary"
            android:textSize="16sp"
            app:backgroundTint="@color/primary"
            app:cornerRadius="14dp"
            app:icon="@drawable/ic_check_circle"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:iconTint="@android:color/white" />

        <TextView
            android:id="@+id/tvAutoHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Tự động chuyển sau 5 giây..."
            android:textColor="#CFE2FF"
            android:textSize="12sp" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>

