<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="@dimen/spacing_24">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary"
            android:paddingStart="@dimen/padding_xlarge"
            android:paddingEnd="@dimen/padding_xlarge"
            android:paddingTop="@dimen/padding_large"
            android:paddingBottom="@dimen/padding_xlarge"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="@dimen/dimen_36dp"
                android:layout_height="@dimen/dimen_36dp"
                android:src="@drawable/ic_back"
                app:tint="@color/bg_white"
                android:padding="@dimen/elevation_6" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/txt_mo_khoa_quyen_ang_bai"
                android:textSize="@dimen/text_size_20"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginStart="@dimen/padding_medium" />

        </LinearLayout>

        <!-- Thông tin cá nhân -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_14"
            app:cardCornerRadius="@dimen/spacing_14"
            app:cardElevation="@dimen/elevation_3"
            app:cardBackgroundColor="@color/bg_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_large">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_14">

                    <View
                        android:layout_width="@dimen/elevation_4"
                        android:layout_height="@dimen/padding_xlarge"
                        android:background="@color/primary" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_thong_tin_ca_nhan"
                        android:textSize="@dimen/text_size_15"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="@dimen/padding_small" />

                </LinearLayout>

                <!-- Họ và tên -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_ho_va_ten"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="@dimen/elevation_4" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtFullName"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_46dp"
                    android:hint="@string/txt_ho_va_ten_theo_cccd"
                    android:textSize="@dimen/text_size_14"
                    android:paddingStart="@dimen/padding_medium"
                    android:background="@drawable/bg_edit_post"
                    android:inputType="textPersonName"
                    android:enabled="false"
                    android:textColor="@color/text_primary"
                    android:alpha="0.85"
                    android:layout_marginBottom="@dimen/padding_medium" />

                <!-- Số CCCD -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_so_cccd_cmnd"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="@dimen/elevation_4" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtCccdNumber"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_46dp"
                    android:hint="@string/txt_nhap_so_cccd_12_so"
                    android:textSize="@dimen/text_size_14"
                    android:paddingStart="@dimen/padding_medium"
                    android:background="@drawable/bg_edit_post"
                    android:inputType="number"
                    android:maxLength="12"
                    android:layout_marginBottom="@dimen/padding_medium" />

                <!-- Số điện thoại -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_so_ien_thoai"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="@dimen/elevation_4" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtPhone"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_46dp"
                    android:hint="@string/txt_so_ien_thoai_lien_he"
                    android:textSize="@dimen/text_size_14"
                    android:paddingStart="@dimen/padding_medium"
                    android:background="@drawable/bg_edit_post"
                    android:inputType="phone"
                    android:enabled="false"
                    android:textColor="@color/text_primary"
                    android:alpha="0.85"
                    android:layout_marginBottom="@dimen/padding_medium" />

                <!-- Email (tự động lấy từ tài khoản, không đổi được) -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_email_ang_ky"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="@dimen/elevation_4" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtEmail"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_46dp"
                    android:hint="@string/txt_email_tai_khoan_cua_ban"
                    android:textSize="@dimen/text_size_14"
                    android:paddingStart="@dimen/padding_medium"
                    android:background="@drawable/bg_edit_post"
                    android:inputType="textEmailAddress"
                    android:enabled="false"
                    android:textColor="@color/text_primary"
                    android:alpha="0.85"
                    android:layout_marginBottom="@dimen/padding_medium" />

                <!-- Địa chỉ thường trú -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_ia_chi_thuong_tru"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="@dimen/elevation_4" />

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtAddress"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_46dp"
                    android:hint="@string/txt_ia_chi_thuong_tru_tu_ien_"
                    android:textSize="@dimen/text_size_14"
                    android:paddingStart="@dimen/padding_medium"
                    android:background="@drawable/bg_edit_post"
                    android:inputType="textPostalAddress" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Ảnh CCCD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_14"
            android:layout_marginEnd="@dimen/spacing_14"
            android:layout_marginBottom="@dimen/spacing_14"
            app:cardCornerRadius="@dimen/spacing_14"
            app:cardElevation="@dimen/elevation_3"
            app:cardBackgroundColor="@color/bg_white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_large">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/spacing_14">

                    <View
                        android:layout_width="@dimen/elevation_4"
                        android:layout_height="@dimen/padding_xlarge"
                        android:background="@color/secondary" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_anh_cccd_cmnd"
                        android:textSize="@dimen/text_size_15"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="@dimen/padding_small" />

                </LinearLayout>

                <!-- Mặt trước -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_mat_truoc_cccd"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="@dimen/padding_small" />

                <FrameLayout
                    android:id="@+id/frameFront"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_180dp"
                    android:background="@drawable/bg_edit_post"
                    android:layout_marginBottom="@dimen/padding_large">

                    <LinearLayout
                        android:id="@+id/layoutFrontPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="@dimen/image_size_40"
                            android:layout_height="@dimen/image_size_40"
                            android:src="@drawable/ic_camera"
                            app:tint="@color/text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_bam_e_chup_anh_mat_truoc"
                            android:textSize="@dimen/text_size_13"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="@dimen/padding_small" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/imgFront"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                </FrameLayout>

                <!-- Mặt sau -->
                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_mat_sau_cccd"
                    android:textSize="@dimen/text_size_13"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="@dimen/padding_small" />

                <FrameLayout
                    android:id="@+id/frameBack"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dimen_180dp"
                    android:background="@drawable/bg_edit_post"
                    android:layout_marginBottom="@dimen/padding_small">

                    <LinearLayout
                        android:id="@+id/layoutBackPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="@dimen/image_size_40"
                            android:layout_height="@dimen/image_size_40"
                            android:src="@drawable/ic_camera"
                            app:tint="@color/text_hint" />

                        <com.google.android.material.textview.MaterialTextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_bam_e_chup_anh_mat_sau"
                            android:textSize="@dimen/text_size_13"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="@dimen/padding_small" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/imgBack"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                </FrameLayout>

                <!-- Thông báo bảo mật -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/corner_radius_10"
                    android:background="@drawable/bg_amenity_row"
                    android:layout_marginTop="@dimen/padding_medium">

                    <ImageView
                        android:layout_width="@dimen/spacing_18"
                        android:layout_height="@dimen/spacing_18"
                        android:src="@drawable/ic_lock"
                        app:tint="@color/success" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_chung_toi_cam_ket_bao_mat"
                        android:textSize="@dimen/text_size_11"
                        android:textColor="@color/success"
                        android:layout_marginStart="@dimen/corner_radius_10"
                        android:textStyle="italic" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Quy định & Cam kết -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_14"
            android:layout_marginEnd="@dimen/spacing_14"
            android:layout_marginBottom="@dimen/padding_large"
            app:cardCornerRadius="@dimen/spacing_14"
            app:cardElevation="@dimen/stroke_2">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_large"
                android:background="@color/color_F8F9FA">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="@dimen/corner_radius_10">

                    <ImageView
                        android:layout_width="@dimen/padding_xlarge"
                        android:layout_height="@dimen/padding_xlarge"
                        android:src="@drawable/ic_info"
                        app:tint="@color/primary" />

                    <com.google.android.material.textview.MaterialTextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_quy_inh_amp_trach_nhiem_c"
                        android:textSize="@dimen/text_size_15"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginStart="@dimen/padding_small" />
                </LinearLayout>

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_1_cung_cap_thong_tin_phon"
                    android:textSize="@dimen/text_size_13"
                    android:textColor="@color/color_555555"
                    android:lineSpacingExtra="@dimen/elevation_4" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Điều khoản cam kết -->
        <CheckBox
            android:id="@+id/cbCommit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/padding_large"
            android:layout_marginEnd="@dimen/padding_large"
            android:layout_marginBottom="@dimen/padding_large"
            android:text="@string/txt_toi_a_oc_va_cam_oan_tuan_"
            android:textSize="@dimen/text_size_13"
            android:textColor="@color/text_primary"
            android:buttonTint="@color/bottom_nav_selected"
            android:paddingStart="@dimen/padding_small" />

        <!-- Nút gửi -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitVerify"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_52dp"
            android:text="@string/txt_gui_yeu_cau_xac_minh"
            android:textSize="@dimen/text_size_16"
            android:textAllCaps="false"
            android:layout_marginStart="@dimen/spacing_14"
            android:layout_marginEnd="@dimen/spacing_14"
            app:backgroundTint="@color/bottom_nav_selected"
            app:cornerRadius="@dimen/spacing_14" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/padding_medium"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
