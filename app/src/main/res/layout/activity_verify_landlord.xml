<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="16dp"
            android:paddingBottom="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/ic_back"
                android:tint="#FFFFFF"
                android:padding="6dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Mở khóa quyền đăng bài"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginStart="12dp" />

        </LinearLayout>

        <!-- Thông tin cá nhân -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin cá nhân"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- Họ và tên -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Họ và tên *"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/edtFullName"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:hint="Họ và tên theo CCCD"
                    android:textSize="14sp"
                    android:paddingStart="12dp"
                    android:background="@drawable/bg_edit_post"
                    android:inputType="textPersonName"
                    android:enabled="true"
                    android:layout_marginBottom="12dp" />

                <!-- Số CCCD -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số CCCD/CMND *"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/edtCccdNumber"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:hint="Nhập số CCCD (12 số)"
                    android:textSize="14sp"
                    android:paddingStart="12dp"
                    android:background="@drawable/bg_edit_post"
                    android:inputType="number"
                    android:maxLength="12"
                    android:layout_marginBottom="12dp" />

                <!-- Số điện thoại -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số điện thoại *"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/edtPhone"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:hint="Số điện thoại liên hệ"
                    android:textSize="14sp"
                    android:paddingStart="12dp"
                    android:background="@drawable/bg_edit_post"
                    android:inputType="phone"
                    android:enabled="true"
                    android:layout_marginBottom="12dp" />

                <!-- Địa chỉ thường trú -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Địa chỉ thường trú *"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="4dp" />

                <EditText
                    android:id="@+id/edtAddress"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:hint="Nhập địa chỉ thường trú"
                    android:textSize="14sp"
                    android:paddingStart="12dp"
                    android:background="@drawable/bg_edit_post"
                    android:inputType="textPostalAddress" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Ảnh CCCD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="14dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="3dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="20dp"
                        android:background="@color/secondary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ảnh CCCD/CMND"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginStart="8dp" />

                </LinearLayout>

                <!-- Mặt trước -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mặt trước CCCD *"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <FrameLayout
                    android:id="@+id/frameFront"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="@drawable/bg_edit_post"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:id="@+id/layoutFrontPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_camera"
                            android:tint="#999999" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bấm để chọn ảnh mặt trước"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/imgFront"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                </FrameLayout>

                <!-- Mặt sau -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mặt sau CCCD *"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginBottom="8dp" />

                <FrameLayout
                    android:id="@+id/frameBack"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:background="@drawable/bg_edit_post"
                    android:layout_marginBottom="8dp">

                    <LinearLayout
                        android:id="@+id/layoutBackPlaceholder"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_camera"
                            android:tint="#999999" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bấm để chọn ảnh mặt sau"
                            android:textSize="13sp"
                            android:textColor="@color/text_hint"
                            android:layout_marginTop="8dp" />

                    </LinearLayout>

                    <ImageView
                        android:id="@+id/imgBack"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone" />

                </FrameLayout>

                <!-- Thông báo bảo mật -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="10dp"
                    android:background="@drawable/bg_amenity_row"
                    android:layout_marginTop="12dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_lock"
                        app:tint="#2E7D32" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chúng tôi cam kết bảo mật thông tin cá nhân của bạn và chỉ dùng cho mục đích xác thực danh tính."
                        android:textSize="11sp"
                        android:textColor="#2E7D32"
                        android:layout_marginStart="10dp"
                        android:textStyle="italic" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Quy định & Cam kết -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="14dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#F8F9FA">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quy định &amp; Trách nhiệm của người đăng bài"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1. Cung cấp thông tin phòng trọ và hình ảnh thực tế, chính xác.\n2. Tuyệt đối không đăng tải thông tin sai lệch hoặc gây nhầm lẫn.\n3. Người đăng tự chịu trách nhiệm về tính pháp lý và an toàn của căn hộ.\n4. Phản hồi thắc mắc của khách thuê một cách lịch sự, đúng hẹn."
                    android:textSize="13sp"
                    android:textColor="#555555"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Điều khoản cam kết -->
        <CheckBox
            android:id="@+id/cbCommit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:text="Tôi đã đọc và cam đoan tuân thủ mọi quy định trên."
            android:textSize="13sp"
            android:textColor="@color/text_primary"
            android:buttonTint="#1976D2"
            android:paddingStart="8dp" />

        <!-- Nút gửi -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSubmitVerify"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Gửi yêu cầu xác minh"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            app:backgroundTint="#1976D2"
            app:cornerRadius="14dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>