<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/corner_radius_10"
    app:cardCornerRadius="@dimen/padding_large"
    app:cardElevation="@dimen/elevation_3"
    app:cardBackgroundColor="@color/bg_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Ảnh phòng -->
        <FrameLayout
            android:layout_width="@dimen/dimen_110dp"
            android:layout_height="match_parent"
            android:minHeight="@dimen/dimen_110dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgRoom"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:background="@color/gray_200"
                app:shapeAppearanceOverlay="@style/RoundedImageLeft" />

        </FrameLayout>

        <!-- Thông tin bên phải -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="@dimen/padding_medium">

            <!-- Tiêu đề -->
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/txt_tieu_e_phong"
                android:textSize="@dimen/dimen_13_5sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingExtra="@dimen/stroke_2" />

            <!-- Địa chỉ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/elevation_6">

                <ImageView
                    android:layout_width="@dimen/dimen_11dp"
                    android:layout_height="@dimen/dimen_11dp"
                    android:src="@drawable/ic_location"
                    app:tint="@color/text_hint"
                    android:layout_marginEnd="@dimen/elevation_4" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_quan_thanh_pho"
                    android:textSize="@dimen/dimen_11_5sp"
                    android:textColor="@color/text_hint"
                    android:maxLines="1"
                    android:ellipsize="end" />

            </LinearLayout>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvPostedDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/elevation_4"
                android:text="@string/txt_ang_ngay_01_01_2026"
                android:textSize="@dimen/text_size_11"
                android:textColor="@color/text_hint"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />

            <!-- Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- Giá + Diện tích -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Tag giá -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:layout_width="@dimen/elevation_3"
                        android:layout_height="@dimen/spacing_14"
                        android:background="@color/secondary"
                        android:layout_marginEnd="@dimen/dimen_5dp" />

                    <com.google.android.material.textview.MaterialTextView
                        android:id="@+id/tvPrice"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/txt_0_thang"
                        android:textSize="@dimen/dimen_12_5sp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:textColor="@color/secondary" />

                </LinearLayout>

                <!-- Trạng thái badge -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvRoomStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/elevation_6"
                    android:text="@string/txt_con_phong"
                    android:textSize="@dimen/text_size_11"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <!-- Diện tích badge -->
                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvArea"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_chip_info"
                    android:paddingStart="@dimen/elevation_6"
                    android:paddingEnd="@dimen/elevation_6"
                    android:paddingTop="@dimen/elevation_3"
                    android:paddingBottom="@dimen/elevation_3"
                    android:text="@string/txt_0_m"
                    android:textSize="@dimen/text_size_11"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:visibility="gone" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
