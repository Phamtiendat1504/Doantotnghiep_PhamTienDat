<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardPost"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Top Layout (Main Info) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingTop="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/imgRoom"
                android:layout_width="100dp"
                android:layout_height="85dp"
                android:scaleType="centerCrop"
                android:background="#E0E0E0"
                android:contentDescription="Room Image" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="12dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="#1A1A2E"
                    android:textStyle="bold"
                    android:maxLines="2"
                    android:text="Chưa có tiêu đề" />

                <TextView
                    android:id="@+id/tvLocation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#999999"
                    android:paddingTop="3dp"
                    android:text="Location" />

                <TextView
                    android:id="@+id/tvArea"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#666666"
                    android:paddingTop="2dp"
                    android:text="Area" />

                <TextView
                    android:id="@+id/tvPrice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="#D32F2F"
                    android:textStyle="bold"
                    android:paddingTop="4dp"
                    android:text="Price" />

                <TextView
                    android:id="@+id/tvFeaturedStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:paddingTop="4dp"
                    android:visibility="gone"
                    android:text="Featured Status" />

            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F0F0F0" />

        <!-- Bottom Layout (Status & Basic Actions) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingTop="10dp"
            android:paddingEnd="12dp"
            android:paddingBottom="10dp">

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:paddingStart="12dp"
                android:paddingTop="4dp"
                android:paddingEnd="12dp"
                android:paddingBottom="4dp"
                android:text="Trạng thái" />

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="11sp"
                android:textColor="#999999"
                android:paddingStart="10dp"
                android:text="Date" />

            <TextView
                android:id="@+id/btnDelete"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Xóa"
                android:textSize="13sp"
                android:textColor="#D32F2F"
                android:textStyle="bold"
                android:padding="6dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnFeatured"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đẩy nổi bật"
                android:textSize="13sp"
                android:textColor="#E65100"
                android:textStyle="bold"
                android:padding="6dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btnEditPending"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chỉnh sửa"
                android:textSize="13sp"
                android:textColor="#1976D2"
                android:textStyle="bold"
                android:padding="6dp"
                android:visibility="gone"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Rejected Block -->
        <LinearLayout
            android:id="@+id/layoutRejectReason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="10dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚠️"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvRejectReason"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:textColor="#D32F2F"
                    android:paddingStart="6dp"
                    android:text="Lý do từ chối" />

            </LinearLayout>

            <TextView
                android:id="@+id/btnEditAndRepublish"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✏️ Sửa và đăng lại"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="10dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_btn_action_blue"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- Expired Block -->
        <LinearLayout
            android:id="@+id/layoutExpiredWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvExpiredWarning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="⚠ Bài đăng đã ẩn khỏi kết quả tìm kiếm sau 2 tháng. Bài sẽ tự động xóa sau 1 tháng nữa."
                android:textSize="12sp"
                android:textColor="#795548"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/btnRenew"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=" Gia hạn bài đăng thêm 2 tháng"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:gravity="center"
                android:padding="10dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_btn_action_blue"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
