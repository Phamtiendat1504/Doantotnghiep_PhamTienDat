<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_24">

        <!-- Header -->
        <ImageView
            android:layout_width="@dimen/dimen_64dp"
            android:layout_height="@dimen/dimen_64dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_verified"
            android:layout_marginBottom="@dimen/padding_large"
            app:tint="@color/primary" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/txt_quy_inh_ang_bai_amp_trach"
            android:textSize="@dimen/text_size_18"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/spacing_24" />

        <!-- Phần 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/padding_large">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/txt_1_yeu_cau_ve_noi_dung_bai"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_15"
                android:layout_marginBottom="@dimen/padding_small" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/txt_thong_tin_bat_buoc_chinh_"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="@dimen/elevation_4"
                android:textSize="@dimen/text_size_13" />
        </LinearLayout>

        <!-- Phần 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/padding_large">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/txt_2_trach_nhiem_oi_voi_nguo"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_15"
                android:layout_marginBottom="@dimen/padding_small" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/txt_cam_ket_giu_ung_gia_niem_"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="@dimen/elevation_4"
                android:textSize="@dimen/text_size_13" />
        </LinearLayout>

        <!-- Phần 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="@dimen/spacing_24">

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/txt_3_quy_trinh_kiem_duyet_am"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_size_15"
                android:layout_marginBottom="@dimen/padding_small" />

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/txt_moi_bai_ang_moi_hoac_chin"
                android:textColor="@color/text_secondary"
                android:lineSpacingExtra="@dimen/elevation_4"
                android:textSize="@dimen/text_size_13" />
        </LinearLayout>

        <!-- Footer -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/txt_bang_viec_nhan_ong_y_ban_"
            android:textSize="@dimen/text_size_12"
            android:textStyle="italic"
            android:textColor="@color/primary"
            android:gravity="center"
            android:layout_marginBottom="@dimen/padding_xlarge" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAcceptRules"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_54dp"
            android:text="@string/txt_toi_a_hieu_va_ong_y"
            android:textStyle="bold"
            app:cornerRadius="@dimen/padding_medium"
            app:backgroundTint="@color/primary" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>