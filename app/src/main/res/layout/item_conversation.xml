<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="@dimen/padding_large"
    android:paddingEnd="@dimen/padding_large"
    android:paddingTop="@dimen/padding_medium"
    android:paddingBottom="@dimen/padding_medium"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Avatar người kia -->
    <FrameLayout
        android:layout_width="@dimen/dimen_54dp"
        android:layout_height="@dimen/dimen_54dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="@dimen/dimen_54dp"
            android:layout_height="@dimen/dimen_54dp"
            app:cardCornerRadius="@dimen/dimen_27dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/color_F1F3F4">

            <ImageView
                android:id="@+id/ivConvAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_person"
                android:padding="@dimen/padding_medium"
                app:tint="@color/text_hint" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Unread badge nhỏ ở góc avatar -->
        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvConvUnreadBadge"
            android:layout_width="@dimen/padding_xlarge"
            android:layout_height="@dimen/padding_xlarge"
            android:layout_gravity="top|end"
            android:gravity="center"
            android:textSize="@dimen/text_size_10"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_badge_red"
            android:visibility="gone" />

    </FrameLayout>

    <!-- Nội dung -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="@dimen/padding_medium">

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvConvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_ten_nguoi_dung"
            android:textSize="@dimen/text_size_15"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvConvLastMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/txt_tin_nhan_cuoi"
            android:textSize="@dimen/text_size_13"
            android:textColor="@color/text_hint"
            android:layout_marginTop="@dimen/stroke_2"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- Thời gian -->
    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/tvConvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/padding_small"
        android:text="@string/txt_12_00"
        android:textSize="@dimen/text_size_12"
        android:textColor="@color/text_hint"
        android:layout_gravity="top"
        android:layout_marginTop="@dimen/stroke_2" />

</LinearLayout>
