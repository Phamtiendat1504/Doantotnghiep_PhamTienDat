<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:paddingStart="@dimen/padding_xlarge"
        android:paddingEnd="@dimen/padding_xlarge"
        android:paddingTop="@dimen/padding_large"
        android:paddingBottom="@dimen/padding_large"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="@dimen/dimen_36dp"
            android:layout_height="@dimen/dimen_36dp"
            android:src="@drawable/ic_back"
            app:tint="@color/bg_white"
            android:padding="@dimen/elevation_6" />

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_lich_hen"
            android:textSize="@dimen/text_size_20"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginStart="@dimen/padding_medium" />

    </LinearLayout>

    <!-- Khu vực Lọc và Tìm kiếm -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_white"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/padding_large"
        android:paddingTop="@dimen/padding_medium"
        android:paddingBottom="@dimen/padding_medium">

        <!-- Thanh tìm kiếm -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/padding_medium"
            app:boxCornerRadiusTopStart="@dimen/padding_small"
            app:boxCornerRadiusTopEnd="@dimen/padding_small"
            app:boxCornerRadiusBottomStart="@dimen/padding_small"
            app:boxCornerRadiusBottomEnd="@dimen/padding_small"
            app:boxStrokeColor="@color/primary"
            app:startIconDrawable="@android:drawable/ic_menu_search"
            android:hint="@string/txt_tim_kiem_ten_so_ien_thoai">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edtSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1"
                android:textSize="@dimen/text_size_14" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Bộ lọc trạng thái dạng Dropdown Menu -->


        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/menuFilterLayout"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:boxCornerRadiusTopStart="@dimen/padding_small"
            app:boxCornerRadiusTopEnd="@dimen/padding_small"
            app:boxCornerRadiusBottomStart="@dimen/padding_small"
            app:boxCornerRadiusBottomEnd="@dimen/padding_small"
            app:boxStrokeColor="@color/primary"
            android:hint="@string/txt_trang_thai_lich_hen">

            <AutoCompleteTextView
                android:id="@+id/menuFilter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textSize="@dimen/text_size_15"
                android:textColor="@color/color_333333"
                android:fontFamily="sans-serif-medium"
                android:paddingTop="@dimen/spacing_14"
                android:paddingBottom="@dimen/spacing_14" />

        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- Tab chuyển đổi vai trò (chỉ hiện với user đã xác minh có cả 2 chiều lịch hẹn) -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutRole"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:visibility="gone"
        app:tabGravity="fill"
        app:tabMode="fixed"
        app:tabSelectedTextColor="@color/primary"
        app:tabTextColor="@color/text_hint"
        app:tabIndicatorColor="@color/primary"
        app:tabIndicatorHeight="@dimen/elevation_3"
        app:tabRippleColor="@color/primary" />

    <View
        android:layout_width="match_parent"
        android:layout_height="@dimen/stroke_1"
        android:background="@color/gray_300" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipeRefreshLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/layoutAppointments"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_14">

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/image_size_40" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_chua_co_lich_hen_nao"
                    android:textSize="@dimen/text_size_14"
                    android:textColor="@color/text_hint"
                    android:gravity="center"
                    android:padding="@dimen/image_size_40"
                    android:visibility="gone" />

            </LinearLayout>

        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>