<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/padding_large"
    android:layout_marginVertical="@dimen/dimen_5dp"
    app:cardCornerRadius="@dimen/padding_large"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/bg_white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_14">

        <!-- Icon -->
        <FrameLayout
            android:id="@+id/iconWrap"
            android:layout_width="@dimen/dimen_44dp"
            android:layout_height="@dimen/dimen_44dp"
            android:background="@drawable/bg_notif_icon"
            android:layout_marginEnd="@dimen/padding_medium">

            <ImageView
                android:id="@+id/ivIcon"
                android:layout_width="@dimen/dimen_22dp"
                android:layout_height="@dimen/dimen_22dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_notification"
                android:contentDescription="icon" />
        </FrameLayout>

        <!-- Text -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvNotifTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/post_info_label_title"
                android:textSize="@dimen/dimen_13_5sp"
                android:textStyle="bold"
                android:textColor="@color/color_0F172A"
                android:maxLines="1"
                android:ellipsize="end" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvNotifMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/stroke_2"
                android:text="@string/txt_noi_dung_thong_bao"
                android:textSize="@dimen/dimen_12_5sp"
                android:textColor="@color/color_64748B"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingExtra="@dimen/stroke_2" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/tvNotifTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dimen_5dp"
                android:text="@string/txt_vua_xong"
                android:textSize="@dimen/text_size_11"
                android:textColor="@color/color_94A3B8"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Unread dot -->
        <View
            android:id="@+id/unreadDot"
            android:layout_width="@dimen/dimen_9dp"
            android:layout_height="@dimen/dimen_9dp"
            android:layout_marginStart="@dimen/padding_small"
            android:background="@drawable/bg_unread_dot"
            android:visibility="gone" />
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
