<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dialog_header"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/padding_large">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_quet_ma_e_thanh_toan"
            android:textSize="@dimen/dimen_17sp"
            android:textStyle="bold"
            android:textColor="@android:color/white" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/tvQrPackageName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_goi_10_luot_30_000"
            android:textSize="@dimen/text_size_13"
            android:textColor="@color/color_CCFFFFFF"
            android:layout_marginTop="@dimen/elevation_3" />

    </LinearLayout>

    <!-- Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/padding_large"
        android:background="@android:color/white">

        <!-- QR Image -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="@dimen/dimen_220dp"
            android:layout_height="@dimen/dimen_220dp"
            app:cardCornerRadius="@dimen/padding_medium"
            app:cardElevation="@dimen/elevation_4"
            android:layout_marginBottom="@dimen/padding_medium">

            <ImageView
                android:id="@+id/imgVietQR"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:padding="@dimen/padding_small"
                android:contentDescription="Mã QR VietQR thanh toán" />

        </com.google.android.material.card.MaterialCardView>

        <!-- Thông tin chuyển khoản -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_amenity_row"
            android:padding="@dimen/padding_medium"
            android:layout_marginBottom="@dimen/padding_medium">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/elevation_4">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/txt_ngan_hang"
                    android:textSize="@dimen/text_size_12"
                    android:textColor="@color/color_888888" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvQrBank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_mb_bank"
                    android:textSize="@dimen/text_size_12"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/elevation_4">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/txt_so_tai_khoan"
                    android:textSize="@dimen/text_size_12"
                    android:textColor="@color/color_888888" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvQrAccountNo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_0889740127"
                    android:textSize="@dimen/text_size_12"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="@dimen/elevation_4">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/txt_chu_tai_khoan"
                    android:textSize="@dimen/text_size_12"
                    android:textColor="@color/color_888888" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvQrAccountName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_pham_tien_dat"
                    android:textSize="@dimen/text_size_12"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.textview.MaterialTextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/txt_noi_dung_ck"
                    android:textSize="@dimen/text_size_12"
                    android:textColor="@color/color_888888" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/tvQrTransferNote"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_mua_luot_dang_bai"
                    android:textSize="@dimen/text_size_12"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />

            </LinearLayout>

        </LinearLayout>

        <!-- Lưu ý -->
        <com.google.android.material.textview.MaterialTextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/padding_large"
            android:text="@string/txt_luu_y_vui_long_chuyen_ung"
            android:textAlignment="center"
            android:textColor="@color/warning"
            android:gravity="center" />

        <!-- Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmPayment"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_48dp"
            android:text="@string/txt_toi_a_chuyen_khoan_xong"
            android:textSize="@dimen/text_size_14"
            android:textAllCaps="false"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            app:cornerRadius="@dimen/padding_medium"
            android:layout_marginBottom="@dimen/padding_small" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelPayment"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/image_size_40"
            android:text="@string/txt_huy_giao_dich"
            android:textAllCaps="false"
            android:textColor="@color/color_888888" />

    </LinearLayout>

</LinearLayout>
