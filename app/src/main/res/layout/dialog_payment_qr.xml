<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dialog_header"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quét mã để thanh toán"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@android:color/white" />

        <TextView
            android:id="@+id/tvQrPackageName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⭐ +10 lượt — 30.000đ"
            android:textSize="13sp"
            android:textColor="#CCffffff"
            android:layout_marginTop="3dp" />

    </LinearLayout>

    <!-- Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="16dp"
        android:background="@android:color/white">

        <!-- QR Image -->
        <androidx.cardview.widget.CardView
            android:layout_width="220dp"
            android:layout_height="220dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/imgVietQR"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:padding="8dp"
                android:contentDescription="Mã QR VietQR thanh toán" />

        </androidx.cardview.widget.CardView>

        <!-- Thông tin chuyển khoản -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_amenity_row"
            android:padding="12dp"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Ngân hàng"
                    android:textSize="12sp"
                    android:textColor="#888888" />

                <TextView
                    android:id="@+id/tvQrBank"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MB Bank"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Số tài khoản"
                    android:textSize="12sp"
                    android:textColor="#888888" />

                <TextView
                    android:id="@+id/tvQrAccountNo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0889740127"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="4dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Chủ tài khoản"
                    android:textSize="12sp"
                    android:textColor="#888888" />

                <TextView
                    android:id="@+id/tvQrAccountName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PHAM TIEN DAT"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A2E" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Nội dung CK"
                    android:textSize="12sp"
                    android:textColor="#888888" />

                <TextView
                    android:id="@+id/tvQrTransferNote"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mua luot dang bai"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />

            </LinearLayout>

        </LinearLayout>

        <!-- Lưu ý -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:text="⚡ Lưu ý: Vui lòng chuyển ĐÚNG số tiền và nội dung. Hệ thống sẽ tự động xác nhận và cộng lượt trong vòng 5-10 giây!"
            android:textAlignment="center"
            android:textColor="#E65100"
            android:gravity="center" />

        <!-- Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConfirmPayment"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="✅  Tôi đã chuyển khoản xong"
            android:textSize="14sp"
            android:textAllCaps="false"
            android:textStyle="bold"
            app:backgroundTint="@color/primary"
            app:cornerRadius="12dp"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCancelPayment"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="Hủy giao dịch"
            android:textAllCaps="false"
            android:textColor="#888888" />

    </LinearLayout>

</LinearLayout>
