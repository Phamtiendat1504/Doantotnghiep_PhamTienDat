<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="vertical"
        android:paddingTop="@dimen/dimen_48dp"
        android:paddingBottom="@dimen/padding_large"
        android:paddingHorizontal="@dimen/padding_large">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnBackSearch"
                android:layout_width="@dimen/image_size_40"
                android:layout_height="@dimen/image_size_40"
                android:src="@drawable/ic_back"
                android:padding="@dimen/padding_small"
                app:tint="@color/white"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Quay lại"/>

            <com.google.android.material.textview.MaterialTextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/txt_tim_kiem_nguoi_dung"
                android:textColor="@color/white"
                android:textSize="@dimen/text_size_18"
                android:textStyle="bold"
                android:layout_marginStart="@dimen/padding_small"/>
        </LinearLayout>

        <!-- Search bar -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="@dimen/dimen_52dp"
            android:layout_marginTop="@dimen/padding_medium"
            app:cardCornerRadius="@dimen/dimen_26dp"
            app:cardElevation="@dimen/elevation_4">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="@dimen/padding_large">

                <ImageView
                    android:layout_width="@dimen/padding_xlarge"
                    android:layout_height="@dimen/padding_xlarge"
                    android:src="@drawable/ic_search"
                    app:tint="@color/text_hint"
                    android:contentDescription="Tìm kiếm"/>

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/edtSearchProfile"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginStart="@dimen/corner_radius_10"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="@string/txt_nhap_ten_nguoi_can_tim"
                    android:textSize="@dimen/text_size_15"
                    android:inputType="textPersonName"
                    android:imeOptions="actionSearch"
                    android:singleLine="true"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progressSearch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/spacing_24"
        android:visibility="gone"/>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/layoutEmptySearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="@dimen/dimen_48dp"
        android:visibility="visible">

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/txt_tim_nguoi_dung"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_size_20"
            android:textStyle="bold"/>

        <com.google.android.material.textview.MaterialTextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/padding_small"
            android:text="@string/txt_go_ten_e_tim_nguoi_dung"
            android:textSize="@dimen/text_size_15"
            android:textColor="@color/text_secondary"
            android:gravity="center"/>
    </LinearLayout>

    <!-- Results list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSearchProfile"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="@dimen/padding_small"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/padding_large"
        android:paddingBottom="@dimen/padding_large"/>

</LinearLayout>
