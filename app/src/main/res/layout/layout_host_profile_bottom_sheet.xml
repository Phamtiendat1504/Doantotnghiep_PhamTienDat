<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_top_rounded_white">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="#E0E0E0"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <androidx.cardview.widget.CardView
            android:layout_width="80dp"
            android:layout_height="80dp"
            app:cardCornerRadius="40dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F5F5F5">
            <ImageView
                android:id="@+id/ivSheetAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_person"
                android:scaleType="centerCrop"
                app:tint="#BDBDBD"/>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="16dp">

            <TextView
                android:id="@+id/tvSheetName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên chủ trọ"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#1A1A1A"/>

            <TextView
                android:id="@+id/tvSheetStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chủ nhà"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginTop="4dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_badge_tenant"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:backgroundTint="#E8F5E9">
                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_check_circle"
                    />
                <TextView
                    android:id="@+id/tvSheetVerified"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã xác minh"
                    android:textSize="12sp"
                    android:textColor="#2E7D32"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thông tin liên hệ"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#1A1A1A"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_phone"
            app:tint="#666666"/>
        <TextView
            android:id="@+id/tvSheetPhone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0999 999 999"
            android:textSize="15sp"
            android:textColor="#333333"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_email"
            app:tint="#666666"/>
        <TextView
            android:id="@+id/tvSheetEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="email@example.com"
            android:textSize="15sp"
            android:textColor="#333333"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_calendar_clear"
            app:tint="#666666"/>
        <TextView
            android:id="@+id/tvSheetJoinDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ngày tham gia: 01/01/2023"
            android:textSize="15sp"
            android:textColor="#333333"
            android:layout_marginStart="12dp"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSheetChat"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="54dp"
            android:layout_marginEnd="8dp"
            android:text="Nhắn tin"
            android:textAllCaps="false"
            app:icon="@drawable/ic_ai"
            app:iconGravity="textStart"
            app:cornerRadius="12dp"
            app:strokeColor="#E0E0E0"
            android:textColor="@color/primary"
            app:iconTint="@color/primary"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSheetCall"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="54dp"
            android:layout_marginStart="8dp"
            android:text="Gọi điện"
            android:textAllCaps="false"
            app:icon="@drawable/ic_phone"
            app:iconGravity="textStart"
            app:cornerRadius="12dp"
            app:backgroundTint="@color/primary"/>

    </LinearLayout>

</LinearLayout>
