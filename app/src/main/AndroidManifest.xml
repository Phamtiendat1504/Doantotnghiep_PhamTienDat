<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.CAMERA" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Doantotnghiep">

        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="@string/google_maps_key" />

        <activity
            android:name=".View.Auth.LoginActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan" />

        <activity
            android:name=".View.Auth.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".View.Auth.ForgotPasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".View.Auth.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Doantotnghiep">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".View.Auth.WelcomeActivity"
            android:exported="false"
            android:theme="@style/Theme.Doantotnghiep" />

        <activity
            android:name=".MainActivity"
            android:exported="false" />


        <activity
            android:name=".View.Auth.ResetPasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".View.Auth.PersonalInfoActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".View.Auth.ChangePasswordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".View.Auth.VerifyLandlordActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".View.Auth.CccdCameraActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity
            android:name=".View.Auth.MyPostsActivity"
            android:exported="false" />
        <activity
            android:name=".View.Auth.SearchResultsActivity"
            android:exported="false" />
        <activity
            android:name=".View.Auth.RoomDetailActivity"
            android:exported="false" />
        <activity
            android:name=".View.Auth.LocationPickerActivity"
            android:exported="false" />
        <activity
            android:name=".View.Auth.SavedPostsActivity"
            android:exported="false" />
        <activity android:name=".View.Auth.BookingActivity" android:exported="false" />
        <activity android:name=".View.Auth.MyAppointmentsActivity" android:exported="false" />
        <activity
            android:name=".View.Auth.ImageViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.NoActionBar" />
        <activity
            android:name=".View.Auth.EditPostActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustPan" />
        <activity
            android:name=".View.Auth.MyPostDetailActivity"
            android:exported="false" />
        <activity
            android:name=".View.Auth.AppointmentRoomDetailActivity"
            android:exported="false" />

        <activity
            android:name=".View.Auth.SavedPostDetailActivity"
            android:exported="false" />

        <activity
            android:name=".View.Auth.PostSuccessActivity"
            android:exported="false" />

        <activity
            android:name=".View.Auth.NotificationsActivity"
            android:exported="false" />
        <activity
            android:name=".View.Auth.SettingsActivity"
            android:exported="false" />
        <activity
            android:name=".View.Auth.InfoContentActivity"
            android:exported="false" />



        <activity
            android:name=".View.Auth.ChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".View.Auth.ConversationsActivity"
            android:exported="false" />

        <activity
            android:name=".View.Auth.SearchProfileActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".View.Auth.UserProfileActivity"
            android:exported="false" />

        <!-- Firebase Messaging Service - nhận Push Notification từ FCM -->

        <service
            android:name=".Utils.MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>


        <!-- Cấu hình FileProvider cho Camera -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.doantotnghiep.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
